---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { SITE_TITLE } from '../consts';

const toolCount = (await getCollection('tools')).length;
---

<!doctype html>
<html lang="en">
<head>
	<BaseHead
		title={`Pricing — Free to Use | ${SITE_TITLE}`}
		description={`${SITE_TITLE} is free to use. Browse ${toolCount}+ AI tools, read reviews, and submit your own tool to reach thousands of AI enthusiasts.`}
	/>
</head>
<body>
	<Header />
	<main>

		<section class="page-hero">
			<div class="container">
				<Breadcrumb crumbs={[{ label: 'Home', href: '/' }, { label: 'Pricing' }]} />
				<div class="hero-badge">Pricing</div>
				<h1>Simple, Transparent Pricing</h1>
				<p>Browse and discover AI tools for free — forever. Submit your tool to reach our growing audience.</p>
			</div>
		</section>

		<div class="container pricing-body">

			<div class="plans-grid">

				<div class="plan-card">
					<div class="plan-head">
						<span class="plan-icon">🔍</span>
						<h2>Browse</h2>
						<div class="plan-price">
							<span class="price">$0</span>
							<span class="period">forever</span>
						</div>
					</div>
					<ul class="plan-features">
						<li><span class="check">✓</span> Browse all {toolCount}+ AI tools</li>
						<li><span class="check">✓</span> Filter by category & pricing</li>
						<li><span class="check">✓</span> Read tutorials and guides</li>
						<li><span class="check">✓</span> Access tool reviews & ratings</li>
						<li><span class="check">✓</span> View tool alternatives</li>
						<li><span class="check">✓</span> No account required</li>
					</ul>
					<a href="/tools/" class="plan-btn plan-btn--secondary">Browse Tools</a>
				</div>

				<div class="plan-card plan-card--featured">
					<div class="plan-badge">Most Popular</div>
					<div class="plan-head">
						<span class="plan-icon">🚀</span>
						<h2>Submit a Tool</h2>
						<div class="plan-price">
							<span class="price">Free</span>
							<span class="period">during beta</span>
						</div>
					</div>
					<ul class="plan-features">
						<li><span class="check">✓</span> Listed in our tools directory</li>
						<li><span class="check">✓</span> Appear in category pages</li>
						<li><span class="check">✓</span> Indexed by search engines</li>
						<li><span class="check">✓</span> Reach AI enthusiasts & pros</li>
						<li><span class="check">✓</span> Featured consideration</li>
					</ul>
					<a href="/submit/" class="plan-btn plan-btn--primary">Submit Your Tool</a>
				</div>

				<div class="plan-card plan-card--soon">
					<div class="plan-head">
						<span class="plan-icon">⭐</span>
						<h2>Featured Listing</h2>
						<div class="plan-price">
							<span class="price coming">Coming</span>
							<span class="period">soon</span>
						</div>
					</div>
					<ul class="plan-features">
						<li><span class="check check--muted">✓</span> Homepage priority placement</li>
						<li><span class="check check--muted">✓</span> Category page top slot</li>
						<li><span class="check check--muted">✓</span> Featured badge on tool card</li>
						<li><span class="check check--muted">✓</span> Newsletter mention</li>
						<li><span class="check check--muted">✓</span> Social media shoutout</li>
						<li><span class="check check--muted">✓</span> Performance analytics</li>
					</ul>
					<a href="/contact/?subject=Featured+Listing" class="plan-btn plan-btn--secondary">Join Waitlist</a>
				</div>

			</div>

			<!-- Trust strip -->
			<div class="trust-strip">
				<div class="trust-item"><span>🔒</span> No account required to browse</div>
				<div class="trust-item"><span>✅</span> Every tool manually reviewed</div>
				<div class="trust-item"><span>⚡</span> Free listings during beta</div>
				<div class="trust-item"><span>📬</span> 48-hour submission review</div>
			</div>

			<!-- FAQ -->
			<section class="faq-section">
				<h2>Frequently Asked Questions</h2>
				<div class="faq-list">
					<details class="faq-item">
						<summary>Is {SITE_TITLE} really free to use?</summary>
						<p>Yes, completely. Browsing all {toolCount}+ tools, reading reviews, tutorials, and articles costs nothing — no account or credit card required. We plan to introduce optional paid features for tool publishers in the future, but browsing will always be free.</p>
					</details>
					<details class="faq-item">
						<summary>How do I submit my AI tool?</summary>
						<p>Use our <a href="/submit/">Submit a Tool</a> form. Fill in your tool's name, URL, description, category, and pricing model. We review every submission manually and typically respond within 48 hours.</p>
					</details>
					<details class="faq-item">
						<summary>What makes a tool eligible for listing?</summary>
						<p>Any legitimate, working AI-powered tool is eligible. We list tools across all 22 categories — from productivity and coding to health and legal. We don't list tools that are broken, scams, or in extreme early access with no working product.</p>
					</details>
					<details class="faq-item">
						<summary>When will featured listings be available?</summary>
						<p>We're currently finalising our featured listing packages. <a href="/contact/?subject=Featured+Listing">Contact us</a> to be added to the waitlist and receive an early-adopter rate when we launch.</p>
					</details>
					<details class="faq-item">
						<summary>Do featured listings affect tool ratings?</summary>
						<p>No. Our editorial ratings and reviews are completely independent of any commercial relationship. A tool cannot pay for a higher rating. See our <a href="/rating-methodology/">rating methodology</a> for full details.</p>
					</details>
					<details class="faq-item">
						<summary>Can I update my tool's information after submission?</summary>
						<p>Yes. Use our <a href="/contact/">contact form</a> with the subject "Update Listing" and include the tool name and what needs to change.</p>
					</details>
				</div>
			</section>

		</div>
	</main>
	<Footer />
</body>
</html>

<style>
.page-hero {
	background: linear-gradient(135deg, var(--primary-light) 0%, var(--bg) 100%);
	border-bottom: 1px solid var(--border);
	padding: 2.5rem 0 2rem;
}
.hero-badge {
	display: inline-block;
	background: var(--accent);
	color: #fff;
	font-size: 0.72rem;
	font-weight: 700;
	letter-spacing: 0.08em;
	text-transform: uppercase;
	padding: 0.25rem 0.8rem;
	border-radius: 99px;
	margin: 0.75rem 0 0.6rem;
}
.page-hero h1 { font-size: clamp(1.8rem, 4vw, 2.6rem); margin-bottom: 0.5rem; }
.page-hero p { color: rgb(var(--gray)); max-width: 540px; }

.pricing-body { padding: 2.5rem 0 4rem; }

.plans-grid {
	display: grid;
	grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
	gap: 1.5rem;
	margin-bottom: 2rem;
	align-items: start;
}

.plan-card {
	position: relative;
	background: var(--bg);
	border: 1px solid var(--border);
	border-radius: var(--radius);
	padding: 2rem 1.75rem;
	display: flex;
	flex-direction: column;
	gap: 1rem;
}
.plan-card--featured {
	border-color: var(--primary);
	box-shadow: 0 0 0 1px rgba(0,200,150,0.2), 0 8px 32px rgba(0,200,150,0.1);
}
.plan-card--soon { opacity: 0.85; }

.plan-badge {
	position: absolute;
	top: -12px; left: 50%;
	transform: translateX(-50%);
	background: var(--primary);
	color: #fff;
	font-size: 0.7rem;
	font-weight: 700;
	text-transform: uppercase;
	letter-spacing: 0.06em;
	padding: 0.2rem 0.85rem;
	border-radius: 99px;
	white-space: nowrap;
}
.plan-head { text-align: center; }
.plan-icon { font-size: 2.25rem; display: block; margin-bottom: 0.4rem; }
.plan-head h2 { font-size: 1.25rem; margin-bottom: 0.65rem; }
.plan-price { display: flex; align-items: baseline; justify-content: center; gap: 0.4rem; }
.price { font-size: 2.1rem; font-weight: 800; color: rgb(var(--black)); }
.price.coming { font-size: 1.5rem; color: rgb(var(--gray)); }
.period { font-size: 0.83rem; color: rgb(var(--gray)); }

.plan-features {
	list-style: none; padding: 0; margin: 0;
	display: flex; flex-direction: column; gap: 0.55rem;
	border-top: 1px solid var(--border);
	padding-top: 1rem;
}
.plan-features li { font-size: 0.87rem; color: rgb(var(--gray-dark)); display: flex; align-items: flex-start; gap: 0.5rem; }
.check { color: var(--primary); font-weight: 700; flex-shrink: 0; }
.check--muted { color: rgb(var(--gray)); }

.plan-btn {
	display: block; text-align: center;
	padding: 0.75rem 1.25rem;
	border-radius: var(--radius);
	font-weight: 700; font-size: 0.9rem;
	margin-top: auto;
	transition: opacity 0.15s, background 0.15s;
}
.plan-btn--primary { background: var(--primary); color: #fff; }
.plan-btn--primary:hover { background: var(--primary-dark); color: #fff; }
.plan-btn--secondary { background: var(--primary-light); color: var(--primary); }
.plan-btn--secondary:hover { background: rgba(0,135,90,0.15); }

/* Trust strip */
.trust-strip {
	display: flex;
	flex-wrap: wrap;
	gap: 0.75rem 1.5rem;
	justify-content: center;
	padding: 1.25rem;
	background: var(--bg-alt);
	border: 1px solid var(--border);
	border-radius: var(--radius);
	margin-bottom: 3rem;
}
.trust-item {
	display: flex; align-items: center; gap: 0.4rem;
	font-size: 0.83rem; color: rgb(var(--gray-dark));
}
.trust-item span { font-size: 1rem; }

/* FAQ */
.faq-section h2 { font-size: 1.3rem; margin-bottom: 1.25rem; }
.faq-list { display: flex; flex-direction: column; gap: 0.5rem; max-width: 760px; }
.faq-item {
	background: var(--bg);
	border: 1px solid var(--border);
	border-radius: var(--radius);
	overflow: hidden;
}
.faq-item summary {
	padding: 1rem 1.25rem;
	font-size: 0.95rem;
	font-weight: 600;
	cursor: pointer;
	list-style: none;
	display: flex;
	align-items: center;
	justify-content: space-between;
	user-select: none;
	color: rgb(var(--black));
}
.faq-item summary::-webkit-details-marker { display: none; }
.faq-item summary::after {
	content: '+';
	font-size: 1.2rem;
	font-weight: 400;
	color: var(--primary);
	transition: transform 0.2s;
	flex-shrink: 0;
	margin-left: 0.75rem;
}
.faq-item[open] summary::after { content: '−'; }
.faq-item summary:hover { background: var(--primary-light); }
.faq-item p {
	padding: 0 1.25rem 1rem;
	font-size: 0.88rem;
	color: rgb(var(--gray-dark));
	line-height: 1.7;
	margin: 0;
}
.faq-item a { color: var(--primary); }
.faq-item a:hover { text-decoration: underline; }
</style>
