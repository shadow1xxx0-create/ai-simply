---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { SITE_TITLE, TOOL_CATEGORIES } from '../consts';
---

<!doctype html>
<html lang="en">
<head>
	<BaseHead
		title={`Submit a Tool | ${SITE_TITLE}`}
		description="Submit your AI tool to the AI Briefs directory. Reach thousands of AI enthusiasts, developers, and professionals."
	/>
</head>
<body>
<Header />

<section class="page-header">
	<div class="container">
		<Breadcrumb crumbs={[{ label: 'Home', href: '/' }, { label: 'Submit a Tool' }]} />
		<h1>Submit a Tool</h1>
		<p>Know a great AI tool that should be in our directory? We review every submission.</p>
	</div>
</section>

<main class="container submit-body">
	<div class="submit-grid">

		<!-- Form -->
		<div class="submit-card">
			<p class="submit-intro">Fill in the details below. We list free, freemium, and paid tools across all 22 categories. Submissions are reviewed within 48 hours.</p>

			<div id="form-success" class="form-success" hidden>
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
				Submitted! We'll review within 48 hours and be in touch.
			</div>
			<div id="form-error" class="form-error" hidden>
				Something went wrong. Please try again or <a href="/contact/">contact us</a> directly.
			</div>

			<form id="submit-form" action="https://formspree.io/f/xkopzklp" method="POST" novalidate>
				<input type="hidden" name="_subject" value="New tool submission — AI Briefs" />

				<div class="field-row">
					<div class="field">
						<label for="tool-name">Tool Name <span class="req">*</span></label>
						<input type="text" id="tool-name" name="tool-name" required placeholder="e.g. My AI Tool" autocomplete="off" />
					</div>
					<div class="field">
						<label for="tool-url">Website URL <span class="req">*</span></label>
						<input type="url" id="tool-url" name="tool-url" required placeholder="https://mytool.ai" />
					</div>
				</div>

				<div class="field">
					<label for="tool-description">
						Short Description <span class="req">*</span>
						<span class="char-count" id="char-count">0 / 160</span>
					</label>
					<textarea
						id="tool-description"
						name="tool-description"
						required
						maxlength="160"
						rows="3"
						placeholder="What does it do, and who is it for? Be specific. (max 160 characters)"
					></textarea>
				</div>

				<div class="field-row">
					<div class="field">
						<label for="tool-category">Category <span class="req">*</span></label>
						<select id="tool-category" name="tool-category" required>
							<option value="">Select a category…</option>
							{TOOL_CATEGORIES.map(cat => (
								<option value={cat.slug}>{cat.emoji} {cat.name}</option>
							))}
						</select>
					</div>
					<div class="field">
						<label for="tool-pricing">Pricing Model <span class="req">*</span></label>
						<select id="tool-pricing" name="tool-pricing" required>
							<option value="">Select pricing…</option>
							<option value="free">Free</option>
							<option value="freemium">Freemium (free + paid tiers)</option>
							<option value="paid">Paid only</option>
						</select>
					</div>
				</div>

				<div class="field">
					<label for="submitter-email">Your Email <span class="req">*</span></label>
					<input type="email" id="submitter-email" name="submitter-email" required placeholder="you@example.com" autocomplete="email" />
					<span class="field-hint">We'll notify you when your tool goes live.</span>
				</div>

				<div class="field">
					<label for="additional-info">Additional Info <span class="optional">(optional)</span></label>
					<textarea
						id="additional-info"
						name="additional-info"
						rows="2"
						placeholder="Anything else we should know? Key features, launch date, special use cases…"
					></textarea>
				</div>

				<div class="field field--checkbox">
					<label class="checkbox-label">
						<input type="checkbox" id="terms-check" name="terms-agreed" value="yes" required />
						<span>I confirm this tool is real, working, and I'm authorised to submit it. I agree to the <a href="/terms/" target="_blank">Terms of Service</a>.</span>
					</label>
				</div>

				<button type="submit" class="btn btn--primary submit-btn" id="submit-btn">
					Submit Tool →
				</button>
			</form>
		</div>

		<!-- Sidebar -->
		<aside class="submit-sidebar">
			<div class="info-block">
				<h3>What happens next?</h3>
				<ol class="steps-list">
					<li>
						<span class="step-num">1</span>
						<div>
							<strong>We review your submission</strong>
							<p>Our team checks the tool is working, legitimate, and fits our standards — usually within 48 hours.</p>
						</div>
					</li>
					<li>
						<span class="step-num">2</span>
						<div>
							<strong>We email you the outcome</strong>
							<p>You'll receive a confirmation email whether your tool is accepted, needs changes, or wasn't a fit.</p>
						</div>
					</li>
					<li>
						<span class="step-num">3</span>
						<div>
							<strong>Your tool goes live</strong>
							<p>Accepted tools are added to the directory and appear in category pages and search results.</p>
						</div>
					</li>
				</ol>
			</div>

			<div class="info-block info-block--alt">
				<h3>Listing criteria</h3>
				<ul class="criteria-list">
					<li>✓ Must use AI as a core feature</li>
					<li>✓ Must have a working product or demo</li>
					<li>✓ Must have a clear pricing model</li>
					<li>✗ No broken, parked, or scam sites</li>
					<li>✗ No pure white-label repackaging</li>
				</ul>
			</div>

			<div class="info-block">
				<h3>Already listed?</h3>
				<p>Need to update your tool's info or request removal? <a href="/contact/">Contact us</a> with "Update Listing" as the subject.</p>
			</div>
		</aside>

	</div>
</main>

<Footer />
</body>
</html>

<script>
// Character counter
const textarea = document.getElementById('tool-description') as HTMLTextAreaElement;
const counter = document.getElementById('char-count')!;
textarea?.addEventListener('input', () => {
	const len = textarea.value.length;
	counter.textContent = `${len} / 160`;
	counter.style.color = len > 140 ? '#e53e3e' : 'rgb(var(--gray))';
});

// Form submission
const form = document.getElementById('submit-form') as HTMLFormElement;
const btn = document.getElementById('submit-btn') as HTMLButtonElement;
const success = document.getElementById('form-success')!;
const errorEl = document.getElementById('form-error')!;

form?.addEventListener('submit', async (e) => {
	e.preventDefault();
	// Basic URL validation
	const urlInput = document.getElementById('tool-url') as HTMLInputElement;
	try { new URL(urlInput.value); } catch {
		urlInput.setCustomValidity('Please enter a valid URL including https://');
		urlInput.reportValidity();
		return;
	}
	urlInput.setCustomValidity('');

	btn.disabled = true;
	btn.textContent = 'Submitting…';
	success.hidden = true;
	errorEl.hidden = true;

	try {
		const res = await fetch(form.action, {
			method: 'POST',
			body: new FormData(form),
			headers: { Accept: 'application/json' },
		});
		if (res.ok) {
			success.hidden = false;
			form.reset();
			counter.textContent = '0 / 160';
			success.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
		} else {
			errorEl.hidden = false;
		}
	} catch {
		errorEl.hidden = false;
	} finally {
		btn.disabled = false;
		btn.textContent = 'Submit Tool →';
	}
});
</script>

<style>
.page-header {
	background: linear-gradient(135deg, var(--primary-light) 0%, var(--bg) 100%);
	border-bottom: 1px solid var(--border);
	padding: 2.5rem 0 2rem;
}
.page-header h1 { font-size: clamp(1.8rem, 4vw, 2.4rem); margin: 0.5rem 0 0.4rem; }
.page-header p { color: rgb(var(--gray)); }

.submit-body { padding: 2.5rem 0 5rem; }

.submit-grid {
	display: grid;
	grid-template-columns: 1fr;
	gap: 2rem;
}
@media (min-width: 900px) {
	.submit-grid { grid-template-columns: 1fr 300px; align-items: start; }
}

/* Form card */
.submit-card {
	background: var(--bg);
	border: 1px solid var(--border);
	border-radius: var(--radius);
	padding: 2rem;
}
.submit-intro { color: rgb(var(--gray)); font-size: 0.93rem; margin-bottom: 1.5rem; line-height: 1.65; }

.form-success {
	display: flex; align-items: center; gap: 0.5rem;
	background: #e0f5ee; color: #00875a;
	border: 1px solid #00875a33;
	border-radius: var(--radius);
	padding: 0.85rem 1rem;
	font-weight: 600; font-size: 0.9rem;
	margin-bottom: 1.25rem;
}
.form-error {
	background: #fff0f0; color: #c53030;
	border: 1px solid #c5303033;
	border-radius: var(--radius);
	padding: 0.85rem 1rem;
	font-size: 0.9rem;
	margin-bottom: 1.25rem;
}
.form-error a { color: #c53030; font-weight: 600; }

.field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
@media (max-width: 600px) { .field-row { grid-template-columns: 1fr; } }

.field { display: flex; flex-direction: column; gap: 0.35rem; margin-bottom: 1rem; }
.field label { font-size: 0.85rem; font-weight: 700; color: rgb(var(--black)); display: flex; align-items: center; justify-content: space-between; }
.req { color: #e53e3e; }
.optional { font-weight: 400; color: rgb(var(--gray)); font-size: 0.78rem; }
.char-count { font-size: 0.75rem; font-weight: 400; color: rgb(var(--gray)); }
.field-hint { font-size: 0.75rem; color: rgb(var(--gray)); margin-top: 0.1rem; }

.field input,
.field select,
.field textarea {
	padding: 0.65rem 0.9rem;
	border: 1.5px solid var(--border);
	border-radius: var(--radius);
	font-size: 0.9rem;
	font-family: inherit;
	background: var(--bg);
	color: rgb(var(--black));
	transition: border-color 0.15s;
	width: 100%;
}
.field input:focus,
.field select:focus,
.field textarea:focus { outline: none; border-color: var(--primary); }
.field textarea { resize: vertical; min-height: 80px; }

.field--checkbox { flex-direction: row; align-items: flex-start; gap: 0; }
.checkbox-label {
	display: flex; align-items: flex-start; gap: 0.6rem;
	font-size: 0.83rem; color: rgb(var(--gray-dark));
	cursor: pointer; line-height: 1.55;
}
.checkbox-label input[type="checkbox"] { width: 16px; height: 16px; flex-shrink: 0; margin-top: 2px; accent-color: var(--primary); cursor: pointer; }
.checkbox-label a { color: var(--primary); }

.submit-btn {
	width: 100%; padding: 0.9rem;
	font-size: 1rem; cursor: pointer;
	margin-top: 0.25rem;
}
.submit-btn:disabled { opacity: 0.6; cursor: not-allowed; }

/* Sidebar */
.submit-sidebar { display: flex; flex-direction: column; gap: 1rem; }
.info-block {
	padding: 1.25rem 1.4rem;
	border: 1px solid var(--border);
	border-radius: var(--radius);
	background: var(--bg);
}
.info-block--alt { background: var(--bg-alt); }
.info-block h3 { font-size: 0.95rem; margin-bottom: 0.85rem; }
.info-block p { font-size: 0.83rem; color: rgb(var(--gray-dark)); margin: 0; line-height: 1.6; }
.info-block a { color: var(--primary); font-weight: 600; }

.steps-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.85rem; }
.steps-list li { display: flex; align-items: flex-start; gap: 0.75rem; }
.step-num {
	width: 24px; height: 24px;
	background: var(--primary);
	color: #fff;
	border-radius: 50%;
	display: flex; align-items: center; justify-content: center;
	font-size: 0.75rem; font-weight: 800;
	flex-shrink: 0; margin-top: 1px;
}
.steps-list strong { display: block; font-size: 0.85rem; margin-bottom: 0.2rem; }
.steps-list p { font-size: 0.8rem; color: rgb(var(--gray)); margin: 0; line-height: 1.55; }

.criteria-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.45rem; }
.criteria-list li { font-size: 0.83rem; color: rgb(var(--gray-dark)); }
</style>
