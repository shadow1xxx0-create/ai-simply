---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ToolCard from '../components/ToolCard.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION, TOOL_CATEGORIES } from '../consts';

const allTools = (await getCollection('tools'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featuredTools = allTools.filter(t => t.data.featured).slice(0, 6);
const recentTools = allTools.slice(0, 12);
const totalTools = allTools.length;
const freeCount = allTools.filter(t => t.data.pricing === 'free').length;
const freemiumCount = allTools.filter(t => t.data.pricing === 'freemium').length;

// Category counts for tiles
const catCounts: Record<string, number> = {};
for (const t of allTools) {
	catCounts[t.data.category] = (catCounts[t.data.category] ?? 0) + 1;
}

// AI News — RSS fetch
interface NewsItem { title: string; link: string; date: string; source: string; }
const RSS_FEEDS = [
	{ url: 'https://venturebeat.com/category/ai/feed/', source: 'VentureBeat' },
	{ url: 'https://www.theverge.com/rss/ai-artificial-intelligence/index.xml', source: 'The Verge' },
	{ url: 'https://techcrunch.com/category/artificial-intelligence/feed/', source: 'TechCrunch' },
];
let newsItems: NewsItem[] = [];
try {
	const fetched = await Promise.allSettled(RSS_FEEDS.map(f => fetch(f.url, { signal: AbortSignal.timeout(4000) }).then(r => r.text()).then(xml => ({ xml, source: f.source }))));
	for (const r of fetched) {
		if (r.status !== 'fulfilled') continue;
		const { xml, source } = r.value;
		const items = [...xml.matchAll(/<item[\s\S]*?<\/item>/g)];
		for (const m of items.slice(0, 4)) {
			const title = m[0].match(/<title><!\[CDATA\[(.*?)\]\]><\/title>|<title>(.*?)<\/title>/)?.[1] ?? m[0].match(/<title>(.*?)<\/title>/)?.[1] ?? '';
			const link = m[0].match(/<link>(.*?)<\/link>|<link href="(.*?)"/)?.[1] ?? '';
			const date = m[0].match(/<pubDate>(.*?)<\/pubDate>/)?.[1] ?? '';
			if (title && link) newsItems.push({ title: title.trim(), link: link.trim(), date, source });
		}
	}
	newsItems = newsItems.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()).slice(0, 8);
} catch {}

const recentPosts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 6);
---

<!doctype html>
<html lang="en">
<head>
	<BaseHead title={`${SITE_TITLE} — AI Tools Directory`} description={SITE_DESCRIPTION} />
</head>
<body>
<Header />

<main>
	<!-- Hero -->
	<section class="hero">
		<div class="container hero__inner">
			<p class="hero__tag">AI Tools Directory</p>
			<h1>Find the Best AI Tools</h1>
			<p class="hero__sub">Browse {totalTools}+ curated AI tools across 22 categories. Free, freemium, and paid.</p>

			<div class="hero__stats">
				<span><strong>{totalTools}+</strong> tools</span>
				<span class="hero__stats-sep">·</span>
				<span><strong>22</strong> categories</span>
				<span class="hero__stats-sep">·</span>
				<span><strong>{freeCount + freemiumCount}</strong> free or freemium</span>
			</div>

			<div class="hero__search">
				<input
					type="search"
					id="global-search"
					placeholder="Search AI tools..."
					autocomplete="off"
					aria-label="Search AI tools"
				/>
				<button type="button" class="hero__search-btn" aria-label="Search">
					<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
				</button>
			</div>
		</div>
	</section>

	<!-- Featured Tools -->
	{featuredTools.length > 0 && (
		<section class="section section--alt">
			<div class="container">
				<div class="section-header">
					<h2 class="section-heading">
						<span class="section-heading__dot"></span>
						Featured Tools
					</h2>
					<a href="/tools/" class="section-link">Browse all →</a>
				</div>
				<div class="featured-grid">
					{featuredTools.map(tool => {
						const cat = TOOL_CATEGORIES.find(c => c.slug === tool.data.category);
						const domain = new URL(tool.data.url).hostname;
						const favicon = `https://www.google.com/s2/favicons?domain=${domain}&sz=64`;
						return (
							<a href={`/tools/${tool.id}/`} class="featured-card">
								<div class="featured-card__logo">
									<img src={favicon} alt={tool.data.name} width="36" height="36" loading="lazy"
										onerror={`this.style.display='none';this.nextElementSibling.style.display='flex'`} />
									<span class="featured-card__emoji" style="display:none">{cat?.emoji ?? '🤖'}</span>
								</div>
								<div class="featured-card__body">
									<div class="featured-card__top">
										<h3 class="featured-card__name">{tool.data.name}</h3>
										<span class="featured-card__cat">{cat?.name}</span>
									</div>
									<p class="featured-card__desc">{tool.data.description}</p>
								</div>
								<span class="featured-card__cta">Explore →</span>
							</a>
						);
					})}
				</div>
			</div>
		</section>
	)}

	<!-- Categories -->
	<section class="section">
		<div class="container">
			<div class="section-header">
				<h2 class="section-heading">Browse by Category</h2>
				<a href="/tools/" class="section-link">All tools →</a>
			</div>
			<div class="categories-grid">
				{TOOL_CATEGORIES.map(cat => (
					<a href={`/tools/category/${cat.slug}/`} class="cat-tile">
						<span class="cat-tile__emoji" aria-hidden="true">{cat.emoji}</span>
						<span class="cat-tile__name">{cat.name}</span>
						{catCounts[cat.slug] && <span class="cat-tile__count">{catCounts[cat.slug]}</span>}
					</a>
				))}
			</div>
		</div>
	</section>

	<!-- Recently Added -->
	{recentTools.length > 0 && (
		<section class="section section--alt">
			<div class="container">
				<div class="section-header">
					<h2 class="section-heading">Recently Added</h2>
					<a href="/tools/" class="section-link">View all →</a>
				</div>
				<div class="tools-grid">
					{recentTools.map(tool => (
						<ToolCard
							name={tool.data.name}
							description={tool.data.description}
							category={tool.data.category}
							subcategory={tool.data.subcategory}
							pricing={tool.data.pricing}
							url={tool.data.url}
							slug={tool.id}
							tags={tool.data.tags}
						/>
					))}
				</div>
				<div class="section-cta">
					<a href="/tools/" class="btn btn--outline">Browse All AI Tools</a>
				</div>
			</div>
		</section>
	)}

	<!-- AI News -->
	{newsItems.length > 0 && (
		<section class="section">
			<div class="container">
				<div class="section-header">
					<h2 class="section-heading">Daily AI News</h2>
					<span class="news-live">● Live</span>
				</div>
				<div class="news-grid">
					{newsItems.map(item => (
						<a href={item.link} target="_blank" rel="noopener noreferrer" class="news-card">
							<span class="news-source">{item.source}</span>
							<p class="news-title">{item.title}</p>
						</a>
					))}
				</div>
			</div>
		</section>
	)}

	<!-- Popular Articles -->
	{recentPosts.length > 0 && (
		<section class="section section--alt">
			<div class="container">
				<div class="section-header">
					<h2 class="section-heading">Popular Articles</h2>
					<a href="/blog/" class="section-link">All articles →</a>
				</div>
				<div class="popular-list">
					{recentPosts.map((post, i) => (
						<a href={`/blog/${post.id}/`} class="popular-item">
							<span class="popular-num">{String(i + 1).padStart(2, '0')}</span>
							<div class="popular-body">
								<span class="popular-cat">{post.data.category.replace(/-/g, ' ')}</span>
								<h3 class="popular-title">{post.data.title}</h3>
								<span class="popular-meta"><FormattedDate date={post.data.pubDate} />{post.data.readingTime && <> · {post.data.readingTime}</>}</span>
							</div>
						</a>
					))}
				</div>
			</div>
		</section>
	)}

	<!-- From the Blog -->
	{recentPosts.length > 0 && (
		<section class="section">
			<div class="container">
				<div class="section-header">
					<h2 class="section-heading">AI Explained Simply</h2>
					<a href="/blog/" class="section-link">All articles →</a>
				</div>
				<div class="blog-grid">
					{recentPosts.map(post => (
						<a href={`/blog/${post.id}/`} class="blog-card">
							<div class="blog-card__body">
								<span class="badge">{post.data.category.replace(/-/g, ' ')}</span>
								<h3 class="blog-card__title">{post.data.title}</h3>
								<p class="blog-card__excerpt">{post.data.description}</p>
								<span class="blog-card__meta"><FormattedDate date={post.data.pubDate} /></span>
							</div>
						</a>
					))}
				</div>
			</div>
		</section>
	)}
</main>

<Footer />
</body>
</html>

<script>
	const input = document.getElementById('global-search') as HTMLInputElement;
	if (input) {
		input.addEventListener('keydown', (e) => {
			if (e.key === 'Enter') {
				const q = input.value.trim();
				if (q) window.location.href = `/tools/?q=${encodeURIComponent(q)}`;
			}
		});
		const btn = document.querySelector('.hero__search-btn');
		btn?.addEventListener('click', () => {
			const q = input.value.trim();
			if (q) window.location.href = `/tools/?q=${encodeURIComponent(q)}`;
		});
	}
</script>

<style>
	/* Hero */
	.hero {
		padding: 5rem 0 4.5rem;
		background: linear-gradient(160deg, #f0f7f4 0%, #fafafa 60%);
		border-bottom: 1px solid var(--border);
		text-align: center;
	}

	.hero__inner {
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.hero__tag {
		display: inline-block;
		font-size: 0.72rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--primary);
		background: var(--primary-light);
		border: 1px solid rgba(0,135,90,0.2);
		padding: 0.28rem 0.75rem;
		border-radius: 50px;
		margin-bottom: 1rem;
	}

	.hero h1 {
		font-size: 3.4rem;
		line-height: 1.1;
		margin-bottom: 0.75rem;
		color: rgb(var(--black));
	}

	.hero__sub {
		font-size: 1.1rem;
		color: rgb(var(--gray));
		margin-bottom: 2rem;
		max-width: 480px;
	}

	.hero__search {
		display: flex;
		align-items: center;
		width: 100%;
		max-width: 520px;
		background: #fff;
		border: 2px solid var(--border);
		border-radius: 50px;
		overflow: hidden;
		transition: border-color 0.2s;
	}

	/* Stats bar */
	.hero__stats {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		font-size: 0.85rem;
		color: rgb(var(--gray));
		margin-bottom: 1.75rem;
	}

	.hero__stats strong { color: rgb(var(--black)); font-weight: 700; }
	.hero__stats-sep { color: var(--border); }

	.hero__search:focus-within { border-color: var(--primary); }

	.hero__search input {
		flex: 1;
		padding: 0.9rem 1.25rem;
		border: none;
		font-size: 1rem;
		background: transparent;
		outline: none;
	}

	.hero__search-btn {
		padding: 0.7rem 1.1rem;
		background: var(--primary);
		color: #fff;
		border: none;
		cursor: pointer;
		display: flex;
		align-items: center;
		border-radius: 0 50px 50px 0;
		transition: background 0.15s;
	}

	.hero__search-btn:hover { background: var(--primary-dark); }

	/* Sections */
	.section { padding: 3rem 0; }
	.section--alt { background: var(--bg-alt); padding: 3rem 0; }

	.section-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 1.5rem;
		gap: 0.5rem;
	}

	.section-heading {
		font-size: 1.35rem;
		margin: 0;
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.section-heading__dot {
		display: inline-block;
		width: 10px;
		height: 10px;
		background: var(--primary);
		border-radius: 50%;
		animation: pulse 2s infinite;
	}

	@keyframes pulse {
		0%, 100% { opacity: 1; transform: scale(1); }
		50% { opacity: 0.6; transform: scale(1.3); }
	}

	.section-link {
		font-size: 0.88rem;
		font-weight: 600;
		color: var(--primary);
		white-space: nowrap;
	}

	.section-cta {
		text-align: center;
		margin-top: 2rem;
	}

	/* Featured */
	.featured-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0.85rem;
	}

	.featured-card {
		display: flex;
		align-items: center;
		gap: 1rem;
		background: #fff;
		border: 1px solid var(--border);
		border-radius: var(--radius);
		padding: 1.25rem;
		color: inherit;
		transition: box-shadow 0.25s, border-color 0.25s, transform 0.25s;
	}

	.featured-card:hover {
		box-shadow: 0 4px 16px rgba(0,135,90,0.12);
		border-color: rgba(0,135,90,0.25);
		transform: translateY(-2px);
	}

	.featured-card__logo {
		width: 48px;
		height: 48px;
		background: var(--primary-light);
		border-radius: 12px;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 1.6rem;
		flex-shrink: 0;
		overflow: hidden;
	}

	.featured-card__logo img { width: 36px; height: 36px; object-fit: contain; }
	.featured-card__emoji { display: flex; align-items: center; justify-content: center; }

	.featured-card__body { flex: 1; min-width: 0; }

	.featured-card__top {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		margin-bottom: 0.3rem;
		flex-wrap: wrap;
	}

	.featured-card__name {
		font-size: 1.05rem;
		font-weight: 700;
		margin: 0;
		color: rgb(var(--black));
	}

	.featured-card__cat {
		font-size: 0.7rem;
		background: var(--primary-light);
		color: var(--primary);
		padding: 0.15rem 0.5rem;
		border-radius: 50px;
		font-weight: 700;
	}

	.featured-card__desc {
		font-size: 0.88rem;
		color: rgb(var(--gray));
		margin: 0;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.featured-card__cta {
		font-size: 0.85rem;
		font-weight: 700;
		color: var(--primary);
		white-space: nowrap;
		flex-shrink: 0;
	}

	/* Category Grid */
	.categories-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 0.6rem;
	}

	.cat-tile {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 0.4rem;
		padding: 1rem 0.5rem;
		background: #fff;
		border: 1px solid var(--border);
		border-radius: var(--radius);
		color: rgb(var(--gray-dark));
		text-align: center;
		transition: all 0.2s;
		text-decoration: none;
	}

	.cat-tile:hover {
		border-color: var(--primary);
		background: var(--primary-light);
		color: var(--primary);
		transform: translateY(-2px);
	}

	.cat-tile__emoji { font-size: 1.5rem; line-height: 1; }
	.cat-tile__name { font-size: 0.72rem; font-weight: 700; line-height: 1.3; }
	.cat-tile__count { font-size: 0.65rem; color: rgb(var(--gray)); background: var(--bg-alt); padding: 0.1rem 0.4rem; border-radius: 50px; }

	/* Tools Grid */
	.tools-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1rem;
	}

	/* Blog Grid */
	.blog-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1rem;
	}

	.blog-card {
		display: block;
		background: #fff;
		border: 1px solid var(--border);
		border-radius: var(--radius);
		padding: 1.25rem;
		color: inherit;
		transition: box-shadow 0.2s, transform 0.2s;
	}

	.blog-card:hover {
		box-shadow: 0 4px 16px rgba(0,135,90,0.1);
		transform: translateY(-2px);
	}

	.blog-card__title {
		font-size: 1rem;
		margin: 0.4rem 0 0.35rem;
		color: rgb(var(--black));
		line-height: 1.4;
	}

	.blog-card:hover .blog-card__title { color: var(--primary); }

	.blog-card__excerpt {
		font-size: 0.84rem;
		color: rgb(var(--gray));
		margin: 0 0 0.5rem;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.blog-card__meta { font-size: 0.75rem; color: rgb(var(--gray)); }

	/* News */
	.news-live { font-size: 0.75rem; font-weight: 700; color: #e03131; }
	.news-grid { display: grid; grid-template-columns: 1fr; gap: 0.6rem; }
	.news-card { display: flex; flex-direction: column; gap: 0.3rem; padding: 0.85rem 1rem; background: #fff; border: 1px solid var(--border); border-radius: var(--radius); transition: border-color 0.15s; }
	.news-card:hover { border-color: var(--primary); }
	.news-source { font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--primary); }
	.news-title { font-size: 0.88rem; font-weight: 600; color: rgb(var(--black)); margin: 0; line-height: 1.4; }

	/* Popular Articles */
	.popular-list { display: flex; flex-direction: column; gap: 0; }
	.popular-item { display: flex; align-items: flex-start; gap: 1.25rem; padding: 1rem 0; border-bottom: 1px solid var(--border); color: inherit; transition: background 0.15s; }
	.popular-item:last-child { border-bottom: none; }
	.popular-item:hover .popular-title { color: var(--primary); }
	.popular-num { font-size: 1.8rem; font-weight: 800; color: var(--border); min-width: 2.5rem; line-height: 1; flex-shrink: 0; }
	.popular-body { display: flex; flex-direction: column; gap: 0.2rem; }
	.popular-cat { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; color: var(--primary); }
	.popular-title { font-size: 0.95rem; font-weight: 700; margin: 0; line-height: 1.4; transition: color 0.15s; }
	.popular-meta { font-size: 0.75rem; color: rgb(var(--gray)); }

	@media (min-width: 640px) {
		.news-grid { grid-template-columns: repeat(2, 1fr); }
		.categories-grid { grid-template-columns: repeat(4, 1fr); }
		.tools-grid { grid-template-columns: repeat(3, 1fr); }
		.featured-grid { grid-template-columns: repeat(2, 1fr); }
		.blog-grid { grid-template-columns: repeat(3, 1fr); }
	}

	@media (min-width: 768px) {
		.featured-grid { grid-template-columns: repeat(3, 1fr); }
	}

	@media (min-width: 960px) {
		.hero h1 { font-size: 4rem; }
		.categories-grid { grid-template-columns: repeat(6, 1fr); }
		.tools-grid { grid-template-columns: repeat(4, 1fr); }
	}
</style>
