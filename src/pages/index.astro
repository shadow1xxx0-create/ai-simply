---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ToolCard from '../components/ToolCard.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION, TOOL_CATEGORIES, TOOL_OF_THE_WEEK } from '../consts';

const allTools = (await getCollection('tools'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featuredTools = allTools.filter(t => t.data.featured).slice(0, 6);
const todaysPick = allTools.filter(t => t.data.featured && t.data.rating)[0] ?? allTools.filter(t => t.data.featured)[0] ?? allTools[0];
const recentTools = allTools.slice(0, 12);
const toolOfWeek = allTools.find(t => t.id === TOOL_OF_THE_WEEK.slug);
const totalTools = allTools.length;
const freeCount = allTools.filter(t => t.data.pricing === 'free').length;
const freemiumCount = allTools.filter(t => t.data.pricing === 'freemium').length;

// Category counts for tiles
const catCounts: Record<string, number> = {};
for (const t of allTools) {
	catCounts[t.data.category] = (catCounts[t.data.category] ?? 0) + 1;
}

// AI News — RSS fetch. Prefer today's committed snapshot (src/data/news/*.json),
// fall back to live fetch if no snapshot exists yet for today.
import { fetchNews } from '../utils/news.mjs';
interface NewsItem { title: string; link: string; date: string; source: string; }

let newsItems: NewsItem[] = [];
const todayIso = new Date().toISOString().slice(0, 10);
const snapshots = import.meta.glob<{ date: string; items: NewsItem[] }>('../data/news/*.json', { eager: true });
const todaySnapshot = Object.entries(snapshots).find(([path]) => path.endsWith(`/${todayIso}.json`))?.[1];
if (todaySnapshot?.items?.length) {
	newsItems = todaySnapshot.items.slice(0, 8);
} else {
	try {
		newsItems = (await fetchNews()).slice(0, 8);
	} catch {}
}

const allPosts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const recentPosts = allPosts.slice(0, 6);
const carouselPosts = allPosts.slice(0, 3);
---

<!doctype html>
<html lang="en">
<head>
	<BaseHead title={`${SITE_TITLE} — AI Tools Directory`} description={SITE_DESCRIPTION} />
</head>
<body>
<Header />

<main id="main-content">
	<!-- Hero Carousel -->
	<section class="hero-carousel" id="hero-carousel">
		{carouselPosts.map((post, i) => (
			<div class={`carousel-slide${i === 0 ? ' active' : ''}`} data-index={i}>
				<div class="carousel-bg" style={post.data.heroImage ? '' : `background: linear-gradient(135deg, var(--primary-light) 0%, #e8f5f0 100%)`}>
					{post.data.heroImage && <img src={post.data.heroImage.src} alt={post.data.title} loading={i === 0 ? 'eager' : 'lazy'} />}
					<div class="carousel-overlay"></div>
				</div>
				<div class="carousel-content container">
					<span class="carousel-cat">{post.data.category.replace(/-/g, ' ')}</span>
					<h2 class="carousel-title">{post.data.title}</h2>
					<p class="carousel-desc">{post.data.description}</p>
					<a href={`/blog/${post.id}/`} class="carousel-btn">Read Article →</a>
				</div>
			</div>
		))}
		<button class="carousel-arrow carousel-arrow--prev" id="carousel-prev" aria-label="Previous">‹</button>
		<button class="carousel-arrow carousel-arrow--next" id="carousel-next" aria-label="Next">›</button>
		<div class="carousel-dots" id="carousel-dots">
			{carouselPosts.map((_, i) => <button class={`carousel-dot${i === 0 ? ' active' : ''}`} data-dot={i} aria-label={`Slide ${i+1}`}></button>)}
		</div>
	</section>

	<!-- Search Bar -->
	<div class="search-bar-wrap">
		<div class="container search-bar-inner">
			<div class="search-stats">
				<span><strong>{totalTools}+</strong> tools</span>
				<span>·</span>
				<span><strong>22</strong> categories</span>
				<span>·</span>
				<span><strong>{freeCount + freemiumCount}</strong> free or freemium</span>
			</div>
			<div class="hero__search">
				<input type="search" id="global-search" placeholder="Search AI tools..." autocomplete="off" aria-label="Search AI tools" />
				<button type="button" class="hero__search-btn" aria-label="Search">
					<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
				</button>
			</div>
		</div>
	</div>

	<!-- AI News -->
	{newsItems.length > 0 && (
		<section class="section section--alt">
			<div class="container">
				<div class="section-header">
					<h2 class="section-heading section-heading--sm">AI News <span class="news-live">● Live</span></h2>
				</div>
				<div class="news-timeline">
					{newsItems.map(item => {
						const d = item.date ? new Date(item.date) : null;
						const iso = d && !isNaN(d.getTime()) ? d.toISOString() : '';
						const fallback = d && !isNaN(d.getTime()) ? d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) : '';
						return (
							<a href={item.link} target="_blank" rel="noopener noreferrer" class="timeline-item">
								<div class="timeline-dot"></div>
								<div class="timeline-body">
									<div class="timeline-meta">
										{iso && <span class="timeline-date" data-date={iso}>{fallback}</span>}
									</div>
									<p class="timeline-title">{item.title}</p>
								</div>
								<span class="timeline-arrow">→</span>
							</a>
						);
					})}
				</div>
			</div>
		</section>
	)}


	<!-- Quiz CTA Banner -->
	<section class="quiz-cta-section">
		<div class="container quiz-cta-inner">
			<div class="quiz-cta-left">
				<span class="quiz-cta-badge">New ✨</span>
				<h2 class="quiz-cta-title">Not sure which AI tool is right for you?</h2>
				<p class="quiz-cta-sub">Answer 5 quick questions and get personalised recommendations from {totalTools}+ tools — matched to your goals, role, and budget.</p>
				<a href="/tools/quiz/" class="quiz-cta-btn">Find My Perfect AI Tool →</a>
				<p class="quiz-cta-note">~1 minute · No sign-up · Instant results</p>
			</div>
			<div class="quiz-cta-visual" aria-hidden="true">
				<div class="quiz-preview-card">
					<div class="qp-step">Step 1 of 5</div>
					<div class="qp-question">What do you want to achieve?</div>
					<div class="qp-options">
						<div class="qp-opt qp-opt--selected">✍️ Write content</div>
						<div class="qp-opt">🖼️ Generate images</div>
						<div class="qp-opt">💻 Code faster</div>
						<div class="qp-opt">📊 Run my business</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Categories -->
	<section class="section">
		<div class="container">
			<div class="section-header">
				<h2 class="section-heading">Browse by Category</h2>
				<a href="/tools/" class="section-link">All tools →</a>
			</div>
			<div class="categories-grid">
				{TOOL_CATEGORIES.map(cat => (
					<a href={`/tools/category/${cat.slug}/`} class="cat-tile">
						<span class="cat-tile__emoji" aria-hidden="true">{cat.emoji}</span>
						<span class="cat-tile__name">{cat.name}</span>
						{catCounts[cat.slug] && <span class="cat-tile__count">{catCounts[cat.slug]}</span>}
					</a>
				))}
			</div>
		</div>
	</section>

	<!-- Newsletter CTA -->
	<section class="newsletter-section">
		<div class="container newsletter-inner">
			<div class="newsletter-text">
				<h2>Get more in my newsletter</h2>
				<p>The stories worth your time. Stay ahead without the noise.</p>
			</div>
			<a href="https://subscribe-forms.beehiiv.com/fda3e0ad-bcc8-4e4d-8f5b-123db9391be9" target="_blank" rel="noopener noreferrer" class="newsletter-cta-btn">
				Subscribe Free →
			</a>
		</div>
	</section>

	<!-- Hot Reviews -->
	{recentPosts.length > 0 && (
		<section class="section section--alt">
			<div class="container">
				<div class="section-header">
					<h2 class="section-heading">🔥 Hot Reviews</h2>
					<a href="/reviews/" class="section-link">All reviews →</a>
				</div>
				<div class="hot-grid">
					{recentPosts.slice(0, 6).map((post, i) => (
						<a href={`/blog/${post.id}/`} class="hot-card">
							<div class="hot-card__img">
								{post.data.heroImage
									? <img src={post.data.heroImage.src} alt={post.data.title} loading="lazy" />
									: <span class="hot-card__emoji">📝</span>
								}
								<span class="hot-card__rank">#{i + 1}</span>
							</div>
							<div class="hot-card__body">
								<span class="hot-card__cat">{post.data.category.replace(/-/g, ' ')}</span>
								<h3>{post.data.title}</h3>
								<span class="hot-card__meta"><FormattedDate date={post.data.pubDate} />{post.data.readingTime && <> · {post.data.readingTime}</>}</span>
							</div>
						</a>
					))}
				</div>
			</div>
		</section>
	)}

	<!-- Tool of the Week -->
	{toolOfWeek && (
		<section class="section">
			<div class="container">
				<div class="totw">
					<span class="totw-badge">🏆 {TOOL_OF_THE_WEEK.label}</span>
					<div class="totw-inner">
						<div class="totw-info">
							<h2 class="totw-name">{toolOfWeek.data.name}</h2>
							<p class="totw-desc">{toolOfWeek.data.description}</p>
							{toolOfWeek.data.rating && <span class="totw-rating">★ {toolOfWeek.data.rating.toFixed(1)}</span>}
						</div>
						<a href={`/tools/${toolOfWeek.id}/`} class="btn btn--primary">Learn More →</a>
					</div>
				</div>
			</div>
		</section>
	)}

	<!-- Recently Added -->
	{recentTools.length > 0 && (
		<section class="section section--alt">
			<div class="container">
				<div class="section-header">
					<h2 class="section-heading">Recently Added</h2>
					<a href="/tools/" class="section-link">View all →</a>
				</div>
				<div class="tools-grid">
					{recentTools.map(tool => (
						<ToolCard
							name={tool.data.name}
							description={tool.data.description}
							category={tool.data.category}
							subcategory={tool.data.subcategory}
							pricing={tool.data.pricing}
							url={tool.data.url}
							slug={tool.id}
							tags={tool.data.tags}
							sponsored={tool.data.sponsored}
							verified={tool.data.verified}
						/>
					))}
				</div>
				<div class="section-cta">
					<a href="/tools/" class="btn btn--outline">Browse All AI Tools</a>
				</div>
			</div>
		</section>
	)}


	<!-- Popular Articles -->
	{recentPosts.length > 0 && (
		<section class="section section--alt">
			<div class="container">
				<div class="section-header">
					<h2 class="section-heading">Popular Articles</h2>
					<a href="/blog/" class="section-link">All articles →</a>
				</div>
				<div class="popular-list">
					{recentPosts.map((post, i) => (
						<a href={`/blog/${post.id}/`} class="popular-item">
							<span class="popular-num">{String(i + 1).padStart(2, '0')}</span>
							<div class="popular-body">
								<span class="popular-cat">{post.data.category.replace(/-/g, ' ')}</span>
								<h3 class="popular-title">{post.data.title}</h3>
								<span class="popular-meta"><FormattedDate date={post.data.pubDate} />{post.data.readingTime && <> · {post.data.readingTime}</>}</span>
							</div>
						</a>
					))}
				</div>
			</div>
		</section>
	)}

	<!-- Latest Tutorials -->
	{recentPosts.length > 0 && (
		<section class="section">
			<div class="container">
				<div class="section-header">
					<h2 class="section-heading">Latest Tutorials</h2>
					<a href="/tutorials/" class="section-link">All tutorials →</a>
				</div>
				<div class="tuts-row">
					{recentPosts.slice(0, 3).map(post => (
						<a href={`/blog/${post.id}/`} class="tut-row-card">
							<div class="tut-row-card__img">
								{post.data.heroImage
									? <img src={post.data.heroImage.src} alt={post.data.title} loading="lazy" />
									: <span>📖</span>
								}
							</div>
							<div class="tut-row-card__body">
								<span class="tut-row-card__cat">AI Tools</span>
								<h3>{post.data.title}</h3>
								<p>{post.data.description}</p>
								<span class="tut-row-card__meta"><FormattedDate date={post.data.pubDate} />{post.data.readingTime && <> · {post.data.readingTime}</>}</span>
							</div>
						</a>
					))}
				</div>
			</div>
		</section>
	)}

	<!-- From the Blog -->
	{recentPosts.length > 0 && (
		<section class="section">
			<div class="container">
				<div class="section-header">
					<h2 class="section-heading">AI Explained Simply</h2>
					<a href="/blog/" class="section-link">All articles →</a>
				</div>
				<div class="blog-grid">
					{recentPosts.map(post => (
						<a href={`/blog/${post.id}/`} class="blog-card">
							<div class="blog-card__body">
								<span class="badge">{post.data.category.replace(/-/g, ' ')}</span>
								<h3 class="blog-card__title">{post.data.title}</h3>
								<p class="blog-card__excerpt">{post.data.description}</p>
								<span class="blog-card__meta"><FormattedDate date={post.data.pubDate} /></span>
							</div>
						</a>
					))}
				</div>
			</div>
		</section>
	)}
</main>

<Footer />
</body>
</html>

<script data-astro-rerun>
	// Carousel
	let current = 0;
	let paused = false;
	const slides = document.querySelectorAll<HTMLElement>('.carousel-slide');
	const dots = document.querySelectorAll<HTMLElement>('.carousel-dot');
	function goTo(n: number) {
		slides[current].classList.remove('active');
		dots[current].classList.remove('active');
		current = (n + slides.length) % slides.length;
		slides[current].classList.add('active');
		dots[current].classList.add('active');
	}
	document.getElementById('carousel-prev')?.addEventListener('click', () => goTo(current - 1));
	document.getElementById('carousel-next')?.addEventListener('click', () => goTo(current + 1));
	dots.forEach(d => d.addEventListener('click', () => goTo(+(d.dataset.dot ?? 0))));
	// Keyboard navigation
	document.getElementById('hero-carousel')?.addEventListener('keydown', (e) => {
		if (e.key === 'ArrowLeft') goTo(current - 1);
		if (e.key === 'ArrowRight') goTo(current + 1);
	});
	// Pause on hover, resume on leave
	const autoplay = setInterval(() => { if (!paused) goTo(current + 1); }, 5000);
	const carousel = document.getElementById('hero-carousel');
	carousel?.addEventListener('mouseenter', () => { paused = true; });
	carousel?.addEventListener('mouseleave', () => { paused = false; });
	document.addEventListener('visibilitychange', () => { if (document.hidden) clearInterval(autoplay); });
	window.addEventListener('beforeunload', () => clearInterval(autoplay));

	const input = document.getElementById('global-search') as HTMLInputElement;
	if (input) {
		input.addEventListener('keydown', (e) => {
			if (e.key === 'Enter') {
				const q = input.value.trim();
				if (q) window.location.href = `/tools/?q=${encodeURIComponent(q)}`;
			}
		});
		const btn = document.querySelector('.hero__search-btn');
		btn?.addEventListener('click', () => {
			const q = input.value.trim();
			if (q) window.location.href = `/tools/?q=${encodeURIComponent(q)}`;
		});
	}

	// Scroll-reveal handled globally by ScrollReveal component in BaseHead.

	// ── Floating orbs (hero background) ───────────────────────────
	const heroCarousel = document.getElementById('hero-carousel');
	if (heroCarousel) {
		['a', 'b', 'c'].forEach(letter => {
			const orb = document.createElement('div');
			orb.className = `hero-orb hero-orb--${letter}`;
			heroCarousel.appendChild(orb);
		});
	}

	// Relative timestamps for AI News timeline
	function formatRelative(iso) {
		const date = new Date(iso);
		if (isNaN(date.getTime())) return '';
		const diff = (Date.now() - date.getTime()) / 1000;
		if (diff < 60) return 'just now';
		if (diff < 3600) return `${Math.floor(diff / 60)}m ago`;
		if (diff < 86400) return `${Math.floor(diff / 3600)}h ago`;
		if (diff < 604800) return `${Math.floor(diff / 86400)}d ago`;
		return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
	}
	document.querySelectorAll('.timeline-date[data-date]').forEach(el => {
		const iso = el.getAttribute('data-date');
		if (iso) el.textContent = formatRelative(iso);
	});
</script>

<style>
	/* ── Floating hero orbs ──────────────────────────────────────── */
	.hero-orb {
		position: absolute;
		border-radius: 50%;
		pointer-events: none;
		z-index: 1;
		filter: blur(60px);
		opacity: 0.18;
	}
	.hero-orb--a {
		width: 340px; height: 340px;
		background: radial-gradient(circle, #00c896, transparent);
		top: -80px; left: -60px;
		animation: orbFloat 9s ease-in-out infinite;
	}
	.hero-orb--b {
		width: 280px; height: 280px;
		background: radial-gradient(circle, #3b82f6, transparent);
		bottom: -60px; right: 10%;
		animation: orbFloat 12s ease-in-out infinite reverse;
	}
	.hero-orb--c {
		width: 200px; height: 200px;
		background: radial-gradient(circle, #a855f7, transparent);
		top: 30%; right: 25%;
		animation: orbFloat 7s ease-in-out infinite 2s;
	}
	@keyframes orbFloat {
		0%, 100% { transform: translateY(0) scale(1); }
		50%       { transform: translateY(-28px) scale(1.06); }
	}

	/* ── Enhanced card hovers ────────────────────────────────────── */
	.featured-card {
		transition: box-shadow 0.25s ease, transform 0.25s ease, border-color 0.25s ease !important;
	}
	.featured-card:hover {
		transform: translateY(-4px) !important;
		box-shadow: 0 8px 28px rgba(var(--primary-rgb), 0.22), var(--accent-glow) !important;
		border-color: rgba(var(--primary-rgb), 0.4) !important;
	}
	.blog-card {
		transition: box-shadow 0.25s ease, transform 0.25s ease, border-color 0.25s ease !important;
	}
	.blog-card:hover {
		transform: translateY(-4px) !important;
		box-shadow: 0 8px 24px rgba(0,0,0,0.08) !important;
	}
	.hot-card:hover {
		transform: translateY(-5px) !important;
		box-shadow: 0 10px 30px rgba(0,0,0,0.1) !important;
	}
	.tut-row-card:hover {
		transform: translateX(4px) !important;
		border-color: var(--primary) !important;
		box-shadow: 0 4px 16px rgba(var(--primary-rgb), 0.18) !important;
	}
	.popular-item {
		transition: transform 0.2s ease, background 0.15s !important;
		border-radius: var(--radius);
		padding-left: 0.5rem;
		padding-right: 0.5rem;
	}
	.popular-item:hover {
		transform: translateX(5px) !important;
		background: var(--primary-light) !important;
	}

	/* ── Timeline item hover ─────────────────────────────────────── */
	.timeline-item:hover .timeline-dot {
		transform: scale(1.4);
		transition: transform 0.2s ease;
	}
	.timeline-dot { transition: transform 0.2s ease; }

	/* ── Section heading underline slide ─────────────────────────── */
	.section-heading {
		position: relative;
		display: inline-block;
	}
	.section-heading::after {
		content: '';
		position: absolute;
		bottom: -4px; left: 0;
		width: 0; height: 3px;
		background: var(--primary);
		border-radius: 2px;
		transition: width 0.4s ease;
	}
	.section-heading:hover::after { width: 100%; }

	/* ── Floating search bar pulse ───────────────────────────────── */
	.hero__search {
		animation: searchFloat 4s ease-in-out infinite;
	}
	@keyframes searchFloat {
		0%, 100% { box-shadow: 0 4px 20px rgba(var(--primary-rgb), 0.20); }
		50%       { box-shadow: 0 8px 32px rgba(var(--primary-rgb), 0.38); }
	}

	/* ── Cat tile bounce on hover ────────────────────────────────── */
	.cat-tile {
		transition: transform 0.2s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.2s ease, border-color 0.2s ease !important;
	}
	.cat-tile:hover {
		transform: translateY(-6px) scale(1.03) !important;
	}

	/* Today's Pick */
	.todays-pick-section {
		background: var(--grad-hero), var(--bg-alt);
		border-top: 1px solid var(--border);
		border-bottom: 1px solid var(--border);
		padding: 1.25rem 0;
	}
	.todays-pick-inner { display: flex; flex-direction: column; gap: 0.75rem; }
	.pick-badge {
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
		font-size: 0.72rem;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.07em;
		color: var(--primary);
	}
	.todays-pick-card {
		display: flex;
		align-items: center;
		gap: 1rem;
		background: var(--surface-1);
		border: 1px solid var(--border);
		border-radius: var(--radius);
		padding: 1rem 1.25rem;
		text-decoration: none;
		color: inherit;
		transition: box-shadow 0.25s var(--ease-out), border-color 0.25s var(--ease-out), transform 0.25s var(--ease-out);
	}
	.todays-pick-card:hover { border-color: var(--primary); box-shadow: var(--accent-glow); transform: translateY(-2px); }
	.pick-logo { flex-shrink: 0; width: 52px; height: 52px; border-radius: 10px; overflow: hidden; background: var(--bg-alt); display: flex; align-items: center; justify-content: center; }
	.pick-logo img { width: 100%; height: 100%; object-fit: cover; border-radius: 10px; }
	.pick-emoji-fallback { font-size: 1.6rem; }
	.pick-body { flex: 1; min-width: 0; }
	.pick-meta { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.2rem; }
	.pick-cat { font-size: 0.72rem; font-weight: 700; color: var(--primary); text-transform: uppercase; letter-spacing: 0.05em; }
	.pick-pricing { font-size: 0.65rem; font-weight: 700; padding: 0.1rem 0.4rem; border-radius: 50px; }
	.pick-pricing--free { background: var(--badge-free-bg); color: var(--badge-free-fg); }
	.pick-pricing--freemium { background: var(--badge-freemium-bg); color: var(--badge-freemium-fg); }
	.pick-pricing--paid { background: var(--badge-paid-bg); color: var(--badge-paid-fg); }
	.pick-name { font-size: 1.05rem; font-weight: 700; margin: 0 0 0.15rem; }
	.pick-desc { font-size: 0.82rem; color: rgb(var(--gray)); margin: 0; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
	.pick-rating { flex-shrink: 0; text-align: center; }
	.pick-score { display: block; font-size: 1.3rem; font-weight: 800; color: rgb(var(--gray-dark)); line-height: 1; }
	.pick-stars { font-size: 0.7rem; color: #f59e0b; letter-spacing: -1px; }
	.pick-arrow { flex-shrink: 0; font-size: 1.2rem; color: var(--primary); font-weight: 700; }
	@media (min-width: 768px) {
		.todays-pick-inner { flex-direction: row; align-items: center; }
		.todays-pick-label { flex-shrink: 0; }
		.todays-pick-card { flex: 1; }
	}

	/* Newsletter inline CTA */
	.newsletter-section {
		background: var(--primary);
		padding: 2rem 0;
	}
	.newsletter-inner {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		align-items: flex-start;
	}
	.newsletter-text h2 { font-size: 1.35rem; color: #fff; margin: 0 0 0.35rem; }
	.newsletter-text p { font-size: 0.9rem; color: rgba(255,255,255,0.8); margin: 0; }
	.newsletter-cta-btn {
		display: inline-flex;
		align-items: center;
		padding: 0.65rem 1.5rem;
		background: #fff;
		color: var(--primary);
		font-weight: 800;
		font-size: 0.9rem;
		border-radius: var(--radius);
		text-decoration: none;
		white-space: nowrap;
		transition: opacity 0.15s;
	}
	.newsletter-cta-btn:hover { opacity: 0.92; }
	@media (min-width: 640px) {
		.newsletter-inner { flex-direction: row; align-items: center; justify-content: space-between; }
	}

	/* Hero Carousel */
	.hero-carousel { position: relative; height: 420px; overflow: hidden; background: #111; }
	.carousel-slide { position: absolute; inset: 0; opacity: 0; transition: opacity 0.6s ease; pointer-events: none; }
	.carousel-slide.active { opacity: 1; pointer-events: auto; }
	.carousel-bg { position: absolute; inset: 0; }
	.carousel-bg img { width: 100%; height: 100%; object-fit: cover; }
	.carousel-overlay { position: absolute; inset: 0; background: linear-gradient(to right, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.2) 100%); }
	.carousel-content { position: relative; z-index: 2; height: 100%; display: flex; flex-direction: column; justify-content: center; gap: 0.75rem; max-width: 600px; }
	.carousel-cat { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(255,255,255,0.8); background: rgba(255,255,255,0.15); padding: 0.25rem 0.7rem; border-radius: 50px; width: fit-content; }
	.carousel-title { font-size: clamp(1.3rem, 3vw, 2rem); color: #fff; line-height: 1.25; margin: 0; }
	.carousel-desc { font-size: 0.92rem; color: rgba(255,255,255,0.75); margin: 0; line-height: 1.55; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
	.carousel-btn { display: inline-flex; align-items: center; padding: 0.55rem 1.1rem; background: var(--primary); color: #fff; font-size: 0.85rem; font-weight: 700; border-radius: var(--radius); width: fit-content; }
	.carousel-btn:hover { background: var(--primary-dark); color: #fff; }
	.carousel-arrow { position: absolute; top: 50%; transform: translateY(-50%); z-index: 3; width: 36px; height: 36px; border-radius: 50%; background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.3); color: #fff; font-size: 1.3rem; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background 0.15s; line-height: 1; }
	.carousel-arrow:hover { background: rgba(255,255,255,0.3); }
	.carousel-arrow--prev { left: 1rem; }
	.carousel-arrow--next { right: 1rem; }
	.carousel-dots { position: absolute; bottom: 1rem; left: 50%; transform: translateX(-50%); display: flex; gap: 0.4rem; z-index: 3; }
	.carousel-dot { width: 8px; height: 8px; border-radius: 50%; background: rgba(255,255,255,0.4); border: none; cursor: pointer; transition: background 0.2s, transform 0.2s; }
	.carousel-dot.active { background: #fff; transform: scale(1.3); }

	/* Quiz CTA Banner */
	.quiz-cta-section {
		background: linear-gradient(135deg, rgba(var(--primary-rgb),0.08) 0%, rgba(var(--primary-rgb),0.18) 50%, rgba(var(--primary-rgb),0.10) 100%), var(--bg-alt);
		padding: 3rem 0;
		overflow: hidden;
		position: relative;
	}
	.quiz-cta-section::before {
		content: '';
		position: absolute;
		inset: 0;
		background: radial-gradient(600px 400px at 90% 120%, rgba(var(--primary-rgb),0.18), transparent 60%);
		pointer-events: none;
	}
	.quiz-cta-section > * { position: relative; z-index: 1; }
	[data-theme="light"] .quiz-cta-section { background: linear-gradient(135deg, #0f2d1e 0%, #0a3d2b 50%, #0d3528 100%); }
	.quiz-cta-inner {
		display: grid;
		grid-template-columns: 1fr;
		gap: 2rem;
		align-items: center;
	}
	@media (min-width: 860px) {
		.quiz-cta-inner { grid-template-columns: 1fr 320px; }
	}
	.quiz-cta-badge {
		display: inline-block;
		background: rgba(0,200,130,0.2);
		color: #4ade9e;
		font-size: 0.72rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		padding: 0.22rem 0.75rem;
		border-radius: 99px;
		border: 1px solid rgba(0,200,130,0.3);
		margin-bottom: 0.75rem;
		display: inline-block;
	}
	.quiz-cta-title {
		font-size: clamp(1.4rem, 3vw, 2rem);
		font-weight: 800;
		color: #fff;
		line-height: 1.2;
		margin-bottom: 0.65rem;
	}
	.quiz-cta-sub { font-size: 0.93rem; color: rgba(255,255,255,0.7); line-height: 1.65; margin-bottom: 1.4rem; max-width: 480px; }
	.quiz-cta-btn {
		display: inline-flex;
		align-items: center;
		padding: 0.85rem 2rem;
		background: #00c878;
		color: #0a2d1d;
		font-size: 0.97rem;
		font-weight: 800;
		border-radius: 50px;
		transition: background 0.15s, transform 0.15s, box-shadow 0.15s;
		box-shadow: 0 4px 20px rgba(0,200,120,0.4);
	}
	.quiz-cta-btn:hover { background: #00e88c; color: #0a2d1d; transform: translateY(-2px); box-shadow: 0 6px 28px rgba(0,200,120,0.5); }
	.quiz-cta-note { font-size: 0.75rem; color: rgba(255,255,255,0.45); margin-top: 0.75rem; }

	/* Quiz preview mockup */
	.quiz-cta-visual { display: none; }
	@media (min-width: 860px) { .quiz-cta-visual { display: block; } }
	.quiz-preview-card {
		background: rgba(255,255,255,0.06);
		border: 1px solid rgba(255,255,255,0.1);
		border-radius: 16px;
		padding: 1.4rem;
		-webkit-backdrop-filter: blur(8px);
		backdrop-filter: blur(8px);
	}
	.qp-step { font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #4ade9e; margin-bottom: 0.6rem; }
	.qp-question { font-size: 0.97rem; font-weight: 700; color: #fff; margin-bottom: 1rem; line-height: 1.3; }
	.qp-options { display: flex; flex-direction: column; gap: 0.45rem; }
	.qp-opt {
		padding: 0.55rem 0.9rem;
		background: rgba(255,255,255,0.06);
		border: 1px solid rgba(255,255,255,0.12);
		border-radius: 8px;
		font-size: 0.82rem;
		color: rgba(255,255,255,0.7);
		transition: all 0.15s;
	}
	.qp-opt--selected {
		background: rgba(0,200,120,0.2);
		border-color: rgba(0,200,120,0.5);
		color: #4ade9e;
		font-weight: 600;
	}

	/* Search bar */
	.search-bar-wrap { background: var(--bg-alt); border-bottom: 1px solid var(--border); padding: 1.25rem 0; }
	.search-bar-inner { display: flex; flex-direction: column; gap: 0.6rem; align-items: center; }
	.search-stats { display: flex; align-items: center; gap: 0.5rem; font-size: 0.82rem; color: rgb(var(--gray)); }
	.search-stats strong { color: rgb(var(--black)); }

	.hero__search {
		display: flex;
		align-items: center;
		width: 100%;
		max-width: 520px;
		background: var(--surface-1);
		border: 2px solid var(--border);
		border-radius: 50px;
		overflow: hidden;
		transition: border-color 0.2s;
	}

	.hero__search:focus-within { border-color: var(--primary); }

	.hero__search input {
		flex: 1;
		padding: 0.9rem 1.25rem;
		border: none;
		font-size: 1rem;
		background: transparent;
		outline: none;
	}

	.hero__search-btn {
		padding: 0.7rem 1.1rem;
		background: var(--primary);
		color: #fff;
		border: none;
		cursor: pointer;
		display: flex;
		align-items: center;
		border-radius: 0 50px 50px 0;
		transition: background 0.15s;
	}

	.hero__search-btn:hover { background: var(--primary-dark); }

	/* Sections */
	.section { padding: 3rem 0; }
	.section--alt { background: var(--bg-alt); padding: 3rem 0; }

	.section-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 1.5rem;
		gap: 0.5rem;
	}

	.section-heading {
		font-size: 1.35rem;
		margin: 0;
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.section-heading__dot {
		display: inline-block;
		width: 10px;
		height: 10px;
		background: var(--primary);
		border-radius: 50%;
		animation: pulse 2s infinite;
	}

	@keyframes pulse {
		0%, 100% { opacity: 1; transform: scale(1); }
		50% { opacity: 0.6; transform: scale(1.3); }
	}

	.section-link {
		font-size: 0.88rem;
		font-weight: 600;
		color: var(--primary);
		white-space: nowrap;
	}

	.section-cta {
		text-align: center;
		margin-top: 2rem;
	}

	/* Tool of the Week */
	.totw {
		border: 2px solid var(--primary);
		border-radius: var(--radius);
		padding: 1.5rem 2rem;
		background: var(--primary-light);
		position: relative;
	}
	.totw-badge {
		position: absolute; top: -0.75rem; left: 1.5rem;
		font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;
		background: var(--primary); color: #fff;
		padding: 0.25rem 0.85rem; border-radius: 50px;
	}
	.totw-inner { display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; flex-wrap: wrap; }
	.totw-info { flex: 1; min-width: 200px; }
	.totw-name { font-size: 1.35rem; color: rgb(var(--black)); margin: 0 0 0.3rem; }
	.totw-desc { font-size: 0.9rem; color: rgb(var(--gray)); margin: 0 0 0.4rem; }
	.totw-rating { font-size: 0.85rem; font-weight: 700; color: #f59e0b; }

	/* Featured */
	.featured-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0.85rem;
	}

	.featured-card {
		display: flex;
		align-items: center;
		gap: 1rem;
		background: var(--surface-1);
		border: 1px solid var(--border);
		border-radius: var(--radius);
		padding: 1.25rem;
		color: inherit;
		transition: box-shadow 0.25s, border-color 0.25s, transform 0.25s;
	}

	.featured-card:hover {
		box-shadow: 0 4px 16px rgba(0,135,90,0.12);
		border-color: rgba(0,135,90,0.25);
		transform: translateY(-2px);
	}

	.featured-card__logo {
		width: 48px;
		height: 48px;
		background: var(--primary-light);
		border-radius: 12px;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 1.6rem;
		flex-shrink: 0;
		overflow: hidden;
	}

	.featured-card__logo img { width: 36px; height: 36px; object-fit: contain; }
	.featured-card__emoji { display: flex; align-items: center; justify-content: center; }

	.featured-card__body { flex: 1; min-width: 0; }

	.featured-card__top {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		margin-bottom: 0.3rem;
		flex-wrap: wrap;
	}

	.featured-card__name {
		font-size: 1.05rem;
		font-weight: 700;
		margin: 0;
		color: rgb(var(--black));
	}

	.featured-card__cat {
		font-size: 0.7rem;
		background: var(--primary-light);
		color: var(--primary);
		padding: 0.15rem 0.5rem;
		border-radius: 50px;
		font-weight: 700;
	}

	.featured-card__desc {
		font-size: 0.88rem;
		color: rgb(var(--gray));
		margin: 0;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.featured-card__cta {
		font-size: 0.85rem;
		font-weight: 700;
		color: var(--primary);
		white-space: nowrap;
		flex-shrink: 0;
	}

	/* Category Grid */
	.categories-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 0.6rem;
	}

	.cat-tile {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 0.4rem;
		padding: 1rem 0.5rem;
		background: var(--surface-1);
		border: 1px solid var(--border);
		border-radius: var(--radius);
		color: rgb(var(--gray-dark));
		text-align: center;
		transition: all 0.2s;
		text-decoration: none;
	}

	.cat-tile:hover {
		border-color: var(--primary);
		background: var(--primary-light);
		color: var(--primary);
		transform: translateY(-2px);
	}

	.cat-tile__emoji { font-size: 1.5rem; line-height: 1; }
	.cat-tile__name { font-size: 0.72rem; font-weight: 700; line-height: 1.3; }
	.cat-tile__count { font-size: 0.65rem; color: rgb(var(--gray)); background: var(--bg-alt); padding: 0.1rem 0.4rem; border-radius: 50px; }

	/* Tools Grid */
	.tools-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1rem;
	}

	/* Blog Grid */
	.blog-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1rem;
	}

	.blog-card {
		display: block;
		background: var(--surface-1);
		border: 1px solid var(--border);
		border-radius: var(--radius);
		padding: 1.25rem;
		color: inherit;
		transition: box-shadow 0.2s, transform 0.2s;
	}

	.blog-card:hover {
		box-shadow: 0 4px 16px rgba(0,135,90,0.1);
		transform: translateY(-2px);
	}

	.blog-card__title {
		font-size: 1rem;
		margin: 0.4rem 0 0.35rem;
		color: rgb(var(--black));
		line-height: 1.4;
	}

	.blog-card:hover .blog-card__title { color: var(--primary); }

	.blog-card__excerpt {
		font-size: 0.84rem;
		color: rgb(var(--gray));
		margin: 0 0 0.5rem;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.blog-card__meta { font-size: 0.75rem; color: rgb(var(--gray)); }

	/* Home two-column layout */
	.home-with-sidebar { background: var(--bg-alt); border-bottom: 1px solid var(--border); }
	.home-with-sidebar__inner { display: grid; grid-template-columns: 1fr; gap: 0; align-items: start; }
	.home-main-col { min-width: 0; overflow: hidden; padding-right: 0; }
	.home-main-col .section { padding-top: 2rem; padding-bottom: 2rem; }
	.home-news-sidebar {
		display: none;
		border-left: 1px solid var(--border);
		background: var(--bg);
		min-width: 0;
	}
	.news-sidebar-inner {
		padding: 1.75rem 1rem 2rem 1.5rem;
		position: sticky;
		top: 72px;
		max-height: calc(100vh - 80px);
		overflow-y: auto;
	}
	.section-heading--sm { font-size: 1rem; margin-bottom: 0.75rem; }

	@media (min-width: 1024px) {
		.home-with-sidebar__inner { grid-template-columns: 1fr 290px; column-gap: 0; }
		.home-news-sidebar { display: block; }
		.home-main-col { padding-right: 2rem; }
		.home-main-col .featured-grid { grid-template-columns: 1fr; }
	}
	@media (min-width: 1280px) {
		.home-with-sidebar__inner { grid-template-columns: 1fr 310px; }
		.home-main-col { padding-right: 2.5rem; }
		.home-main-col .featured-grid { grid-template-columns: 1fr; }
	}

	/* News Timeline */
	.news-live { font-size: 0.75rem; font-weight: 700; color: #e03131; }
	.news-sub { font-size: 0.82rem; color: rgb(var(--gray)); }
	.news-timeline { display: flex; flex-direction: column; border-left: 2px solid var(--border); margin-left: 0.5rem; padding-left: 1.25rem; gap: 0; }
	.timeline-item { display: flex; align-items: flex-start; gap: 0.75rem; padding: 0.85rem 0; border-bottom: 1px solid var(--border); color: inherit; position: relative; transition: background 0.15s; }
	.timeline-item:last-child { border-bottom: none; }
	.timeline-dot { width: 10px; height: 10px; background: var(--primary); border-radius: 50%; flex-shrink: 0; margin-top: 4px; position: absolute; left: -1.55rem; border: 2px solid #fff; }
	.timeline-body { flex: 1; }
	.timeline-meta { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.2rem; }
	.timeline-source { font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--primary); }
	.timeline-date { font-size: 0.68rem; color: rgb(var(--gray)); }
	.timeline-title { font-size: 0.88rem; font-weight: 600; color: rgb(var(--black)); margin: 0; line-height: 1.45; }
	.timeline-item:hover .timeline-title { color: var(--primary); }
	.timeline-arrow { font-size: 0.85rem; color: rgb(var(--gray)); flex-shrink: 0; margin-top: 2px; }

	/* Hot Reviews */
	.hot-grid { display: grid; grid-template-columns: 1fr; gap: 1rem; }
	.hot-card { display: flex; flex-direction: column; background: var(--surface-1); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; color: inherit; transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s; }
	.hot-card:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(0,135,90,0.12); border-color: rgba(0,135,90,0.3); }
	.hot-card__img { position: relative; height: 160px; background: var(--primary-light); display: flex; align-items: center; justify-content: center; overflow: hidden; }
	.hot-card__img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s; }
	.hot-card:hover .hot-card__img img { transform: scale(1.05); }
	.hot-card__emoji { font-size: 2.5rem; }
	.hot-card__rank { position: absolute; top: 0.5rem; left: 0.5rem; background: rgba(0,0,0,0.65); color: #fff; font-size: 0.72rem; font-weight: 700; padding: 0.2rem 0.5rem; border-radius: 4px; }
	.hot-card__body { padding: 0.9rem 1rem; display: flex; flex-direction: column; gap: 0.3rem; flex: 1; }
	.hot-card__cat { font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--primary); }
	.hot-card__body h3 { font-size: 0.9rem; font-weight: 700; line-height: 1.4; margin: 0; }
	.hot-card:hover h3 { color: var(--primary); }
	.hot-card__meta { font-size: 0.73rem; color: rgb(var(--gray)); margin-top: auto; }

	/* Latest Tutorials */
	.tuts-row { display: grid; grid-template-columns: 1fr; gap: 1rem; }
	.tut-row-card { display: flex; gap: 1rem; padding: 1rem; background: var(--surface-1); border: 1px solid var(--border); border-radius: var(--radius); color: inherit; align-items: flex-start; transition: border-color 0.15s, box-shadow 0.15s; }
	.tut-row-card:hover { border-color: var(--primary); box-shadow: 0 4px 12px rgba(0,135,90,0.1); }
	.tut-row-card__img { width: 100px; height: 70px; flex-shrink: 0; border-radius: 8px; background: var(--primary-light); overflow: hidden; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; }
	.tut-row-card__img img { width: 100%; height: 100%; object-fit: cover; }
	.tut-row-card__body { flex: 1; display: flex; flex-direction: column; gap: 0.2rem; }
