---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ToolCard from '../components/ToolCard.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION, TOOL_CATEGORIES } from '../consts';

const allTools = (await getCollection('tools'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featuredTools = allTools.filter(t => t.data.featured).slice(0, 6);
const recentTools = allTools.slice(0, 12);
const totalTools = allTools.length;
const freeCount = allTools.filter(t => t.data.pricing === 'free').length;
const freemiumCount = allTools.filter(t => t.data.pricing === 'freemium').length;

// Category counts for tiles
const catCounts: Record<string, number> = {};
for (const t of allTools) {
	catCounts[t.data.category] = (catCounts[t.data.category] ?? 0) + 1;
}

// AI News — RSS fetch
interface NewsItem { title: string; link: string; date: string; source: string; }
const RSS_FEEDS = [
	{ url: 'https://venturebeat.com/category/ai/feed/', source: 'VentureBeat' },
	{ url: 'https://www.theverge.com/rss/ai-artificial-intelligence/index.xml', source: 'The Verge' },
	{ url: 'https://techcrunch.com/category/artificial-intelligence/feed/', source: 'TechCrunch' },
];
let newsItems: NewsItem[] = [];
try {
	const fetched = await Promise.allSettled(RSS_FEEDS.map(f => fetch(f.url, { signal: AbortSignal.timeout(4000) }).then(r => r.text()).then(xml => ({ xml, source: f.source }))));
	for (const r of fetched) {
		if (r.status !== 'fulfilled') continue;
		const { xml, source } = r.value;
		const items = [...xml.matchAll(/<item[\s\S]*?<\/item>/g)];
		for (const m of items.slice(0, 4)) {
			const title = m[0].match(/<title><!\[CDATA\[(.*?)\]\]><\/title>|<title>(.*?)<\/title>/)?.[1] ?? m[0].match(/<title>(.*?)<\/title>/)?.[1] ?? '';
			const link = m[0].match(/<link>(.*?)<\/link>|<link href="(.*?)"/)?.[1] ?? '';
			const date = m[0].match(/<pubDate>(.*?)<\/pubDate>/)?.[1] ?? '';
			if (title && link) newsItems.push({ title: title.trim(), link: link.trim(), date, source });
		}
	}
	newsItems = newsItems.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()).slice(0, 8);
} catch {}

const allPosts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const recentPosts = allPosts.slice(0, 6);
const carouselPosts = allPosts.slice(0, 3);
---

<!doctype html>
<html lang="en">
<head>
	<BaseHead title={`${SITE_TITLE} — AI Tools Directory`} description={SITE_DESCRIPTION} />
</head>
<body>
<Header />

<main>
	<!-- Hero Carousel -->
	<section class="hero-carousel" id="hero-carousel">
		{carouselPosts.map((post, i) => (
			<div class={`carousel-slide${i === 0 ? ' active' : ''}`} data-index={i}>
				<div class="carousel-bg" style={post.data.heroImage ? '' : `background: linear-gradient(135deg, var(--primary-light) 0%, #e8f5f0 100%)`}>
					{post.data.heroImage && <img src={post.data.heroImage.src} alt={post.data.title} loading={i === 0 ? 'eager' : 'lazy'} />}
					<div class="carousel-overlay"></div>
				</div>
				<div class="carousel-content container">
					<span class="carousel-cat">{post.data.category.replace(/-/g, ' ')}</span>
					<h2 class="carousel-title">{post.data.title}</h2>
					<p class="carousel-desc">{post.data.description}</p>
					<a href={`/blog/${post.id}/`} class="carousel-btn">Read Article →</a>
				</div>
			</div>
		))}
		<button class="carousel-arrow carousel-arrow--prev" id="carousel-prev" aria-label="Previous">‹</button>
		<button class="carousel-arrow carousel-arrow--next" id="carousel-next" aria-label="Next">›</button>
		<div class="carousel-dots" id="carousel-dots">
			{carouselPosts.map((_, i) => <button class={`carousel-dot${i === 0 ? ' active' : ''}`} data-dot={i} aria-label={`Slide ${i+1}`}></button>)}
		</div>
	</section>

	<!-- Search Bar -->
	<div class="search-bar-wrap">
		<div class="container search-bar-inner">
			<div class="search-stats">
				<span><strong>{totalTools}+</strong> tools</span>
				<span>·</span>
				<span><strong>22</strong> categories</span>
				<span>·</span>
				<span><strong>{freeCount + freemiumCount}</strong> free or freemium</span>
			</div>
			<div class="hero__search">
				<input type="search" id="global-search" placeholder="Search AI tools..." autocomplete="off" aria-label="Search AI tools" />
				<button type="button" class="hero__search-btn" aria-label="Search">
					<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
				</button>
			</div>
		</div>
	</div>

	<!-- Featured Tools -->
	{featuredTools.length > 0 && (
		<section class="section section--alt">
			<div class="container">
				<div class="section-header">
					<h2 class="section-heading">
						<span class="section-heading__dot"></span>
						Featured Tools
					</h2>
					<a href="/tools/" class="section-link">Browse all →</a>
				</div>
				<div class="featured-grid">
					{featuredTools.map(tool => {
						const cat = TOOL_CATEGORIES.find(c => c.slug === tool.data.category);
						const domain = new URL(tool.data.url).hostname;
						const favicon = `https://www.google.com/s2/favicons?domain=${domain}&sz=64`;
						return (
							<a href={`/tools/${tool.id}/`} class="featured-card">
								<div class="featured-card__logo">
									<img src={favicon} alt={tool.data.name} width="36" height="36" loading="lazy"
										onerror={`this.style.display='none';this.nextElementSibling.style.display='flex'`} />
									<span class="featured-card__emoji" style="display:none">{cat?.emoji ?? '🤖'}</span>
								</div>
								<div class="featured-card__body">
									<div class="featured-card__top">
										<h3 class="featured-card__name">{tool.data.name}</h3>
										<span class="featured-card__cat">{cat?.name}</span>
									</div>
									<p class="featured-card__desc">{tool.data.description}</p>
								</div>
								<span class="featured-card__cta">Explore →</span>
							</a>
						);
					})}
				</div>
			</div>
		</section>
	)}

	<!-- Categories -->
	<section class="section">
		<div class="container">
			<div class="section-header">
				<h2 class="section-heading">Browse by Category</h2>
				<a href="/tools/" class="section-link">All tools →</a>
			</div>
			<div class="categories-grid">
				{TOOL_CATEGORIES.map(cat => (
					<a href={`/tools/category/${cat.slug}/`} class="cat-tile">
						<span class="cat-tile__emoji" aria-hidden="true">{cat.emoji}</span>
						<span class="cat-tile__name">{cat.name}</span>
						{catCounts[cat.slug] && <span class="cat-tile__count">{catCounts[cat.slug]}</span>}
					</a>
				))}
			</div>
		</div>
	</section>

	<!-- Hot Reviews -->
	{recentPosts.length > 0 && (
		<section class="section section--alt">
			<div class="container">
				<div class="section-header">
					<h2 class="section-heading">🔥 Hot Reviews</h2>
					<a href="/reviews/" class="section-link">All reviews →</a>
				</div>
				<div class="hot-grid">
					{recentPosts.slice(0, 6).map((post, i) => (
						<a href={`/blog/${post.id}/`} class="hot-card">
							<div class="hot-card__img">
								{post.data.heroImage
									? <img src={post.data.heroImage.src} alt={post.data.title} loading="lazy" />
									: <span class="hot-card__emoji">📝</span>
								}
								<span class="hot-card__rank">#{i + 1}</span>
							</div>
							<div class="hot-card__body">
								<span class="hot-card__cat">{post.data.category.replace(/-/g, ' ')}</span>
								<h3>{post.data.title}</h3>
								<span class="hot-card__meta"><FormattedDate date={post.data.pubDate} />{post.data.readingTime && <> · {post.data.readingTime}</>}</span>
							</div>
						</a>
					))}
				</div>
			</div>
		</section>
	)}

	<!-- Recently Added -->
	{recentTools.length > 0 && (
		<section class="section section--alt">
			<div class="container">
				<div class="section-header">
					<h2 class="section-heading">Recently Added</h2>
					<a href="/tools/" class="section-link">View all →</a>
				</div>
				<div class="tools-grid">
					{recentTools.map(tool => (
						<ToolCard
							name={tool.data.name}
							description={tool.data.description}
							category={tool.data.category}
							subcategory={tool.data.subcategory}
							pricing={tool.data.pricing}
							url={tool.data.url}
							slug={tool.id}
							tags={tool.data.tags}
						/>
					))}
				</div>
				<div class="section-cta">
					<a href="/tools/" class="btn btn--outline">Browse All AI Tools</a>
				</div>
			</div>
		</section>
	)}

	<!-- AI News Timeline -->
	{newsItems.length > 0 && (
		<section class="section section--alt">
			<div class="container">
				<div class="section-header">
					<h2 class="section-heading">AI News Timeline <span class="news-live">● Live</span></h2>
					<span class="news-sub">Daily developments in global artificial intelligence</span>
				</div>
				<div class="news-timeline">
					{newsItems.map(item => {
						const d = item.date ? new Date(item.date) : null;
						const dateStr = d && !isNaN(d.getTime()) ? d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) : '';
						return (
							<a href={item.link} target="_blank" rel="noopener noreferrer" class="timeline-item">
								<div class="timeline-dot"></div>
								<div class="timeline-body">
									<div class="timeline-meta">
										<span class="timeline-source">{item.source}</span>
										{dateStr && <span class="timeline-date">{dateStr}</span>}
									</div>
									<p class="timeline-title">{item.title}</p>
								</div>
								<span class="timeline-arrow">→</span>
							</a>
						);
					})}
				</div>
			</div>
		</section>
	)}

	<!-- Popular Articles -->
	{recentPosts.length > 0 && (
		<section class="section section--alt">
			<div class="container">
				<div class="section-header">
					<h2 class="section-heading">Popular Articles</h2>
					<a href="/blog/" class="section-link">All articles →</a>
				</div>
				<div class="popular-list">
					{recentPosts.map((post, i) => (
						<a href={`/blog/${post.id}/`} class="popular-item">
							<span class="popular-num">{String(i + 1).padStart(2, '0')}</span>
							<div class="popular-body">
								<span class="popular-cat">{post.data.category.replace(/-/g, ' ')}</span>
								<h3 class="popular-title">{post.data.title}</h3>
								<span class="popular-meta"><FormattedDate date={post.data.pubDate} />{post.data.readingTime && <> · {post.data.readingTime}</>}</span>
							</div>
						</a>
					))}
				</div>
			</div>
		</section>
	)}

	<!-- Latest Tutorials -->
	{recentPosts.length > 0 && (
		<section class="section">
			<div class="container">
				<div class="section-header">
					<h2 class="section-heading">Latest Tutorials</h2>
					<a href="/tutorials/" class="section-link">All tutorials →</a>
				</div>
				<div class="tuts-row">
					{recentPosts.slice(0, 3).map(post => (
						<a href={`/blog/${post.id}/`} class="tut-row-card">
							<div class="tut-row-card__img">
								{post.data.heroImage
									? <img src={post.data.heroImage.src} alt={post.data.title} loading="lazy" />
									: <span>📖</span>
								}
							</div>
							<div class="tut-row-card__body">
								<span class="tut-row-card__cat">AI Tools</span>
								<h3>{post.data.title}</h3>
								<p>{post.data.description}</p>
								<span class="tut-row-card__meta"><FormattedDate date={post.data.pubDate} />{post.data.readingTime && <> · {post.data.readingTime}</>}</span>
							</div>
						</a>
					))}
				</div>
			</div>
		</section>
	)}

	<!-- From the Blog -->
	{recentPosts.length > 0 && (
		<section class="section">
			<div class="container">
				<div class="section-header">
					<h2 class="section-heading">AI Explained Simply</h2>
					<a href="/blog/" class="section-link">All articles →</a>
				</div>
				<div class="blog-grid">
					{recentPosts.map(post => (
						<a href={`/blog/${post.id}/`} class="blog-card">
							<div class="blog-card__body">
								<span class="badge">{post.data.category.replace(/-/g, ' ')}</span>
								<h3 class="blog-card__title">{post.data.title}</h3>
								<p class="blog-card__excerpt">{post.data.description}</p>
								<span class="blog-card__meta"><FormattedDate date={post.data.pubDate} /></span>
							</div>
						</a>
					))}
				</div>
			</div>
		</section>
	)}
</main>

<Footer />
</body>
</html>

<script>
	// Carousel
	let current = 0;
	const slides = document.querySelectorAll<HTMLElement>('.carousel-slide');
	const dots = document.querySelectorAll<HTMLElement>('.carousel-dot');
	function goTo(n: number) {
		slides[current].classList.remove('active');
		dots[current].classList.remove('active');
		current = (n + slides.length) % slides.length;
		slides[current].classList.add('active');
		dots[current].classList.add('active');
	}
	document.getElementById('carousel-prev')?.addEventListener('click', () => goTo(current - 1));
	document.getElementById('carousel-next')?.addEventListener('click', () => goTo(current + 1));
	dots.forEach(d => d.addEventListener('click', () => goTo(+(d.dataset.dot ?? 0))));
	const autoplay = setInterval(() => goTo(current + 1), 5000);
	document.getElementById('hero-carousel')?.addEventListener('mouseenter', () => clearInterval(autoplay));

	const input = document.getElementById('global-search') as HTMLInputElement;
	if (input) {
		input.addEventListener('keydown', (e) => {
			if (e.key === 'Enter') {
				const q = input.value.trim();
				if (q) window.location.href = `/tools/?q=${encodeURIComponent(q)}`;
			}
		});
		const btn = document.querySelector('.hero__search-btn');
		btn?.addEventListener('click', () => {
			const q = input.value.trim();
			if (q) window.location.href = `/tools/?q=${encodeURIComponent(q)}`;
		});
	}
</script>

<style>
	/* Hero Carousel */
	.hero-carousel { position: relative; height: 420px; overflow: hidden; background: #111; }
	.carousel-slide { position: absolute; inset: 0; opacity: 0; transition: opacity 0.6s ease; pointer-events: none; }
	.carousel-slide.active { opacity: 1; pointer-events: auto; }
	.carousel-bg { position: absolute; inset: 0; }
	.carousel-bg img { width: 100%; height: 100%; object-fit: cover; }
	.carousel-overlay { position: absolute; inset: 0; background: linear-gradient(to right, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.2) 100%); }
	.carousel-content { position: relative; z-index: 2; height: 100%; display: flex; flex-direction: column; justify-content: center; gap: 0.75rem; max-width: 600px; }
	.carousel-cat { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(255,255,255,0.8); background: rgba(255,255,255,0.15); padding: 0.25rem 0.7rem; border-radius: 50px; width: fit-content; }
	.carousel-title { font-size: clamp(1.3rem, 3vw, 2rem); color: #fff; line-height: 1.25; margin: 0; }
	.carousel-desc { font-size: 0.92rem; color: rgba(255,255,255,0.75); margin: 0; line-height: 1.55; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
	.carousel-btn { display: inline-flex; align-items: center; padding: 0.55rem 1.1rem; background: var(--primary); color: #fff; font-size: 0.85rem; font-weight: 700; border-radius: var(--radius); width: fit-content; }
	.carousel-btn:hover { background: var(--primary-dark); color: #fff; }
	.carousel-arrow { position: absolute; top: 50%; transform: translateY(-50%); z-index: 3; width: 36px; height: 36px; border-radius: 50%; background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.3); color: #fff; font-size: 1.3rem; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background 0.15s; line-height: 1; }
	.carousel-arrow:hover { background: rgba(255,255,255,0.3); }
	.carousel-arrow--prev { left: 1rem; }
	.carousel-arrow--next { right: 1rem; }
	.carousel-dots { position: absolute; bottom: 1rem; left: 50%; transform: translateX(-50%); display: flex; gap: 0.4rem; z-index: 3; }
	.carousel-dot { width: 8px; height: 8px; border-radius: 50%; background: rgba(255,255,255,0.4); border: none; cursor: pointer; transition: background 0.2s, transform 0.2s; }
	.carousel-dot.active { background: #fff; transform: scale(1.3); }

	/* Search bar */
	.search-bar-wrap { background: var(--bg-alt); border-bottom: 1px solid var(--border); padding: 1.25rem 0; }
	.search-bar-inner { display: flex; flex-direction: column; gap: 0.6rem; align-items: center; }
	.search-stats { display: flex; align-items: center; gap: 0.5rem; font-size: 0.82rem; color: rgb(var(--gray)); }
	.search-stats strong { color: rgb(var(--black)); }

	.hero__search {
		display: flex;
		align-items: center;
		width: 100%;
		max-width: 520px;
		background: #fff;
		border: 2px solid var(--border);
		border-radius: 50px;
		overflow: hidden;
		transition: border-color 0.2s;
	}

	.hero__search:focus-within { border-color: var(--primary); }

	.hero__search input {
		flex: 1;
		padding: 0.9rem 1.25rem;
		border: none;
		font-size: 1rem;
		background: transparent;
		outline: none;
	}

	.hero__search-btn {
		padding: 0.7rem 1.1rem;
		background: var(--primary);
		color: #fff;
		border: none;
		cursor: pointer;
		display: flex;
		align-items: center;
		border-radius: 0 50px 50px 0;
		transition: background 0.15s;
	}

	.hero__search-btn:hover { background: var(--primary-dark); }

	/* Sections */
	.section { padding: 3rem 0; }
	.section--alt { background: var(--bg-alt); padding: 3rem 0; }

	.section-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 1.5rem;
		gap: 0.5rem;
	}

	.section-heading {
		font-size: 1.35rem;
		margin: 0;
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.section-heading__dot {
		display: inline-block;
		width: 10px;
		height: 10px;
		background: var(--primary);
		border-radius: 50%;
		animation: pulse 2s infinite;
	}

	@keyframes pulse {
		0%, 100% { opacity: 1; transform: scale(1); }
		50% { opacity: 0.6; transform: scale(1.3); }
	}

	.section-link {
		font-size: 0.88rem;
		font-weight: 600;
		color: var(--primary);
		white-space: nowrap;
	}

	.section-cta {
		text-align: center;
		margin-top: 2rem;
	}

	/* Featured */
	.featured-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0.85rem;
	}

	.featured-card {
		display: flex;
		align-items: center;
		gap: 1rem;
		background: #fff;
		border: 1px solid var(--border);
		border-radius: var(--radius);
		padding: 1.25rem;
		color: inherit;
		transition: box-shadow 0.25s, border-color 0.25s, transform 0.25s;
	}

	.featured-card:hover {
		box-shadow: 0 4px 16px rgba(0,135,90,0.12);
		border-color: rgba(0,135,90,0.25);
		transform: translateY(-2px);
	}

	.featured-card__logo {
		width: 48px;
		height: 48px;
		background: var(--primary-light);
		border-radius: 12px;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 1.6rem;
		flex-shrink: 0;
		overflow: hidden;
	}

	.featured-card__logo img { width: 36px; height: 36px; object-fit: contain; }
	.featured-card__emoji { display: flex; align-items: center; justify-content: center; }

	.featured-card__body { flex: 1; min-width: 0; }

	.featured-card__top {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		margin-bottom: 0.3rem;
		flex-wrap: wrap;
	}

	.featured-card__name {
		font-size: 1.05rem;
		font-weight: 700;
		margin: 0;
		color: rgb(var(--black));
	}

	.featured-card__cat {
		font-size: 0.7rem;
		background: var(--primary-light);
		color: var(--primary);
		padding: 0.15rem 0.5rem;
		border-radius: 50px;
		font-weight: 700;
	}

	.featured-card__desc {
		font-size: 0.88rem;
		color: rgb(var(--gray));
		margin: 0;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.featured-card__cta {
		font-size: 0.85rem;
		font-weight: 700;
		color: var(--primary);
		white-space: nowrap;
		flex-shrink: 0;
	}

	/* Category Grid */
	.categories-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 0.6rem;
	}

	.cat-tile {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 0.4rem;
