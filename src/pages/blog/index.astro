---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Newsletter from '../../components/Newsletter.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { CATEGORY_COLORS } from '../../consts';
import Breadcrumb from '../../components/Breadcrumb.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
<head>
	<BaseHead
		title="AI Articles — AI Briefs"
		description="Browse all AI Briefs articles: AI explained, future of work, tool comparisons, how-to guides. AI made simple for everyone."
	/>
</head>
<body>
	<Header />
	<main>

		<!-- Page header -->
		<section class="page-header">
			<div class="container">
				<h1>Latest Articles</h1>
				<p>AI explained clearly — no jargon, no hype.</p>
			</div>
		</section>

		<div class="container articles-section">
			<div class="post-list">
				{posts.map((post) => (
					<a href={`/blog/${post.id}/`} class="post-item">
						<div class="post-item__img" style={`background:${CATEGORY_COLORS[post.data.category] ?? 'var(--primary-light)'}`}>
							{post.data.heroImage ? (
								<Image width={200} height={130} src={post.data.heroImage} alt={post.data.title} loading="lazy" />
							) : (
								<span aria-hidden="true">&#129302;</span>
							)}
						</div>
						<div class="post-item__body">
							<div class="post-item__meta">
								<span class="badge">{post.data.category.replace(/-/g, ' ')}</span>
								<span class="meta-date"><FormattedDate date={post.data.pubDate} /></span>
								{post.data.readingTime && <span class="meta-date">{post.data.readingTime}</span>}
							</div>
							<h2 class="post-item__title">{post.data.title}</h2>
							<p class="post-item__excerpt">{post.data.description}</p>
						</div>
					</a>
				))}
			</div>
		</div>

		<Newsletter />
	</main>
	<Footer />
</body>
</html>

<style>
	.articles-section { padding: 2rem 0 3rem; }

	.meta-date {
		font-size: 0.75rem;
		color: rgb(var(--gray));
	}

	.post-list {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.post-item {
		display: grid;
		grid-template-columns: 200px 1fr;
		gap: 1.25rem;
		align-items: center;
		padding: 1rem;
		color: inherit;
		background: var(--bg);
		border: 1px solid var(--border);
		border-radius: var(--radius);
		transition:
			box-shadow 0.55s ease,
			transform 0.55s cubic-bezier(0.34, 1.56, 0.64, 1),
			border-color 0.4s ease;
	}

	.post-item:hover {
		box-shadow:
			0 0 0 1px rgba(0, 200, 150, 0.15),
			0 6px 24px rgba(0, 200, 150, 0.18),
			0 12px 40px rgba(0, 200, 150, 0.10);
		transform: translateY(-5px);
		border-color: rgba(0, 200, 150, 0.35);
	}

	.post-item__img {
		width: 200px;
		height: 130px;
		border-radius: var(--radius);
		overflow: hidden;
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		font-size: 2rem;
	}

	.post-item__img img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.65s cubic-bezier(0.25, 0.8, 0.25, 1);
	}

	.post-item:hover .post-item__img img {
		transform: scale(1.06);
	}

	.post-item__meta {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		margin-bottom: 0.4rem;
		flex-wrap: wrap;
	}

	.post-item__title {
		font-size: 1.1rem;
		line-height: 1.3;
		color: rgb(var(--black));
		margin-bottom: 0.35rem;
		transition: color 0.45s ease;
	}

	.post-item:hover .post-item__title { color: var(--primary); }

	.post-item__excerpt {
		font-size: 0.88rem;
		color: rgb(var(--gray));
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	@media (max-width: 600px) {
		.post-item { grid-template-columns: 1fr; }
		.post-item__img { width: 100%; height: 160px; }
	}

</style>
