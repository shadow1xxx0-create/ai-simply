---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Newsletter from '../../components/Newsletter.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { CATEGORY_COLORS, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const categories = [
	{ slug: 'all', label: 'All Articles' },
	{ slug: 'ai-explained', label: 'AI Explained' },
	{ slug: 'future-of-work', label: 'Future of Work' },
	{ slug: 'how-ai-works', label: 'How AI Works' },
	{ slug: 'comparisons', label: 'Comparisons' },
	{ slug: 'guides', label: 'Guides' },
];
---

<!doctype html>
<html lang="en">
<head>
	<BaseHead
		title={`AI Articles & Guides | ${SITE_TITLE}`}
		description="Browse all AI Briefs articles: AI explained, future of work, tool comparisons, how-to guides. AI made simple for everyone."
	/>
</head>
<body>
	<Header />
	<main>

		<!-- Page header -->
		<section class="page-header">
			<div class="container">
				<Breadcrumb crumbs={[{ label: 'Home', href: '/' }, { label: 'Articles' }]} />
				<h1>Latest Articles</h1>
				<p>AI explained clearly — no jargon, no hype. <span class="post-count">{posts.length} articles</span></p>
			</div>
		</section>

		<!-- Category filter tabs -->
		<div class="cat-tabs-wrap">
			<div class="container">
				<div class="cat-tabs" id="cat-tabs" role="tablist">
					{categories.map((cat, i) => (
						<button
							class={`cat-tab${i === 0 ? ' active' : ''}`}
							data-cat={cat.slug}
							role="tab"
							aria-selected={i === 0 ? 'true' : 'false'}
						>
							{cat.label}
						</button>
					))}
				</div>
			</div>
		</div>

		<div class="container articles-section">
			<p class="results-label" id="results-label">{posts.length} articles</p>
			<div class="post-list" id="post-list">
				{posts.map((post) => (
					<a
						href={`/blog/${post.id}/`}
						class="post-item"
						data-cat={post.data.category}
					>
						<div class="post-item__img" style={`background:${CATEGORY_COLORS[post.data.category] ?? 'var(--primary-light)'}`}>
							{post.data.heroImage ? (
								<Image width={200} height={130} src={post.data.heroImage} alt={post.data.title} loading="lazy" />
							) : (
								<span aria-hidden="true">🤖</span>
							)}
						</div>
						<div class="post-item__body">
							<div class="post-item__meta">
								<span class="badge">{post.data.category.replace(/-/g, ' ')}</span>
								<span class="meta-sep">·</span>
								<span class="meta-date"><FormattedDate date={post.data.pubDate} /></span>
								{post.data.readingTime && <><span class="meta-sep">·</span><span class="meta-date">{post.data.readingTime}</span></>}
							</div>
							<h2 class="post-item__title">{post.data.title}</h2>
							<p class="post-item__excerpt">{post.data.description}</p>
							<span class="post-item__cta">Read article →</span>
						</div>
					</a>
				))}
			</div>
			<p class="no-results" id="no-results" style="display:none">
				No articles in this category yet.
				<a href="/blog/">See all articles</a>
			</p>
		</div>

		<Newsletter />
	</main>
	<Footer />
</body>
</html>

<script data-astro-rerun>
const tabs = document.querySelectorAll<HTMLButtonElement>('.cat-tab');
const posts = document.querySelectorAll<HTMLElement>('.post-item');
const label = document.getElementById('results-label')!;
const noResults = document.getElementById('no-results')!;

tabs.forEach(tab => {
	tab.addEventListener('click', () => {
		tabs.forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
		tab.classList.add('active');
		tab.setAttribute('aria-selected', 'true');

		const cat = tab.dataset.cat;
		let visible = 0;
		posts.forEach(post => {
			const match = cat === 'all' || post.dataset.cat === cat;
			post.style.display = match ? '' : 'none';
			if (match) visible++;
		});
		label.textContent = `${visible} article${visible !== 1 ? 's' : ''}`;
		noResults.style.display = visible === 0 ? '' : 'none';
	});
});
</script>

<style>
.page-header {
	background: linear-gradient(135deg, var(--primary-light) 0%, var(--bg) 100%);
	border-bottom: 1px solid var(--border);
	padding: 2.5rem 0 1.75rem;
}
.page-header h1 { font-size: clamp(1.75rem, 4vw, 2.4rem); margin: 0.5rem 0 0.3rem; }
.page-header p { color: rgb(var(--gray)); font-size: 0.95rem; }
.post-count { font-weight: 700; color: var(--primary); }

/* Category tabs */
.cat-tabs-wrap {
	background: var(--bg-alt);
	border-bottom: 1px solid var(--border);
	position: sticky;
	top: 64px;
	z-index: 100;
}
.cat-tabs {
	display: flex;
	gap: 0;
	overflow-x: auto;
	-webkit-overflow-scrolling: touch;
	scrollbar-width: none;
}
.cat-tabs::-webkit-scrollbar { display: none; }
.cat-tab {
	padding: 0.75rem 1.1rem;
	background: none;
	border: none;
	border-bottom: 2px solid transparent;
	font-size: 0.85rem;
	font-weight: 600;
	color: rgb(var(--gray));
	cursor: pointer;
	white-space: nowrap;
	transition: color 0.15s, border-color 0.15s;
	font-family: inherit;
}
.cat-tab:hover { color: rgb(var(--black)); }
.cat-tab.active { color: var(--primary); border-bottom-color: var(--primary); }

.articles-section { padding: 1.75rem 0 3rem; }
.results-label { font-size: 0.82rem; color: rgb(var(--gray)); margin-bottom: 1rem; }

.post-list {
	display: flex;
	flex-direction: column;
	gap: 1.1rem;
}

.post-item {
	display: grid;
	grid-template-columns: 200px 1fr;
	gap: 1.25rem;
	align-items: center;
	padding: 1rem;
	color: inherit;
	background: var(--bg);
	border: 1px solid var(--border);
	border-radius: var(--radius);
	transition: box-shadow 0.2s, transform 0.2s, border-color 0.2s;
}
.post-item:hover {
	box-shadow: 0 4px 20px rgba(0,200,150,0.12);
	transform: translateY(-2px);
	border-color: rgba(0,200,150,0.3);
}

.post-item__img {
	width: 200px;
	height: 130px;
	border-radius: var(--radius);
	overflow: hidden;
	display: flex;
	align-items: center;
	justify-content: center;
	flex-shrink: 0;
	font-size: 2rem;
}
.post-item__img img {
	width: 100%;
	height: 100%;
	object-fit: cover;
	transition: transform 0.3s ease;
}
.post-item:hover .post-item__img img { transform: scale(1.04); }

.post-item__meta {
	display: flex;
	align-items: center;
	gap: 0.35rem;
	margin-bottom: 0.4rem;
	flex-wrap: wrap;
}
.meta-sep { color: rgb(var(--gray)); font-size: 0.75rem; }
.meta-date { font-size: 0.75rem; color: rgb(var(--gray)); }

.post-item__title {
	font-size: 1.07rem;
	line-height: 1.3;
	color: rgb(var(--black));
	margin-bottom: 0.3rem;
	transition: color 0.15s;
}
.post-item:hover .post-item__title { color: var(--primary); }

.post-item__excerpt {
	font-size: 0.86rem;
	color: rgb(var(--gray));
	margin: 0 0 0.5rem;
	display: -webkit-box;
	-webkit-line-clamp: 2;
	-webkit-box-orient: vertical;
	overflow: hidden;
	line-height: 1.5;
}
.post-item__cta { font-size: 0.8rem; font-weight: 700; color: var(--primary); }

.no-results { color: rgb(var(--gray)); font-size: 0.9rem; padding: 1.5rem 0; }
.no-results a { color: var(--primary); font-weight: 600; }

@media (max-width: 600px) {
	.post-item { grid-template-columns: 1fr; }
	.post-item__img { width: 100%; height: 160px; }
}
</style>
