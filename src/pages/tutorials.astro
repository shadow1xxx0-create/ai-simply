---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { CATEGORY_COLORS, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const guides = posts.filter(p => p.data.category === 'guides');
const explained = posts.filter(p => p.data.category !== 'guides');
---

<!doctype html>
<html lang="en">
<head>
	<BaseHead
		title={`AI Tutorials & Guides | ${SITE_TITLE}`}
		description="Learn how to use AI tools effectively. Step-by-step guides, tutorials, and plain-English explainers — AI made simple for everyone."
	/>
</head>
<body>
	<Header />
	<main>

		<section class="page-hero">
			<div class="container">
				<Breadcrumb crumbs={[{ label: 'Home', href: '/' }, { label: 'Tutorials' }]} />
				<div class="hero-badge">Learn AI</div>
				<h1>Tutorials & Guides</h1>
				<p>Step-by-step guides and plain-English explainers to help you understand and use AI tools — no jargon, no fluff.</p>
			</div>
		</section>

		<div class="container tutorials-body">

			{guides.length > 0 && (
				<section class="tut-section">
					<h2 class="section-title">How-To Guides</h2>
					<div class="tut-grid">
						{guides.map(post => (
							<a href={`/blog/${post.id}/`} class="tut-card">
								<div class="tut-card__img" style={`background:${CATEGORY_COLORS[post.data.category] ?? 'var(--primary-light)'}`}>
									{post.data.heroImage
										? <Image width={400} height={220} src={post.data.heroImage} alt={post.data.title} loading="lazy" />
										: <span aria-hidden="true">📖</span>
									}
								</div>
								<div class="tut-card__body">
									<span class="tut-badge">Guide</span>
									<h3>{post.data.title}</h3>
									<p>{post.data.description}</p>
									<span class="tut-meta"><FormattedDate date={post.data.pubDate} />{post.data.readingTime && <> · {post.data.readingTime}</>}</span>
								</div>
							</a>
						))}
					</div>
				</section>
			)}

			<section class="tut-section">
				<h2 class="section-title">AI Explained</h2>
				<div class="tut-grid">
					{explained.map(post => (
						<a href={`/blog/${post.id}/`} class="tut-card">
							<div class="tut-card__img" style={`background:${CATEGORY_COLORS[post.data.category] ?? 'var(--primary-light)'}`}>
								{post.data.heroImage
									? <Image width={400} height={220} src={post.data.heroImage} alt={post.data.title} loading="lazy" />
									: <span aria-hidden="true">🤖</span>
								}
							</div>
							<div class="tut-card__body">
								<span class="tut-badge tut-badge--explain">Explainer</span>
								<h3>{post.data.title}</h3>
								<p>{post.data.description}</p>
								<span class="tut-meta"><FormattedDate date={post.data.pubDate} />{post.data.readingTime && <> · {post.data.readingTime}</>}</span>
							</div>
						</a>
					))}
				</div>
			</section>

		</div>
	</main>
	<Footer />
</body>
</html>

<style>
.page-hero {
	background: linear-gradient(135deg, var(--primary-light) 0%, var(--bg) 100%);
	border-bottom: 1px solid var(--border);
	padding: 3.5rem 0 2.5rem;
	text-align: center;
}

.hero-badge {
	display: inline-block;
	background: var(--accent);
	color: #fff;
	font-size: 0.75rem;
	font-weight: 700;
	letter-spacing: 0.08em;
	text-transform: uppercase;
	padding: 0.3rem 0.9rem;
	border-radius: 99px;
	margin-bottom: 1rem;
}

.page-hero h1 {
	font-size: clamp(1.8rem, 4vw, 2.8rem);
	margin-bottom: 0.75rem;
}

.page-hero p {
	color: rgb(var(--gray));
	max-width: 540px;
	margin: 0 auto;
}

.tutorials-body { padding: 3rem 0 4rem; }

.tut-section { margin-bottom: 3.5rem; }

.section-title {
	font-size: 1.35rem;
	font-weight: 700;
	margin-bottom: 1.5rem;
	padding-bottom: 0.6rem;
	border-bottom: 2px solid var(--border);
}

.tut-grid {
	display: grid;
	grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
	gap: 1.25rem;
}

.tut-card {
	display: flex;
	flex-direction: column;
	background: var(--bg);
	border: 1px solid var(--border);
	border-radius: var(--radius);
	overflow: hidden;
	color: inherit;
	transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
}

.tut-card:hover {
	transform: translateY(-4px);
	border-color: rgba(0,200,150,0.35);
	box-shadow: 0 8px 28px rgba(0,200,150,0.12);
}

.tut-card__img {
	width: 100%;
	height: 180px;
	overflow: hidden;
	display: flex;
	align-items: center;
	justify-content: center;
	font-size: 2.5rem;
	flex-shrink: 0;
}

.tut-card__img img {
	width: 100%;
	height: 100%;
	object-fit: cover;
	transition: transform 0.4s ease;
}

.tut-card:hover .tut-card__img img { transform: scale(1.05); }

.tut-card__body {
	padding: 1.1rem 1.25rem 1.25rem;
	display: flex;
	flex-direction: column;
	gap: 0.4rem;
	flex: 1;
}

.tut-card__body h3 {
	font-size: 1rem;
	line-height: 1.4;
	margin: 0;
	transition: color 0.2s;
}

.tut-card:hover h3 { color: var(--primary); }

.tut-card__body p {
	font-size: 0.85rem;
	color: rgb(var(--gray));
	margin: 0;
	display: -webkit-box;
	-webkit-line-clamp: 2;
	-webkit-box-orient: vertical;
	overflow: hidden;
}

.tut-badge {
	display: inline-block;
	font-size: 0.7rem;
	font-weight: 700;
	text-transform: uppercase;
	letter-spacing: 0.06em;
	padding: 0.2rem 0.6rem;
	border-radius: 99px;
	background: var(--primary-light);
	color: var(--primary);
	width: fit-content;
}

.tut-badge--explain {
	background: #f0f4ff;
	color: #4060d0;
}

.tut-meta {
	font-size: 0.75rem;
	color: rgb(var(--gray));
	margin-top: auto;
	padding-top: 0.5rem;
}
</style>
