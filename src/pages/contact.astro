---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
<head>
	<BaseHead
		title={`Contact Us | ${SITE_TITLE}`}
		description="Get in touch with the AI Briefs team. Report a broken tool, suggest a new AI tool, or ask a question."
	/>
</head>
<body>
<Header />

<section class="page-header">
	<div class="container">
		<Breadcrumb crumbs={[{ label: 'Home', href: '/' }, { label: 'Contact' }]} />
		<h1>Contact Us</h1>
		<p>Have a question, spotted an error, or want to suggest a tool? We'd love to hear from you.</p>
	</div>
</section>

<main class="container contact-body">
	<div class="contact-grid">

		<!-- Form -->
		<div class="contact-form-wrap">
			<h2>Send a Message</h2>
			<form id="contact-form" action="https://formspree.io/f/xkopzklp" method="POST" novalidate>
				<div class="field-row">
					<div class="field">
						<label for="name">Your Name <span class="req">*</span></label>
						<input type="text" id="name" name="name" placeholder="Jane Smith" required autocomplete="name" />
					</div>
					<div class="field">
						<label for="email">Email Address <span class="req">*</span></label>
						<input type="email" id="email" name="email" placeholder="jane@example.com" required autocomplete="email" />
					</div>
				</div>
				<div class="field">
					<label for="subject">Subject <span class="req">*</span></label>
					<select id="subject" name="subject" required>
						<option value="" disabled selected>Select a topic…</option>
						<option value="Featured Listing">Featured Listing (Waitlist)</option>
						<option value="Submit a Tool">Submit a Tool</option>
						<option value="Report an Error">Report an Error</option>
						<option value="Advertising / Partnership">Advertising / Partnership</option>
						<option value="Press Enquiry">Press Enquiry</option>
						<option value="Technical Issue">Technical Issue</option>
						<option value="General Question">General Question</option>
					</select>
				</div>
				<div class="field">
					<label for="message">Message <span class="req">*</span></label>
					<textarea id="message" name="message" rows="6" placeholder="Tell us how we can help…" required></textarea>
				</div>
				<input type="hidden" name="_subject" value="New contact from AI Briefs" />
				<button type="submit" class="btn btn--primary submit-btn" id="submit-btn">Send Message</button>
				<p class="form-note">We aim to respond within 1–2 business days.</p>
				<div id="form-success" class="form-success" hidden>
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
					Message sent! We'll be in touch soon.
				</div>
				<div id="form-error" class="form-error" hidden>
					Something went wrong. Please try again or email us directly.
				</div>
			</form>
		</div>

		<!-- Sidebar info -->
		<aside class="contact-sidebar">
<div class="info-card">
				<div class="info-icon">🛠️</div>
				<h3>Submit a Tool</h3>
				<p>Want us to list your AI tool?</p>
				<a href="/submit/" class="btn btn--secondary btn--sm mt-sm">Submit a Tool →</a>
			</div>
			<div class="info-card">
				<div class="info-icon">📰</div>
				<h3>Press & Media</h3>
				<p>For press enquiries, interviews, or partnerships, select "Press Enquiry" in the form.</p>
			</div>
		</aside>

	</div>
</main>

<Footer />
</body>
</html>

<script data-astro-rerun>
const form = document.getElementById('contact-form') as HTMLFormElement;
const btn = document.getElementById('submit-btn') as HTMLButtonElement;
const success = document.getElementById('form-success')!;
const error = document.getElementById('form-error')!;

const params = new URLSearchParams(location.search);
const pre = params.get('subject');
if (pre) {
	const select = document.getElementById('subject') as HTMLSelectElement;
	const match = Array.from(select.options).find(
		o => o.value.toLowerCase() === pre.toLowerCase()
	);
	if (match) select.value = match.value;
}

form?.addEventListener('submit', async (e) => {
	e.preventDefault();
	btn.disabled = true;
	btn.textContent = 'Sending…';
	success.hidden = true;
	error.hidden = true;
	try {
		const res = await fetch(form.action, {
			method: 'POST',
			body: new FormData(form),
			headers: { Accept: 'application/json' },
		});
		if (res.ok) {
			success.hidden = false;
			form.reset();
		} else {
			error.hidden = false;
		}
	} catch {
		error.hidden = false;
	} finally {
		btn.disabled = false;
		btn.textContent = 'Send Message';
	}
});
</script>

<style>
.page-header {
	background: linear-gradient(135deg, var(--primary-light) 0%, var(--bg) 100%);
	border-bottom: 1px solid var(--border);
	padding: 3rem 0 2rem;
}
.page-header h1 { font-size: clamp(1.8rem, 4vw, 2.4rem); margin: 0.5rem 0 0.5rem; }
.page-header p { color: rgb(var(--gray)); max-width: 520px; }

.contact-body { padding: 3rem 0 5rem; }

.contact-grid {
	display: grid;
	grid-template-columns: 1fr;
	gap: 2.5rem;
}

@media (min-width: 900px) {
	.contact-grid { grid-template-columns: 1fr 280px; }
}

.contact-form-wrap h2 { font-size: 1.25rem; margin-bottom: 1.5rem; }

.field-row {
	display: grid;
	grid-template-columns: 1fr 1fr;
	gap: 1rem;
}
@media (max-width: 600px) { .field-row { grid-template-columns: 1fr; } }

.field { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1rem; }
.field label { font-size: 0.85rem; font-weight: 600; color: rgb(var(--black)); }
.req { color: #e53e3e; }

.field input,
.field select,
.field textarea {
	padding: 0.65rem 0.85rem;
	border: 1.5px solid var(--border);
	border-radius: var(--radius);
	font-size: 0.9rem;
	font-family: inherit;
	background: var(--bg);
	color: rgb(var(--black));
	transition: border-color 0.15s;
	width: 100%;
}
.field input:focus,
.field select:focus,
.field textarea:focus {
	outline: none;
	border-color: var(--primary);
}
.field textarea { resize: vertical; min-height: 120px; }
.field select { cursor: pointer; }

.submit-btn { width: 100%; padding: 0.85rem; font-size: 1rem; cursor: pointer; }
.submit-btn:disabled { opacity: 0.6; cursor: not-allowed; }

.form-note { font-size: 0.78rem; color: rgb(var(--gray)); text-align: center; margin-top: 0.5rem; }

.form-success {
	display: flex;
	align-items: center;
	gap: 0.5rem;
	background: #e0f5ee;
	color: #00875a;
	border: 1px solid #00875a33;
	border-radius: var(--radius);
	padding: 0.75rem 1rem;
	font-weight: 600;
	font-size: 0.9rem;
	margin-top: 1rem;
}
.form-error {
	background: #fff0f0;
	color: #c53030;
	border: 1px solid #c5303033;
	border-radius: var(--radius);
	padding: 0.75rem 1rem;
	font-size: 0.9rem;
	margin-top: 1rem;
}

/* Sidebar */
.contact-sidebar { display: flex; flex-direction: column; gap: 1rem; }

.info-card {
	padding: 1.25rem;
	border: 1px solid var(--border);
	border-radius: var(--radius);
	background: var(--bg);
}
.info-icon { font-size: 1.5rem; margin-bottom: 0.5rem; }
.info-card h3 { font-size: 0.9rem; margin: 0 0 0.3rem; }
.info-card p { font-size: 0.83rem; color: rgb(var(--gray)); margin: 0; }
.mt-sm { margin-top: 0.75rem; }
.btn--secondary {
	display: inline-block;
	padding: 0.45rem 0.9rem;
	border: 1.5px solid var(--primary);
	color: var(--primary);
	border-radius: var(--radius);
	font-size: 0.82rem;
	font-weight: 700;
	transition: background 0.15s, color 0.15s;
}
.btn--secondary:hover { background: var(--primary); color: #fff; }
.btn--sm { font-size: 0.8rem; padding: 0.4rem 0.8rem; }
</style>
