---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

interface NewsItem { title: string; link: string; date: string; source: string; }
interface Snapshot { date: string; fetchedAt?: string; items: NewsItem[]; }

export async function getStaticPaths() {
	const snapshots = import.meta.glob<Snapshot>('../../data/news/*.json', { eager: true });
	const entries = Object.entries(snapshots).map(([path, data]) => {
		const slug = path.split('/').pop()!.replace(/\.json$/, '');
		return { slug, data };
	}).sort((a, b) => b.slug.localeCompare(a.slug));

	return entries.map((entry, i) => ({
		params: { date: entry.slug },
		props: {
			snapshot: entry.data,
			prevDate: entries[i + 1]?.slug ?? null,
			nextDate: entries[i - 1]?.slug ?? null,
		},
	}));
}

interface Props {
	snapshot: Snapshot;
	prevDate: string | null;
	nextDate: string | null;
}

const { snapshot, prevDate, nextDate } = Astro.props;
const { date, items } = snapshot;

const displayDate = new Date(date + 'T00:00:00Z').toLocaleDateString('en-US', {
	weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC',
});

const title = `AI News — ${displayDate}`;
const description = `${items.length} AI headlines from ${new Set(items.map(i => i.source)).size} outlets on ${displayDate}. Daily snapshot of what's happening in AI.`;
---

<!doctype html>
<html lang="en">
<head>
	<BaseHead title={title} description={description} type="article" publishDate={new Date(date + 'T00:00:00Z')} />
</head>
<body>
<Header />

<main id="main-content">
	<section class="section">
		<div class="container news-archive">
			<nav class="news-crumbs" aria-label="Breadcrumb">
				<a href="/">Home</a> <span>/</span> <a href="/news/">AI News</a> <span>/</span> <span>{date}</span>
			</nav>

			<h1 class="news-title">AI News — {displayDate}</h1>
			<p class="news-sub">{items.length} headlines from {new Set(items.map(i => i.source)).size} outlets, deduped.</p>

			<div class="news-timeline">
				{items.map(item => {
					const d = item.date ? new Date(item.date) : null;
					const iso = d && !isNaN(d.getTime()) ? d.toISOString() : '';
					const fallback = d && !isNaN(d.getTime()) ? d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) : '';
					return (
						<a href={item.link} target="_blank" rel="noopener noreferrer" class="timeline-item">
							<div class="timeline-dot"></div>
							<div class="timeline-body">
								<div class="timeline-meta">
									{iso && <span class="timeline-date" data-date={iso}>{fallback}</span>}
								</div>
								<p class="timeline-title">{item.title}</p>
							</div>
							<span class="timeline-arrow">→</span>
						</a>
					);
				})}
			</div>

			<nav class="news-pager" aria-label="Archive navigation">
				{prevDate ? <a href={`/news/${prevDate}/`} class="pager-link pager-prev">← {prevDate}</a> : <span class="pager-link pager-disabled">← Earlier</span>}
				<a href="/news/" class="pager-link pager-all">All dates</a>
				{nextDate ? <a href={`/news/${nextDate}/`} class="pager-link pager-next">{nextDate} →</a> : <span class="pager-link pager-disabled">Later →</span>}
			</nav>
		</div>
	</section>
</main>

<Footer />

<script is:inline>
	function formatRelative(iso) {
		const date = new Date(iso);
		if (isNaN(date.getTime())) return '';
		const diff = (Date.now() - date.getTime()) / 1000;
		if (diff < 60) return 'just now';
		if (diff < 3600) return `${Math.floor(diff / 60)}m ago`;
		if (diff < 86400) return `${Math.floor(diff / 3600)}h ago`;
		if (diff < 604800) return `${Math.floor(diff / 86400)}d ago`;
		return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
	}
	document.querySelectorAll('.timeline-date[data-date]').forEach(function(el) {
		const iso = el.getAttribute('data-date');
		if (iso) el.textContent = formatRelative(iso);
	});
</script>

<style>
	.news-archive { max-width: 760px; }
	.news-crumbs { font-size: 0.85rem; color: rgb(var(--gray)); margin-bottom: 1rem; }
	.news-crumbs a { color: var(--primary); }
	.news-crumbs span { margin: 0 0.4rem; }
	.news-title { font-size: 2rem; font-weight: 800; margin: 0 0 0.35rem; color: rgb(var(--black)); }
	.news-sub { font-size: 0.95rem; color: rgb(var(--gray)); margin: 0 0 1.75rem; }

	.news-timeline { display: flex; flex-direction: column; border-left: 2px solid var(--border); margin-left: 0.5rem; padding-left: 1.25rem; gap: 0; }
	.timeline-item { display: flex; align-items: flex-start; gap: 0.75rem; padding: 0.85rem 0; border-bottom: 1px solid var(--border); color: inherit; position: relative; transition: background 0.15s; }
	.timeline-item:last-child { border-bottom: none; }
	.timeline-dot { width: 10px; height: 10px; background: var(--primary); border-radius: 50%; flex-shrink: 0; margin-top: 4px; position: absolute; left: -1.55rem; border: 2px solid #fff; }
	.timeline-body { flex: 1; }
	.timeline-meta { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.2rem; }
	.timeline-date { font-size: 0.7rem; color: rgb(var(--gray)); font-weight: 600; }
	.timeline-title { font-size: 0.95rem; font-weight: 600; color: rgb(var(--black)); margin: 0; line-height: 1.5; }
	.timeline-item:hover .timeline-title { color: var(--primary); }
	.timeline-arrow { font-size: 0.9rem; color: rgb(var(--gray)); flex-shrink: 0; margin-top: 2px; }

	.news-pager { display: flex; justify-content: space-between; align-items: center; gap: 1rem; margin-top: 2.5rem; flex-wrap: wrap; }
	.pager-link { font-size: 0.9rem; font-weight: 600; color: var(--primary); padding: 0.55rem 0.9rem; border: 1px solid var(--border); border-radius: var(--radius); }
	.pager-link:hover:not(.pager-disabled) { background: var(--primary-light); border-color: var(--primary); }
	.pager-disabled { color: rgb(var(--gray)); cursor: not-allowed; opacity: 0.6; }
	.pager-all { background: var(--primary); color: #fff; border-color: var(--primary); }
	.pager-all:hover { background: var(--primary-dark); color: #fff !important; }
</style>
</body>
</html>
