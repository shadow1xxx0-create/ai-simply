---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { TOOL_CATEGORIES, SITE_TITLE } from '../../consts';

const allTools = await getCollection('tools');

// Compact tool data passed to client — only what scoring needs
const toolsData = allTools.map(t => ({
  id: t.id,
  name: t.data.name,
  description: t.data.description,
  category: t.data.category,
  pricing: t.data.pricing,
  url: t.data.url,
  rating: t.data.rating ?? null,
  ratingCount: t.data.ratingCount ?? null,
  featured: t.data.featured,
  verified: t.data.verified,
  tags: t.data.tags,
}));

const catsData = TOOL_CATEGORIES.map(c => ({ slug: c.slug, name: c.name, emoji: c.emoji }));
---

<!doctype html>
<html lang="en">
<head>
  <BaseHead
    title={`AI Tool Finder Quiz — Find Your Perfect Match | ${SITE_TITLE}`}
    description="Answer 5 quick questions and get personalised AI tool recommendations from 200+ tools — matched to your goals, role, and budget."
  />
</head>
<body class="quiz-page">
<Header />
<main id="quiz-main">
  <div id="quiz-app" role="main" aria-live="polite">
    <noscript>
      <div class="noscript-msg">
        <p>This quiz requires JavaScript. <a href="/tools/">Browse all 200+ AI tools →</a></p>
      </div>
    </noscript>
  </div>
</main>
<Footer />

<script define:vars={{ toolsData, catsData }} data-astro-rerun>

/* ─── DATA ────────────────────────────────────────────────────── */

const QUESTIONS = [
  {
    id: 'goal',
    step: 1,
    question: 'What do you mainly want to achieve with AI?',
    subtitle: 'Pick the one that fits best — we\'ll personalise your results from 200+ tools.',
    options: [
      { id: 'write',    emoji: '✍️', label: 'Write better content',       sub: 'Blog posts, emails, copy, scripts' },
      { id: 'images',   emoji: '🖼️', label: 'Generate images & visuals',  sub: 'Photos, illustrations, art, design' },
      { id: 'code',     emoji: '💻', label: 'Code and build software',     sub: 'Autocomplete, debugging, generation' },
      { id: 'business', emoji: '📊', label: 'Run and grow my business',    sub: 'Marketing, automation, CRM, analytics' },
      { id: 'video',    emoji: '🎬', label: 'Create videos and audio',     sub: 'Video generation, voice cloning, music' },
      { id: 'research', emoji: '💬', label: 'Research and get answers',    sub: 'Q&A, summarise documents, learn fast' },
      { id: 'design',   emoji: '🎨', label: 'Design and creative work',    sub: 'UI, logos, branding, 3D, graphics' },
    ],
  },
  {
    id: 'role',
    step: 2,
    question: 'Which best describes you?',
    subtitle: 'This helps us weight tools suited to your context and experience.',
    options: [
      { id: 'student',  emoji: '🎓', label: 'Student or researcher',       sub: 'Learning, essays, research papers' },
      { id: 'pro',      emoji: '💼', label: 'Working professional',         sub: 'Productivity, reports, communication' },
      { id: 'dev',      emoji: '🧑‍💻', label: 'Developer or engineer',     sub: 'APIs, code, technical side projects' },
      { id: 'creator',  emoji: '🎨', label: 'Content creator or artist',   sub: 'YouTube, social, design, music' },
      { id: 'biz',      emoji: '🏢', label: 'Business owner or marketer',  sub: 'Growth, campaigns, customer ops' },
      { id: 'newcomer', emoji: '🤔', label: 'Curious AI newcomer',         sub: 'Just exploring — new to all this' },
    ],
  },
  {
    id: 'budget',
    step: 3,
    question: "What's your budget?",
    subtitle: "We'll make sure every recommendation fits your spending comfort.",
    options: [
      { id: 'free',     emoji: '🆓', label: 'Has a free tier',            sub: 'Free or freemium — start without paying' },
      { id: 'freemium', emoji: '💳', label: 'Open to paying if it\'s worth it', sub: 'Mix of freemium and paid tools' },
      { id: 'any',      emoji: '🚀', label: 'Budget isn\'t the priority', sub: 'Show me the best, whatever the price' },
    ],
  },
  {
    id: 'freq',
    step: 4,
    question: 'How will you use AI day-to-day?',
    subtitle: 'Frequent use cases versus one-off projects need different tools.',
    options: [
      { id: 'daily',     emoji: '📅', label: 'Every day for work or study', sub: 'I\'ll use this constantly' },
      { id: 'project',   emoji: '🎯', label: 'For a specific project',      sub: 'One big use case I\'m working on' },
      { id: 'exploring', emoji: '🔍', label: 'Just exploring AI',           sub: 'Curious — no specific plan yet' },
      { id: 'building',  emoji: '🔨', label: 'Building something with AI',  sub: 'Integrating AI into a product' },
    ],
  },
  {
    id: 'tech',
    step: 5,
    question: 'How technical are you?',
    subtitle: "We'll match you with tools that fit your comfort level.",
    options: [
      { id: 'easy', emoji: '🖱️', label: 'Non-technical',         sub: 'Point, click, done — no setup please' },
      { id: 'mid',  emoji: '⚙️', label: 'Somewhat technical',    sub: 'Fine with some configuration' },
      { id: 'dev',  emoji: '🔌', label: 'Very technical',         sub: 'I want APIs, SDKs, and integrations' },
    ],
  },
];

/* ─── SCORING MATRIX ──────────────────────────────────────────── */

const SCORES = {
  goal: {
    write:    { 'ai-writing': 5, 'ai-marketing': 3, 'ai-productivity': 2 },
    images:   { 'ai-image': 5, 'ai-art': 4, 'ai-design': 2 },
    code:     { 'ai-coding': 5, 'ai-productivity': 2 },
    business: { 'ai-business': 5, 'ai-marketing': 4, 'ai-productivity': 3 },
    video:    { 'ai-video': 5, 'ai-voice': 3 },
    research: { 'ai-chatbot': 5, 'ai-research': 4, 'ai-learning': 3 },
    design:   { 'ai-design': 5, 'ai-art': 3, 'ai-image': 2 },
  },
  role: {
    student:  { 'ai-learning': 3, 'ai-research': 3, 'ai-writing': 2, 'ai-chatbot': 2 },
    pro:      { 'ai-productivity': 3, 'ai-writing': 2, 'ai-business': 2 },
    dev:      { 'ai-coding': 4, 'ai-productivity': 2 },
    creator:  { 'ai-image': 2, 'ai-video': 2, 'ai-art': 2, 'ai-writing': 2 },
    biz:      { 'ai-business': 3, 'ai-marketing': 3, 'ai-productivity': 2 },
    newcomer: { 'ai-chatbot': 3, 'ai-learning': 3 },
  },
  freq: {
    daily:     { 'ai-productivity': 2, 'ai-writing': 1 },
    project:   {},
    exploring: { 'ai-chatbot': 2, 'ai-learning': 1 },
    building:  { 'ai-coding': 2, 'ai-productivity': 1 },
  },
  tech: {
    easy: {},
    mid:  {},
    dev:  { 'ai-coding': 2 },
  },
};

const PRICING_FILTER = {
  free:     ['free', 'freemium'],
  freemium: ['free', 'freemium', 'paid'],
  any:      ['free', 'freemium', 'paid'],
};

/* ─── STATE ───────────────────────────────────────────────────── */

const state = {
  step: 0,
  answers: {},
  results: [],
  transitioning: false,
};

/* ─── SCORING ENGINE ──────────────────────────────────────────── */

function scoreTools(answers) {
  // Build category weight map
  const catWeights = {};
  for (const [qId, optId] of Object.entries(answers)) {
    if (qId === 'budget') continue;
    const map = SCORES[qId]?.[optId] ?? {};
    for (const [cat, w] of Object.entries(map)) {
      catWeights[cat] = (catWeights[cat] ?? 0) + w;
    }
  }

  const allowedPricing = PRICING_FILTER[answers.budget ?? 'any'];

  const scored = toolsData
    .filter(t => allowedPricing.includes(t.pricing))
    .map(t => {
      let score = catWeights[t.category] ?? 0;
      // Quality / curation bonuses (these break ties between tools in the same category)
      if (t.featured)                              score += 2;
      if (t.verified)                              score += 0.5;
      if (t.rating)                                score += (t.rating - 4.0) * 1.5;
      if (t.ratingCount)                           score += Math.min(1.5, Math.log10(t.ratingCount + 1) * 0.4);
      // Pricing preference bonus — within "has a free tier", prefer truly free over freemium
      if (answers.budget === 'free' && t.pricing === 'free') score += 0.75;
      // Tech-level bonuses
      if (answers.tech === 'dev'  && (t.tags?.includes('api') || t.tags?.includes('sdk') || t.category === 'ai-coding')) score += 1;
      if (answers.tech === 'easy' && t.rating && t.rating >= 4.5) score += 0.5;
      return { ...t, score };
    })
    .filter(t => t.score > 0)
    .sort((a, b) => {
      if (b.score !== a.score) return b.score - a.score;
      // Stable tiebreakers when scores are equal
      if ((b.featured ? 1 : 0) !== (a.featured ? 1 : 0)) return (b.featured ? 1 : 0) - (a.featured ? 1 : 0);
      if ((b.rating ?? 0) !== (a.rating ?? 0))           return (b.rating ?? 0) - (a.rating ?? 0);
      if ((b.ratingCount ?? 0) !== (a.ratingCount ?? 0)) return (b.ratingCount ?? 0) - (a.ratingCount ?? 0);
      return a.name.localeCompare(b.name);
    });

  // Match % derived from actual score relative to the top match (not rank position).
  // Tied tools get the same %, which is honest. Floor at 62% so even weaker matches feel reasonable.
  const maxScore = scored[0]?.score ?? 1;
  return scored.slice(0, 8).map(t => ({
    ...t,
    matchPct: Math.round(Math.max(62, Math.min(98, 62 + (t.score / maxScore) * 36))),
  }));
}

function getMatchReason(tool, answers) {
  const reasons = [];
  const cat = catsData.find(c => c.slug === tool.category);

  if (answers.goal === 'write'    && ['ai-writing','ai-marketing'].includes(tool.category)) reasons.push('matches your writing goal');
  if (answers.goal === 'images'   && ['ai-image','ai-art'].includes(tool.category))         reasons.push('perfect for image creation');
  if (answers.goal === 'code'     && tool.category === 'ai-coding')                         reasons.push('built for coders');
  if (answers.goal === 'business' && ['ai-business','ai-marketing'].includes(tool.category)) reasons.push('built for business');
  if (answers.goal === 'video'    && ['ai-video','ai-voice'].includes(tool.category))       reasons.push('great for video & audio');
  if (answers.goal === 'research' && ['ai-chatbot','ai-research'].includes(tool.category)) reasons.push('ideal for research');
  if (answers.goal === 'design'   && ['ai-design','ai-art'].includes(tool.category))       reasons.push('top design tool');

  if (answers.role === 'student'  && ['ai-learning','ai-research'].includes(tool.category)) reasons.push('popular with students');
  if (answers.role === 'dev'      && tool.category === 'ai-coding')                         reasons.push('developer favourite');
  if (answers.role === 'creator'  && ['ai-image','ai-video','ai-art'].includes(tool.category)) reasons.push('loved by creators');
  if (answers.role === 'newcomer' && ['ai-chatbot','ai-learning'].includes(tool.category)) reasons.push('great starting point');

  if (answers.budget === 'free' && tool.pricing === 'free') reasons.push('100% free');
  if (tool.rating && tool.rating >= 4.7) reasons.push(`top-rated ${tool.rating}/5`);
  if (tool.featured) reasons.push("editor's pick");

  const top = reasons.slice(0, 2);
  if (top.length === 0 && cat) top.push(`top ${cat.name} tool`);
  return top.join(' · ');
}

function getCategoryOf(tool) {
  return catsData.find(c => c.slug === tool.category);
}

function faviconUrl(url) {
  try { return `https://www.google.com/s2/favicons?domain=${new URL(url).hostname}&sz=64`; }
  catch { return ''; }
}

function esc(str) {
  const d = document.createElement('div');
  d.textContent = str;
  return d.innerHTML;
}

function pricingBadge(pricing) {
  const MAP = {
    free:     { bg: '#E0F5EE', color: '#00875A', label: 'Free' },
    freemium: { bg: '#EEF3FF', color: '#3B5BDB', label: 'Freemium' },
    paid:     { bg: '#FFF4E6', color: '#E67700', label: 'Paid' },
  };
  return MAP[pricing] ?? MAP.freemium;
}

/* ─── URL SHARING ─────────────────────────────────────────────── */

function encodeAnswers(answers) {
  const keys = ['goal','role','budget','freq','tech'];
  return keys.map(k => answers[k] ?? '').join(',');
}

function decodeAnswers(str) {
  if (!str) return null;
  const keys = ['goal','role','budget','freq','tech'];
  const vals = str.split(',');
  const out = {};
  keys.forEach((k, i) => { if (vals[i]) out[k] = vals[i]; });
  return Object.keys(out).length === 5 ? out : null;
}

/* ─── RENDERERS ───────────────────────────────────────────────── */

function renderIntro() {
  return `
    <div class="qz-intro">
      <div class="qz-intro__icon">🎯</div>
      <h1 class="qz-intro__title">Find Your Perfect AI Tool</h1>
      <p class="qz-intro__sub">5 quick questions. Personalised matches from 200+ AI tools — filtered to your goals, role, and budget.</p>
      <div class="qz-intro__stats">
        <span>✓ 200+ tools</span>
        <span>✓ 22 categories</span>
        <span>✓ ~1 minute</span>
      </div>
      <button class="qz-start-btn" id="qz-start">Start the Quiz →</button>
      <p class="qz-intro__privacy">No sign-up. No data stored. Results are instant.</p>
    </div>
  `;
}

function renderQuestion(q, currentAnswer) {
  const progress = (q.step / 5) * 100;
  return `
    <div class="qz-question">
      <div class="qz-progress">
        <div class="qz-progress__bar" style="width:${progress}%"></div>
      </div>
      <div class="qz-q-header">
        <span class="qz-step">Question ${q.step} of 5</span>
        ${q.step > 1 ? `<button class="qz-back-btn" id="qz-back">← Back</button>` : ''}
      </div>
      <h2 class="qz-q-title">${q.question}</h2>
      <p class="qz-q-sub">${q.subtitle}</p>
      <div class="qz-options qz-options--${q.options.length <= 4 ? 'small' : 'large'}" id="qz-options">
        ${q.options.map(opt => `
          <button
            class="qz-option${currentAnswer === opt.id ? ' selected' : ''}"
            data-value="${opt.id}"
            aria-pressed="${currentAnswer === opt.id ? 'true' : 'false'}"
          >
            <span class="qz-option__emoji">${opt.emoji}</span>
            <span class="qz-option__label">${opt.label}</span>
            <span class="qz-option__sub">${opt.sub}</span>
            <span class="qz-option__check" aria-hidden="true">✓</span>
          </button>
        `).join('')}
      </div>
      <div class="qz-nav">
        <button class="qz-next-btn${currentAnswer ? '' : ' disabled'}" id="qz-next" ${!currentAnswer ? 'disabled' : ''}>
          ${q.step < 5 ? 'Next Question →' : 'See My Matches →'}
        </button>
      </div>
    </div>
  `;
}

function renderCalculating() {
  return `
    <div class="qz-calculating">
      <div class="qz-calc-spinner"></div>
      <h2>Finding your matches…</h2>
      <p>Scoring 200+ tools against your answers</p>
      <div class="qz-calc-steps">
        <span class="qz-calc-step active" id="cs1">Analysing your goals</span>
        <span class="qz-calc-step" id="cs2">Filtering by budget</span>
        <span class="qz-calc-step" id="cs3">Ranking top matches</span>
      </div>
    </div>
  `;
}

function renderResults(results, answers) {
  const topMatches = results.slice(0, 3);
  const alsoConsider = results.slice(3);
  const goalLabel = QUESTIONS[0].options.find(o => o.id === answers.goal)?.label ?? '';
  const roleLabel = QUESTIONS[1].options.find(o => o.id === answers.role)?.label ?? '';

  const shareUrl = `${window.location.origin}/tools/quiz/?r=${encodeURIComponent(encodeAnswers(answers))}`;

  return `
    <div class="qz-results">
      <div class="qz-results__hero">
        <div class="qz-results__badge">Your AI Matches</div>
        <h1 class="qz-results__title">Here are your top picks</h1>
        <p class="qz-results__sub">
          Based on your goal to <strong>${goalLabel.toLowerCase()}</strong> as a <strong>${roleLabel.toLowerCase()}</strong>
          — scored and ranked from ${toolsData.filter(t => PRICING_FILTER[answers.budget].includes(t.pricing)).length}+ eligible tools.
        </p>
      </div>

      <div class="qz-top-matches">
        ${topMatches.map((tool, i) => {
          const cat = getCategoryOf(tool);
          const badge = pricingBadge(tool.pricing);
          const reason = getMatchReason(tool, answers);
          const favicon = faviconUrl(tool.url);
          const medals = ['🥇','🥈','🥉'];
          return `
            <a href="/tools/${tool.id}/" class="qz-match-card qz-match-card--top" target="_self">
              <div class="qz-match-card__rank">${medals[i]}</div>
              <div class="qz-match-card__head">
                <div class="qz-match-logo">
                  <img src="${favicon}" alt="${esc(tool.name)}" width="44" height="44" loading="${i === 0 ? 'eager' : 'lazy'}"
                    class="qz-favicon" />
                  <span class="qz-match-logo-fb" style="display:none">${cat?.emoji ?? '🤖'}</span>
                </div>
                <div class="qz-match-info">
                  <div class="qz-match-name-row">
                    <h3 class="qz-match-name">${esc(tool.name)}</h3>
                    <span class="qz-pricing-pill" style="background:${badge.bg};color:${badge.color}">${badge.label}</span>
                  </div>
                  <span class="qz-match-cat">${cat?.emoji ?? ''} ${esc(cat?.name ?? '')}</span>
                </div>
                <div class="qz-match-pct">
                  <span class="qz-pct-num">${tool.matchPct}%</span>
                  <span class="qz-pct-label">match</span>
                </div>
              </div>
              <div class="qz-match-bar-wrap">
                <div class="qz-match-bar" style="--pct:${tool.matchPct}%"></div>
              </div>
              <p class="qz-match-desc">${esc(tool.description)}</p>
              ${reason ? `<div class="qz-match-reason">✓ ${esc(reason)}</div>` : ''}
              <span class="qz-match-cta">Explore ${esc(tool.name)} →</span>
            </a>
          `;
        }).join('')}
      </div>

      ${alsoConsider.length > 0 ? `
        <div class="qz-also">
          <h2 class="qz-also__title">Also worth considering</h2>
          <div class="qz-also-grid">
            ${alsoConsider.map(tool => {
              const cat = getCategoryOf(tool);
              const badge = pricingBadge(tool.pricing);
              const favicon = faviconUrl(tool.url);
              return `
                <a href="/tools/${tool.id}/" class="qz-also-card" target="_self">
                  <div class="qz-also-head">
                    <div class="qz-also-logo">
                      <img src="${favicon}" alt="${esc(tool.name)}" width="32" height="32" loading="lazy"
                        class="qz-favicon" />
                      <span class="qz-also-logo-fb" style="display:none">${cat?.emoji ?? '🤖'}</span>
                    </div>
                    <div>
                      <div class="qz-also-name">${esc(tool.name)}</div>
                      <span class="qz-pricing-pill" style="background:${badge.bg};color:${badge.color};font-size:0.6rem">${badge.label}</span>
                    </div>
                    <span class="qz-also-pct">${tool.matchPct}%</span>
                  </div>
                  <p class="qz-also-desc">${esc(tool.description)}</p>
                </a>
              `;
            }).join('')}
          </div>
        </div>
      ` : ''}

      <div class="qz-results-actions">
        <button class="qz-retake-btn" id="qz-retake">↺ Retake Quiz</button>
        <button class="qz-share-btn" id="qz-share" data-url="${shareUrl}">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
          Share Results
        </button>
        <a href="/tools/" class="qz-browse-btn">Browse All Tools →</a>
      </div>

      <p class="qz-disclaimer">Results are personalised based on your answers. <a href="/rating-methodology/">How we rate tools.</a></p>
    </div>
  `;
}

/* ─── TRANSITIONS ─────────────────────────────────────────────── */

function mount(html, direction = 'forward') {
  const app = document.getElementById('quiz-app');
  if (!app) return;

  const incoming = document.createElement('div');
  incoming.className = `qz-screen qz-screen--${direction === 'forward' ? 'enter-right' : 'enter-left'}`;
  incoming.innerHTML = html;

  const current = app.querySelector('.qz-screen');
  if (current) {
    current.classList.add(direction === 'forward' ? 'qz-screen--exit-left' : 'qz-screen--exit-right');
    setTimeout(() => current.remove(), 280);
  }

  app.appendChild(incoming);
  // Trigger reflow then animate in
  requestAnimationFrame(() => {
    requestAnimationFrame(() => {
      incoming.classList.remove('qz-screen--enter-right', 'qz-screen--enter-left');
      incoming.classList.add('qz-screen--active');
    });
  });

  bindEvents();
}

/* ─── EVENT BINDING ───────────────────────────────────────────── */

function bindEvents() {
  const app = document.getElementById('quiz-app');
  if (!app) return;
  // Always bind to the last (newest) screen so old exiting screens don't intercept
  const root = app.lastElementChild || app;

  // Favicon error fallback
  root.querySelectorAll('.qz-favicon').forEach(img => {
    img.addEventListener('error', () => {
      img.style.display = 'none';
      const fb = img.nextElementSibling;
      if (fb) fb.style.display = 'flex';
    }, { once: true });
  });

  // Start button
  root.querySelector('#qz-start')?.addEventListener('click', () => {
    state.step = 1;
    mount(renderQuestion(QUESTIONS[0], state.answers['goal']));
  });

  // Option selection
  root.querySelector('#qz-options')?.addEventListener('click', e => {
    const btn = e.target.closest('.qz-option');
    if (!btn) return;
    const val = btn.dataset.value;
    const qId = QUESTIONS[state.step - 1].id;
    state.answers[qId] = val;

    // Update UI without full re-render
    root.querySelectorAll('.qz-option').forEach(b => {
      const sel = b.dataset.value === val;
      b.classList.toggle('selected', sel);
      b.setAttribute('aria-pressed', sel ? 'true' : 'false');
    });
    const nextBtn = root.querySelector('#qz-next');
    if (nextBtn) { nextBtn.disabled = false; nextBtn.classList.remove('disabled'); }
  });

  // Next button
  root.querySelector('#qz-next')?.addEventListener('click', () => {
    const qId = QUESTIONS[state.step - 1].id;
    if (!state.answers[qId]) return;
    if (state.step < 5) {
      state.step++;
      mount(renderQuestion(QUESTIONS[state.step - 1], state.answers[QUESTIONS[state.step - 1].id]));
    } else {
      // Go to calculating → results
      state.step = 6;
      mount(renderCalculating());
      // Animate calculating steps
      let s = 1;
      const iv = setInterval(() => {
        if (s > 3) { clearInterval(iv); return; }
        document.getElementById(`cs${s}`)?.classList.add('done');
        s++;
        if (s <= 3) document.getElementById(`cs${s}`)?.classList.add('active');
      }, 350);
      setTimeout(() => {
        state.results = scoreTools(state.answers);
        state.step = 7;
        // Update URL for sharing
        const url = new URL(window.location.href);
        url.searchParams.set('r', encodeAnswers(state.answers));
        history.replaceState(null, '', url.toString());
        mount(renderResults(state.results, state.answers));
        // Animate match bars
        setTimeout(() => {
          document.querySelectorAll('.qz-match-bar').forEach(bar => {
            bar.classList.add('animated');
          });
        }, 100);
      }, 1400);
    }
  });

  // Back button
  root.querySelector('#qz-back')?.addEventListener('click', () => {
    if (state.step > 1) {
      state.step--;
      mount(renderQuestion(QUESTIONS[state.step - 1], state.answers[QUESTIONS[state.step - 1].id]), 'back');
    }
  });

  // Retake
  root.querySelector('#qz-retake')?.addEventListener('click', () => {
    state.step = 0;
    state.answers = {};
    state.results = [];
    history.replaceState(null, '', window.location.pathname);
    mount(renderIntro(), 'back');
  });

  // Share
  root.querySelector('#qz-share')?.addEventListener('click', async function() {
    const url = this.dataset.url;
    try {
      await navigator.clipboard.writeText(url);
      this.textContent = '✓ Link copied!';
      this.style.background = 'var(--primary)';
      this.style.color = '#fff';
      setTimeout(() => {
        this.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg> Share Results`;
        this.style.background = '';
        this.style.color = '';
      }, 2500);
    } catch {
      prompt('Copy this link:', url);
    }
  });
}

/* ─── INIT ────────────────────────────────────────────────────── */

function initQuiz() {
  const app = document.getElementById('quiz-app');
  if (!app) return;
  // If a previous mount left content (e.g. on SPA re-entry), clear and reset state.
  app.innerHTML = '';
  state.step = 0;
  state.answers = {};
  state.results = [];

  // Check for shared results in URL
  const params = new URLSearchParams(window.location.search);
  const shared = params.get('r');
  const decoded = shared ? decodeAnswers(decodeURIComponent(shared)) : null;

  if (decoded) {
    state.answers = decoded;
    state.results = scoreTools(decoded);
    state.step = 7;
    const screen = document.createElement('div');
    screen.className = 'qz-screen qz-screen--active';
    screen.innerHTML = renderResults(state.results, decoded);
    app.appendChild(screen);
    bindEvents();
    setTimeout(() => {
      document.querySelectorAll('.qz-match-bar').forEach(b => b.classList.add('animated'));
    }, 200);
  } else {
    const screen = document.createElement('div');
    screen.className = 'qz-screen qz-screen--active';
    screen.innerHTML = renderIntro();
    app.appendChild(screen);
    bindEvents();
  }
}

// Run now if the DOM is already parsed (true for body-placed scripts on initial
// load, and true on Astro ClientRouter re-execution since DOMContentLoaded
// already fired on the original page). Otherwise wait for it.
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initQuiz);
} else {
  initQuiz();
}

</script>

