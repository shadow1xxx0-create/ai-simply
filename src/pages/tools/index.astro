---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ToolCard from '../../components/ToolCard.astro';
import { TOOL_CATEGORIES, SITE_TITLE } from '../../consts';

const allTools = (await getCollection('tools'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const totalTools = allTools.length;

// Build counts per category
const catCounts: Record<string, number> = {};
for (const t of allTools) {
	catCounts[t.data.category] = (catCounts[t.data.category] ?? 0) + 1;
}
---

<!doctype html>
<html lang="en">
<head>
	<BaseHead
		title={`AI Tools Directory — ${totalTools}+ Tools | ${SITE_TITLE}`}
		description={`Browse ${totalTools}+ AI tools across 22 categories. Find the best free, freemium, and paid AI tools for productivity, writing, coding, image generation, and more.`}
	/>
</head>
<body>
<Header />

<div class="page-header">
	<div class="container">
		<h1>AI Tools Directory</h1>
		<p>{totalTools} tools across 22 categories</p>
	</div>
</div>

<!-- Category Rail -->
<div class="cat-rail-wrap">
	<button class="rail-arrow rail-arrow--left" id="rail-left" aria-label="Scroll left">‹</button>
	<div class="cat-rail" id="cat-rail">
		<button class="rail-item rail-item--active" data-rail-cat="all">All <span>{totalTools}</span></button>
		{TOOL_CATEGORIES.map(cat => (
			<button class="rail-item" data-rail-cat={cat.slug}>
				{cat.emoji} {cat.name} <span>{catCounts[cat.slug] ?? 0}</span>
			</button>
		))}
	</div>
	<button class="rail-arrow rail-arrow--right" id="rail-right" aria-label="Scroll right">›</button>
</div>

<main class="tools-main">
	<div class="container tools-layout">

		<!-- Sidebar -->
		<aside class="sidebar">
			<div class="sidebar__section">
				<h3 class="sidebar__heading">Categories</h3>
				<ul class="sidebar__list">
					<li>
						<button class="sidebar__item sidebar__item--active" data-filter-cat="all">
							All Tools
							<span class="sidebar__count">{totalTools}</span>
						</button>
					</li>
					{TOOL_CATEGORIES.map(cat => (
						<li>
							<button class="sidebar__item" data-filter-cat={cat.slug}>
								<span>{cat.emoji} {cat.name}</span>
								<span class="sidebar__count">{catCounts[cat.slug] ?? 0}</span>
							</button>
						</li>
					))}
				</ul>
			</div>

			<div class="sidebar__section">
				<h3 class="sidebar__heading">Pricing</h3>
				<ul class="sidebar__list">
					<li><button class="sidebar__item sidebar__item--active" data-filter-price="all">All</button></li>
					<li><button class="sidebar__item" data-filter-price="free">Free</button></li>
					<li><button class="sidebar__item" data-filter-price="freemium">Freemium</button></li>
					<li><button class="sidebar__item" data-filter-price="paid">Paid</button></li>
				</ul>
			</div>
		</aside>

		<!-- Main content -->
		<div class="tools-content">

			<!-- Toolbar -->
			<div class="toolbar">
				<div class="toolbar__search">
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
					<input
						type="search"
						id="tools-search"
						placeholder="Search tools..."
						autocomplete="off"
						aria-label="Search tools"
					/>
				</div>
				<div class="toolbar__sort">
					<label for="sort-select" class="sr-only">Sort by</label>
					<select id="sort-select">
						<option value="newest">Newest</option>
						<option value="name">A–Z</option>
						<option value="free">Free first</option>
					</select>
				</div>
			</div>

			<!-- Active filter label -->
			<p class="results-label" id="results-label">Showing all {totalTools} tools</p>

			<!-- Category subcategory chips (shown when category selected) -->
			<div class="subcats" id="subcats" style="display:none;"></div>

			<!-- Grid -->
			<div class="tools-grid" id="tools-grid">
				{allTools.map(tool => (
					<ToolCard
						name={tool.data.name}
						description={tool.data.description}
						category={tool.data.category}
						subcategory={tool.data.subcategory}
						pricing={tool.data.pricing}
						url={tool.data.url}
						slug={tool.id}
						tags={tool.data.tags}
						sponsored={tool.data.sponsored}
						verified={tool.data.verified}
					/>
				))}
			</div>

			<p class="no-results" id="no-results" style="display:none;">
				No tools found. <button id="clear-filters">Clear filters</button>
			</p>

			<div class="load-more-wrap" id="load-more-wrap" style="display:none;">
				<button class="load-more-btn" id="load-more-btn">Load more</button>
			</div>
		</div>
	</div>
</main>

<Footer />
</body>
</html>

<script data-astro-rerun>
function esc(str) {
	const d = document.createElement('span');
	d.textContent = str;
	return d.innerHTML;
}

// Category rail arrows
const rail = document.getElementById('cat-rail');
document.getElementById('rail-left')?.addEventListener('click', () => rail.scrollBy({ left: -200, behavior: 'smooth' }));
document.getElementById('rail-right')?.addEventListener('click', () => rail.scrollBy({ left: 200, behavior: 'smooth' }));

// Rail item clicks — sync with sidebar filter
document.querySelectorAll('.rail-item').forEach(btn => {
	btn.addEventListener('click', () => {
		document.querySelectorAll('.rail-item').forEach(b => b.classList.remove('rail-item--active'));
		btn.classList.add('rail-item--active');
		const cat = btn.dataset.railCat;
		activeCat = cat;
		activeSubcat = '';
		// sync sidebar
		document.querySelectorAll('[data-filter-cat]').forEach(b => b.classList.toggle('sidebar__item--active', b.dataset.filterCat === cat));
		applyFilters();
	});
});

// Tool categories subcategories map
const SUBCATS = {
	'ai-productivity': ['AI Assistant','AI Agent','AI Copilot','AI Search Engine','AI Email Assistant','AI Meeting Assistant','AI Note Taker','AI Resume Builder','AI Task Management','AI Scheduling','AI PDF','AI Report Generator'],
	'ai-writing': ['AI Writing Assistants','AI Summarizer','AI Text Generator','AI Blog Generator','AI Copywriting','AI Story Generator','AI Rewriter','AI Grammar Checker','AI Essay Writer','AI Email Writer','AI Script Writing','AI Paraphraser'],
	'ai-video': ['AI Video Generator','Text to Video','AI Video Editor','Image to Video','AI Short Video Generator','AI Animation Generator','AI Video Summarizer','AI Lip Sync Generator'],
	'ai-image': ['AI Image Generator','Text to Image','AI Photo Editor','AI Background Remover','AI Avatar Generator','AI Image Enhancer','AI Image Upscaler','AI Headshot Generator','AI Face Swap Generator','AI Product Photography'],
	'ai-art': ['AI Art Generator','AI Logo Generator','AI Illustration Generator','AI Anime Generator','AI 3D Model Generator','AI Cartoon Generator','AI Graphic Design','AI Drawing'],
	'ai-voice': ['AI Text-to-Speech','AI Speech-to-Text','AI Transcription','AI Voice Generator','AI Voice Cloning','AI Voice Over','AI Dubbing','AI Voice Changer'],
	'ai-music': ['AI Music Generator','AI Song Generator','AI Lyrics Generator','AI Sound Effect Generator','AI Vocal Remover','AI Beat Generator'],
	'ai-chatbot': ['AI Chatbot','AI Character','AI Roleplay','AI Dating Assistant'],
	'ai-vision': ['AI Image Recognition','AI OCR','AI Face Recognition','AI Face Analyzer','AI Describe Image','Image to Prompt'],
	'ai-marketing': ['AI Marketing','AI SEO Tools','AI Lead Generation','AI Sales Assistant','AI Ad Generator','AI Email Marketing'],
	'ai-coding': ['AI Code Generator','AI Code Assistant','AI Developer Tools','No-Code & Low-Code','AI App Builder','AI Website Builder','AI Code Review'],
	'ai-learning': ['AI Translate','AI Homework Helper','AI Language Learning','AI Quiz Generator','AI Flashcard Maker','AI Course','AI Coaching'],
	'ai-social': ['AI Social Media Post Generator','AI YouTube','AI Twitter','AI Instagram','AI Hashtag','AI Meme Generator','AI TikTok'],
	'ai-business': ['AI Customer Service','AI Workflow','AI Recruiting','AI CRM','AI Project Management','AI Call Center'],
	'ai-research': ['AI Research Tool','AI For Data Analytics','AI Predictions','AI Research Papers','AI Data Mining'],
	'ai-insights': ['AI Consulting','AI Business Ideas Generator','AI Crypto','AI Business Name Generator'],
	'ai-life': ['AI Travel','AI Trip Planner','AI Fitness','AI Recipe','AI Shopping Assistant','AI Outfit Generator'],
	'ai-health': ['AI Healthcare','AI Mental Health','AI Therapist','AI Medical Diagnosis','AI Symptom Checker'],
	'ai-legal': ['AI Legal Assistant','AI For Finance','AI Investing','AI Contract Review','AI Accounting','AI Tax Assistant'],
	'ai-design': ['AI Interior Design','AI Room Planner','AI Landscape Generator','AI Kitchen Design','AI Floor Plan Generator'],
	'ai-detection': ['AI Detector','AI Content Detector','AI Plagiarism Checker','Humanizer AI','AI Image Detector'],
	'others': ['Large Language Models','AI Models','Open Source AI','AI Games'],
};

const PAGE_SIZE = 24;
let page = 1;
let activeCat = 'all';
let activePrice = 'all';
let activeSubcat = '';
let searchQuery = '';
let sortMode = 'newest';

const grid = document.getElementById('tools-grid');
const cards = Array.from(grid.querySelectorAll('.tool-card'));
const label = document.getElementById('results-label');
const noResults = document.getElementById('no-results');
const subcatsEl = document.getElementById('subcats');
const searchInput = document.getElementById('tools-search');
const sortSelect = document.getElementById('sort-select');
const loadMoreWrap = document.getElementById('load-more-wrap');
const loadMoreBtn = document.getElementById('load-more-btn');

// Read URL params on load
const params = new URLSearchParams(window.location.search);
if (params.get('q')) { searchQuery = params.get('q'); searchInput.value = searchQuery; }
if (params.get('category')) activeCat = params.get('category');
if (params.get('pricing')) activePrice = params.get('pricing');

function applyFilters() {
	let visible = 0;
	const q = searchQuery.toLowerCase();

	// Sort cards
	const sorted = [...cards].sort((a, b) => {
		if (sortMode === 'name') return (a.dataset.name ?? '').localeCompare(b.dataset.name ?? '');
		if (sortMode === 'free') {
			const pa = a.dataset.pricing === 'free' ? 0 : a.dataset.pricing === 'freemium' ? 1 : 2;
			const pb = b.dataset.pricing === 'free' ? 0 : b.dataset.pricing === 'freemium' ? 1 : 2;
			return pa - pb;
		}
		return 0; // newest = DOM order (already sorted)
	});

	sorted.forEach(card => {
		grid.appendChild(card);
	});

	const matched = [];
	cards.forEach(card => {
		const cat = card.dataset.category ?? '';
		const price = card.dataset.pricing ?? '';
		const name = card.dataset.name ?? '';
		const subcat = card.dataset.subcat ?? '';
		const desc = card.dataset.desc ?? '';
		const tags = card.dataset.tags ?? '';

		const catMatch = activeCat === 'all' || cat === activeCat;
		const priceMatch = activePrice === 'all' || price === activePrice;
		const subcatMatch = !activeSubcat || subcat === activeSubcat;
		const searchMatch = !q || name.includes(q) || desc.includes(q) || tags.includes(q) || subcat.toLowerCase().includes(q);

		if (catMatch && priceMatch && subcatMatch && searchMatch) matched.push(card);
	});

	const limit = page * PAGE_SIZE;
	cards.forEach(card => { card.style.display = 'none'; });
	matched.slice(0, limit).forEach(card => { card.style.display = ''; visible++; });

	const remaining = matched.length - limit;
	if (remaining > 0) {
		loadMoreWrap.style.display = '';
		loadMoreBtn.textContent = `Load more (${remaining} remaining)`;
	} else {
		loadMoreWrap.style.display = 'none';
	}

	label.textContent = `Showing ${Math.min(limit, matched.length)} of ${matched.length} tool${matched.length !== 1 ? 's' : ''}${activeCat !== 'all' ? ` in ${activeCat.replace(/-/g, ' ')}` : ''}`;
	noResults.style.display = matched.length === 0 ? '' : 'none';

	// Subcategory chips
	if (activeCat !== 'all' && SUBCATS[activeCat]) {
		// Find which subcats have at least one card matching cat+price+search (ignoring subcat filter)
		const availableSubs = SUBCATS[activeCat].filter(s =>
			cards.some(card => {
				const cat = card.dataset.category ?? '';
				const price = card.dataset.pricing ?? '';
				const name = card.dataset.name ?? '';
				const subcat = card.dataset.subcat ?? '';
				const desc = card.dataset.desc ?? '';
				const tags = card.dataset.tags ?? '';
				const catMatch = activeCat === 'all' || cat === activeCat;
				const priceMatch = activePrice === 'all' || price === activePrice;
				const searchMatch = !q || name.includes(q) || desc.includes(q) || tags.includes(q) || subcat.toLowerCase().includes(q);
				return catMatch && priceMatch && searchMatch && subcat === s;
			})
		);
		if (availableSubs.length > 0) {
			subcatsEl.style.display = '';
			subcatsEl.innerHTML = `<button class="subcat-chip${!activeSubcat ? ' active' : ''}" data-sub="">All</button>` +
				availableSubs.map(s => `<button class="subcat-chip${activeSubcat === s ? ' active' : ''}" data-sub="${esc(s)}">${esc(s)}</button>`).join('');
		} else {
			subcatsEl.style.display = 'none';
			subcatsEl.innerHTML = '';
		}
	} else {
		subcatsEl.style.display = 'none';
		subcatsEl.innerHTML = '';
	}
}

// Sidebar category buttons
document.querySelectorAll('[data-filter-cat]').forEach(btn => {
	btn.addEventListener('click', () => {
		document.querySelectorAll('[data-filter-cat]').forEach(b => b.classList.remove('sidebar__item--active'));
		btn.classList.add('sidebar__item--active');
		activeCat = btn.dataset.filterCat;
		activeSubcat = '';
		page = 1;
		applyFilters();
	});
});

// Sidebar pricing buttons
document.querySelectorAll('[data-filter-price]').forEach(btn => {
	btn.addEventListener('click', () => {
		document.querySelectorAll('[data-filter-price]').forEach(b => b.classList.remove('sidebar__item--active'));
		btn.classList.add('sidebar__item--active');
		activePrice = btn.dataset.filterPrice;
		page = 1;
		applyFilters();
	});
});

// Subcategory chips (delegated)
subcatsEl.addEventListener('click', (e) => {
	const t = e.target.closest('.subcat-chip');
	if (!t) return;
	activeSubcat = t.dataset.sub ?? '';
	page = 1;
	applyFilters();
});

// Search (debounced)
let searchTimer;
searchInput.addEventListener('input', () => {
	clearTimeout(searchTimer);
	searchTimer = setTimeout(() => {
		searchQuery = searchInput.value;
		page = 1;
		applyFilters();
	}, 200);
});

// Sort
sortSelect.addEventListener('change', () => {
	sortMode = sortSelect.value;
	page = 1;
	applyFilters();
});

// Load more
loadMoreBtn.addEventListener('click', () => {
	page++;
	applyFilters();
});

// Clear
document.getElementById('clear-filters')?.addEventListener('click', () => {
	activeCat = 'all'; activePrice = 'all'; activeSubcat = ''; searchQuery = ''; page = 1;
	searchInput.value = '';
	document.querySelectorAll('[data-filter-cat]').forEach((b, i) => b.classList.toggle('sidebar__item--active', i === 0));
	document.querySelectorAll('[data-filter-price]').forEach((b, i) => b.classList.toggle('sidebar__item--active', i === 0));
	applyFilters();
});

// Run on load
applyFilters();

// Set active category from URL
if (activeCat !== 'all') {
	document.querySelectorAll('[data-filter-cat]').forEach(btn => {
		btn.classList.toggle('sidebar__item--active', btn.dataset.filterCat === activeCat);
	});
}
</script>

<style>
	.tools-main { padding: 2rem 0 3rem; }

	.tools-layout {
		display: grid;
		grid-template-columns: 1fr;
		gap: 2rem;
	}

	/* Sidebar */
	.sidebar {
		display: none;
	}

	.sidebar__section { margin-bottom: 1.5rem; }

	.sidebar__heading {
		font-size: 0.72rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: rgb(var(--gray));
		margin-bottom: 0.6rem;
	}

	.sidebar__list {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.sidebar__item {
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: 100%;
		padding: 0.42rem 0.65rem;
		background: none;
		border: none;
		border-radius: var(--radius);
		font-size: 0.84rem;
		color: rgb(var(--gray-dark));
		cursor: pointer;
		text-align: left;
		transition: background 0.15s, color 0.15s;
		font-family: inherit;
		gap: 0.5rem;
	}

	.sidebar__item:hover { background: var(--bg-alt); color: var(--primary); }
	.sidebar__item--active { background: var(--primary-light); color: var(--primary); font-weight: 700; }

	.sidebar__count {
		font-size: 0.7rem;
		background: var(--bg-alt);
		padding: 0.1rem 0.4rem;
		border-radius: 50px;
		color: rgb(var(--gray));
		flex-shrink: 0;
	}

	/* Toolbar */
	.toolbar {
		display: flex;
		gap: 0.75rem;
		margin-bottom: 1rem;
		align-items: center;
		flex-wrap: wrap;
	}

	.toolbar__search {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		flex: 1;
		min-width: 200px;
		background: #fff;
		border: 1px solid var(--border);
		border-radius: var(--radius);
		padding: 0 0.75rem;
	}

	.toolbar__search svg { color: rgb(var(--gray)); flex-shrink: 0; }

	.toolbar__search input {
		border: none;
		padding: 0.6rem 0;
		font-size: 0.9rem;
		background: transparent;
		outline: none;
		width: 100%;
	}

	.toolbar__sort select {
		padding: 0.6rem 0.75rem;
		border: 1px solid var(--border);
		border-radius: var(--radius);
		font-size: 0.85rem;
		background: #fff;
		cursor: pointer;
		outline: none;
		font-family: inherit;
	}

	/* Results label */
	.results-label {
		font-size: 0.82rem;
		color: rgb(var(--gray));
		margin-bottom: 0.75rem;
	}


	/* Tools grid */
	.tools-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1rem;
	}

	.load-more-wrap {
		text-align: center;
		padding: 1.5rem 0 0.5rem;
	}
	.load-more-btn {
		padding: 0.65rem 2rem;
		background: #fff;
		border: 2px solid var(--primary);
		border-radius: var(--radius);
		color: var(--primary);
		font-size: 0.9rem;
		font-weight: 700;
		cursor: pointer;
		font-family: inherit;
		transition: all 0.15s;
	}
	.load-more-btn:hover { background: var(--primary); color: #fff; }

	.no-results {
		text-align: center;
		color: rgb(var(--gray));
		padding: 3rem 0;
		font-size: 0.95rem;
	}

	.no-results button {
		color: var(--primary);
		background: none;
		border: none;
		cursor: pointer;
		font-weight: 700;
		font-size: 0.95rem;
		font-family: inherit;
	}

	/* Category Rail */
	.cat-rail-wrap {
		position: relative;
		background: var(--bg-alt);
		border-bottom: 1px solid var(--border);
		display: flex;
		align-items: center;
	}
	.cat-rail {
		display: flex;
		gap: 0.4rem;
		overflow-x: auto;
		scroll-behavior: smooth;
		padding: 0.6rem 0.5rem;
		scrollbar-width: none;
		flex: 1;
	}
	.cat-rail::-webkit-scrollbar { display: none; }
	.rail-item {
		display: flex;
		align-items: center;
		gap: 0.35rem;
		padding: 0.35rem 0.85rem;
		border: 1px solid var(--border);
		border-radius: 50px;
		background: #fff;
		font-size: 0.78rem;
		font-weight: 600;
		white-space: nowrap;
		cursor: pointer;
		font-family: inherit;
		color: rgb(var(--gray-dark));
		transition: all 0.15s;
		flex-shrink: 0;
	}
	.rail-item span { font-size: 0.65rem; color: rgb(var(--gray)); }
	.rail-item:hover, .rail-item--active {
		background: var(--primary);
		color: #fff;
		border-color: var(--primary);
	}
	.rail-item--active span, .rail-item:hover span { color: rgba(255,255,255,0.8); }
	.rail-arrow {
		background: #fff;
		border: 1px solid var(--border);
		width: 28px;
		height: 28px;
		border-radius: 50%;
		font-size: 1.1rem;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		margin: 0 0.35rem;
		line-height: 1;
		transition: all 0.15s;
	}
	.rail-arrow:hover { background: var(--primary); color: #fff; border-color: var(--primary); }

	@media (min-width: 640px) {
		.tools-grid { grid-template-columns: repeat(3, 1fr); }
	}

	@media (min-width: 768px) {
		.sidebar { display: block; }
		.tools-layout { grid-template-columns: 220px 1fr; }
		.tools-grid { grid-template-columns: repeat(2, 1fr); }
	}

	@media (min-width: 1024px) {
		.tools-layout { grid-template-columns: 240px 1fr; }
		.tools-grid { grid-template-columns: repeat(3, 1fr); }
	}

	@media (min-width: 1280px) {
		.tools-grid { grid-template-columns: repeat(4, 1fr); }
	}
</style>

<style is:global>
	/* Subcategory chips — global because they're created dynamically via JS */
	.subcats {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin-bottom: 1rem;
	}

	.subcat-chip {
		padding: 0.3rem 0.75rem;
		font-size: 0.75rem;
		font-weight: 600;
		border: 1px solid var(--border);
		border-radius: 50px;
		background: #fff;
		cursor: pointer;
		transition: all 0.15s;
		font-family: inherit;
		color: rgb(var(--gray-dark));
	}

	.subcat-chip:hover, .subcat-chip.active {
		background: var(--primary);
		color: #fff;
		border-color: var(--primary);
	}
</style>
