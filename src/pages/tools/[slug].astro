---
import { getCollection, render } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ToolCard from '../../components/ToolCard.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import { TOOL_CATEGORIES, PRICING_BADGE, SITE_TITLE, SITE_URL } from '../../consts';

export async function getStaticPaths() {
	const tools = await getCollection('tools');
	return tools.map(tool => ({
		params: { slug: tool.id },
		props: { tool },
	}));
}

const { tool } = Astro.props;
const { Content } = await render(tool);

const category = TOOL_CATEGORIES.find(c => c.slug === tool.data.category);
const pb = PRICING_BADGE[tool.data.pricing] ?? PRICING_BADGE.freemium;
const toolDomain = new URL(tool.data.url).hostname;
const toolFavicon = `https://www.google.com/s2/favicons?domain=${toolDomain}&sz=128`;
const visitUrl = tool.data.affiliateUrl ?? tool.data.url;
const isAffiliate = !!tool.data.affiliateUrl;

const allTools = await getCollection('tools');
const related = allTools
	.filter(t => t.id !== tool.id && t.data.category === tool.data.category)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 4);

const allPosts = await getCollection('blog');
const toolNameLower = tool.data.name.toLowerCase();
const toolTags = (tool.data.tags ?? []).map((t: string) => t.toLowerCase());
const relatedPosts = allPosts
	.filter(p => {
		const titleMatch = p.data.title.toLowerCase().includes(toolNameLower);
		const tagOverlap = (p.data.tags ?? []).some((t: string) => toolTags.includes(t.toLowerCase()));
		return titleMatch || tagOverlap;
	})
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

// SEO-optimised title and description
const year = (tool.data.updatedDate ?? tool.data.pubDate).getFullYear();
const seoTitle = `${tool.data.name} Review (${year}): Features, Pricing & Alternatives`;
const pricingLabel = pb.label; // Free / Freemium / Paid
const subcatLabel = tool.data.subcategory ?? category?.name ?? 'AI Tool';
const seoDescription = `${tool.data.name} is a ${pricingLabel.toLowerCase()} ${subcatLabel.toLowerCase()}. ${tool.data.description} See features, pricing, pros & cons.`;

// Rating helpers
const rating = tool.data.rating;
const ratingCount = tool.data.ratingCount ?? 500;
const fullStars = rating ? Math.floor(rating) : 0;
const halfStar = rating ? (rating % 1 >= 0.5) : false;
const emptyStars = rating ? 5 - fullStars - (halfStar ? 1 : 0) : 0;

// Structured data — SoftwareApplication
const offersMap: Record<string, { price: string; priceCurrency: string }> = {
	free:     { price: '0', priceCurrency: 'USD' },
	freemium: { price: '0', priceCurrency: 'USD' },
	paid:     { price: '9.99', priceCurrency: 'USD' },
};
const softwareSchema: Record<string, unknown> = {
	'@context': 'https://schema.org',
	'@type': 'SoftwareApplication',
	name: tool.data.name,
	description: tool.data.description,
	url: tool.data.url,
	applicationCategory: 'AIApplication',
	operatingSystem: 'Web',
	inLanguage: 'en-US',
	offers: {
		'@type': 'Offer',
		...offersMap[tool.data.pricing],
		availability: 'https://schema.org/OnlineOnly',
	},
	...(rating && {
		aggregateRating: {
			'@type': 'AggregateRating',
			ratingValue: rating.toFixed(1),
			ratingCount,
			bestRating: '5',
			worstRating: '1',
		},
	}),
};

// Structured data — BreadcrumbList
const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Home', item: SITE_URL },
		{ '@type': 'ListItem', position: 2, name: 'AI Tools', item: `${SITE_URL}/tools/` },
		...(category ? [{ '@type': 'ListItem', position: 3, name: category.name, item: `${SITE_URL}/tools/category/${category.slug}/` }] : []),
		{ '@type': 'ListItem', position: category ? 4 : 3, name: tool.data.name, item: `${SITE_URL}/tools/${tool.id}/` },
	],
};

// Date formatting
const lastUpdated = tool.data.updatedDate ?? tool.data.pubDate;
const formattedDate = lastUpdated.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<!doctype html>
<html lang="en">
<head>
	<BaseHead
		title={seoTitle}
		description={seoDescription}
		type="website"
		publishDate={tool.data.pubDate}
		updatedDate={tool.data.updatedDate}
	/>
	<!-- SoftwareApplication schema -->
	<script type="application/ld+json" set:html={JSON.stringify(softwareSchema)} />
	<!-- BreadcrumbList schema -->
	<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</head>
<body>
<Header />

<main>
	<!-- Breadcrumb -->
	<div class="breadcrumb-bar">
		<div class="container">
			<nav class="breadcrumbs" aria-label="Breadcrumb">
				<a href="/">Home</a><span>/</span>
				<a href="/tools/">AI Tools</a><span>/</span>
				{category && <><a href={`/tools/category/${category.slug}/`}>{category.name}</a><span>/</span></>}
				<span aria-current="page">{tool.data.name}</span>
			</nav>
		</div>
	</div>

	<!-- Tool Header -->
	<section class="tool-hero">
		<div class="container tool-hero__inner">
			<div class="tool-hero__logo" aria-hidden="true">
				<img
					src={toolFavicon}
					alt={`${tool.data.name} logo`}
					width="64"
					height="64"
					loading="eager"
					id="tool-hero-favicon"
				/>
				<span class="tool-hero__logo-fallback" id="tool-hero-fallback" style="display:none">{category?.emoji ?? '🤖'}</span>
			</div>
			<div class="tool-hero__info">
				<div class="tool-hero__meta">
					{category && (
						<a href={`/tools/category/${category.slug}/`} class="tool-hero__cat">
							{category.emoji} {category.name}
						</a>
					)}
					{tool.data.subcategory && (
						<span class="tool-hero__subcat">{tool.data.subcategory}</span>
					)}
					<span
						class="tool-hero__pricing"
						style={`background:${pb.bg};color:${pb.text}`}
					>{pb.label}</span>
				</div>
				<h1 class="tool-hero__name">{tool.data.name}</h1>
				<p class="tool-hero__desc">{tool.data.description}</p>

				{/* Rating stars */}
				{rating && (
					<div class="tool-hero__rating" aria-label={`Rated ${rating} out of 5`}>
						<div class="stars" aria-hidden="true">
							{Array.from({ length: fullStars }).map(() => <span class="star star--full">★</span>)}
							{halfStar && <span class="star star--half">★</span>}
							{Array.from({ length: emptyStars }).map(() => <span class="star star--empty">★</span>)}
						</div>
						<span class="rating-value">{rating.toFixed(1)}</span>
						<span class="rating-count">({ratingCount.toLocaleString()} reviews)</span>
					</div>
				)}

				{tool.data.tags.length > 0 && (
					<div class="tool-hero__tags">
						{tool.data.tags.map(tag => (
							<span class="tag">#{tag}</span>
						))}
					</div>
				)}

				<p class="tool-hero__updated">Last updated: <time datetime={lastUpdated.toISOString()}>{formattedDate}</time></p>
				<ShareButtons url={`${SITE_URL}/tools/${tool.id}/`} title={`${tool.data.name} — ${SITE_TITLE}`} />
			</div>
			<div class="tool-hero__actions">
				<a
					href={visitUrl}
					target="_blank"
					rel={`noopener noreferrer${isAffiliate ? ' sponsored' : ''}`}
					class="btn btn--primary tool-hero__visit"
					data-track="visit"
				>
					Visit {tool.data.name}
					<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
				</a>
				<a href="/tools/" class="btn btn--outline">← Back to Directory</a>
			</div>
		</div>
	</section>

	<!-- Content + Sidebar -->
	<section class="tool-content">
		<div class="container tool-content__inner">
			<div class="tool-body prose">
				<Content />
			</div>

			<aside class="tool-sidebar">
				<!-- Tool Info card -->
				<div class="tool-sidebar__card">
					<h3>Tool Info</h3>
					<dl class="tool-info">
						<div>
							<dt>Category</dt>
							<dd>{category?.name ?? tool.data.category}</dd>
						</div>
						{tool.data.subcategory && (
							<div>
								<dt>Type</dt>
								<dd>{tool.data.subcategory}</dd>
							</div>
						)}
						<div>
							<dt>Pricing</dt>
							<dd>
								<span style={`background:${pb.bg};color:${pb.text};padding:0.15rem 0.5rem;border-radius:50px;font-size:0.8rem;font-weight:700`}>
									{pb.label}
								</span>
							</dd>
						</div>
						{rating && (
							<div>
								<dt>Rating</dt>
								<dd>{rating.toFixed(1)} / 5</dd>
							</div>
						)}
					</dl>
					<a
						href={visitUrl}
						target="_blank"
						rel={`noopener noreferrer${isAffiliate ? ' sponsored' : ''}`}
						data-track="visit"
						class="btn btn--primary"
						style="width:100%;justify-content:center;margin-top:1rem"
					>
						Visit Website →
					</a>
					<a
						href={`/tools/alternatives/${tool.id}/`}
						class="btn btn--outline-sm"
						style="width:100%;justify-content:center;margin-top:0.5rem"
					>
						See Alternatives →
					</a>
					<a
						href={`/contact/?subject=claim&tool=${encodeURIComponent(tool.data.name)}`}
						class="tool-claim-link"
					>
						Are you the owner of this tool?
					</a>
				</div>

				{/* Pros & Cons */}
				{(tool.data.pros || tool.data.cons) && (
					<div class="tool-sidebar__card pros-cons">
						<h3>Pros &amp; Cons</h3>
						{tool.data.pros && tool.data.pros.length > 0 && (
							<div class="pros">
								<p class="pros-cons__label pros-cons__label--pro">Pros</p>
								<ul>
									{tool.data.pros.map(p => <li>{p}</li>)}
								</ul>
							</div>
						)}
						{tool.data.cons && tool.data.cons.length > 0 && (
							<div class="cons">
								<p class="pros-cons__label pros-cons__label--con">Cons</p>
								<ul>
									{tool.data.cons.map(c => <li>{c}</li>)}
								</ul>
							</div>
						)}
					</div>
				)}
			</aside>
		</div>
	</section>

	<!-- Related Tools -->
	{related.length > 0 && (
		<section class="section section--alt">
			<div class="container">
				<h2 class="section-heading" style="margin-bottom:1.25rem">More {category?.name ?? 'AI'} Tools</h2>
				<div class="related-grid">
					{related.map(t => (
						<ToolCard
							name={t.data.name}
							description={t.data.description}
							category={t.data.category}
							subcategory={t.data.subcategory}
							pricing={t.data.pricing}
							url={t.data.url}
							slug={t.id}
							tags={t.data.tags}
							sponsored={t.data.sponsored}
							verified={t.data.verified}
						/>
					))}
				</div>
			</div>
		</section>
	)}

	<!-- Related Articles -->
	{relatedPosts.length > 0 && (
		<section class="section">
			<div class="container">
				<h2 class="section-heading" style="margin-bottom:1.25rem">Related Articles</h2>
				<div class="related-articles">
					{relatedPosts.map(p => (
						<a href={`/blog/${p.id}/`} class="ra-card">
							<span class="ra-badge">📝 {p.data.category.replace(/-/g, ' ')}</span>
							<h3 class="ra-title">{p.data.title}</h3>
							<p class="ra-desc">{p.data.description}</p>
						</a>
					))}
				</div>
			</div>
		</section>
	)}
</main>

<Footer />
</body>
</html>

<style>
	.breadcrumb-bar {
		background: var(--bg-alt);
		border-bottom: 1px solid var(--border);
		padding: 0.75rem 0;
	}

	.breadcrumbs {
		font-size: 0.82rem;
		color: rgb(var(--gray));
		display: flex;
		align-items: center;
		gap: 0.35rem;
		flex-wrap: wrap;
	}

	.breadcrumbs a { color: rgb(var(--gray)); transition: color 0.15s; }
	.breadcrumbs a:hover { color: var(--primary); }
	.breadcrumbs span[aria-current] { color: rgb(var(--gray-dark)); font-weight: 600; }

	/* Tool Hero */
	.tool-hero {
		padding: 2.5rem 0 2rem;
		border-bottom: 1px solid var(--border);
	}

	.tool-hero__inner {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.tool-hero__logo {
		width: 72px;
		height: 72px;
		background: var(--primary-light);
		border-radius: 16px;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 2.2rem;
		flex-shrink: 0;
		overflow: hidden;
	}

	.tool-hero__logo img { width: 100%; height: 100%; object-fit: contain; border-radius: 16px; }
	.tool-hero__logo-fallback { font-size: 2rem; display: flex; align-items: center; justify-content: center; width: 100%; height: 100%; }

	.tool-hero__meta {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		flex-wrap: wrap;
		margin-bottom: 0.5rem;
	}

	.tool-hero__cat {
		font-size: 0.78rem;
		font-weight: 700;
		color: var(--primary);
		background: var(--primary-light);
		padding: 0.2rem 0.6rem;
		border-radius: 50px;
		text-decoration: none;
	}

	.tool-hero__subcat {
		font-size: 0.75rem;
		color: rgb(var(--gray));
		background: var(--bg-alt);
		padding: 0.2rem 0.6rem;
		border-radius: 50px;
	}

	.tool-hero__pricing {
		font-size: 0.72rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		padding: 0.2rem 0.6rem;
		border-radius: 50px;
	}

	.tool-hero__name {
		font-size: 2rem;
		margin: 0 0 0.5rem;
	}

	.tool-hero__desc {
		font-size: 1.05rem;
		color: rgb(var(--gray));
		margin: 0 0 0.75rem;
		line-height: 1.6;
	}

	/* Rating */
	.tool-hero__rating {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		margin-bottom: 0.75rem;
	}

	.stars { display: flex; gap: 1px; }

	.star { font-size: 1.1rem; }
	.star--full { color: #f59e0b; }
	.star--half { color: #f59e0b; opacity: 0.6; }
	.star--empty { color: #d1d5db; }

	.rating-value { font-weight: 700; font-size: 0.95rem; color: rgb(var(--black)); }
	.rating-count { font-size: 0.82rem; color: rgb(var(--gray)); }

	.tool-hero__tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin-bottom: 0.5rem;
	}

	.tag {
		font-size: 0.75rem;
		color: rgb(var(--gray));
		background: var(--bg-alt);
		border: 1px solid var(--border);
		padding: 0.18rem 0.55rem;
		border-radius: 50px;
	}

	.tool-hero__updated {
		font-size: 0.78rem;
		color: rgb(var(--gray));
		margin: 0;
	}

	.tool-hero__actions {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
	}

	.tool-hero__visit {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
	}

	/* Content */
	.tool-content { padding: 2.5rem 0 3rem; }

	.tool-content__inner {
		display: grid;
		grid-template-columns: 1fr;
		gap: 2rem;
	}

	.tool-body { max-width: 100%; }

	.prose h2 { font-size: 1.3rem; margin: 1.75rem 0 0.75rem; }
	.prose h3 { font-size: 1.1rem; margin: 1.5rem 0 0.5rem; }
	.prose p { color: rgb(var(--gray-dark)); line-height: 1.75; }
	.prose ul { padding-left: 1.25rem; }
	.prose li { margin-bottom: 0.35rem; color: rgb(var(--gray-dark)); }

	/* Sidebar */
	.tool-sidebar {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.tool-sidebar__card {
		background: var(--bg-alt);
		border: 1px solid var(--border);
		border-radius: var(--radius);
		padding: 1.25rem;
		position: sticky;
		top: 80px;
	}

	.tool-sidebar__card h3 {
		font-size: 1rem;
		margin-bottom: 1rem;
	}

	.tool-info {
		display: flex;
		flex-direction: column;
		gap: 0.65rem;
	}

	.tool-info div {
		display: flex;
		justify-content: space-between;
		align-items: center;
		font-size: 0.88rem;
	}

	.tool-info dt { color: rgb(var(--gray)); }
	.tool-info dd { font-weight: 600; color: rgb(var(--black)); margin: 0; }

	/* Pros & Cons */
	.pros-cons { position: static !important; }

	.pros-cons__label {
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: 0.5rem !important;
	}

	.pros-cons__label--pro { color: #00875A; }
	.pros-cons__label--con { color: #C0392B; }

	.pros ul, .cons ul {
		margin: 0 0 0.75rem;
		padding-left: 1.1rem;
	}

	.pros li, .cons li {
		font-size: 0.87rem;
		margin-bottom: 0.3rem;
		color: rgb(var(--gray-dark));
	}

	.pros li::marker { color: #00875A; }
	.cons li::marker { color: #C0392B; }

	/* Related */
	.section { padding: 3rem 0; }
	.section--alt { background: var(--bg-alt); padding: 3rem 0; }
	.section-heading { font-size: 1.35rem; }

	.related-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1rem;
	}

	@media (min-width: 640px) {
		.related-grid { grid-template-columns: repeat(3, 1fr); }
	}

	@media (min-width: 768px) {
		.tool-hero__inner { flex-direction: row; align-items: flex-start; }
		.tool-hero__info { flex: 1; }
		.tool-hero__actions { flex-direction: column; align-items: flex-start; }
		.tool-content__inner { grid-template-columns: 1fr 280px; }
		.related-grid { grid-template-columns: repeat(4, 1fr); }
	}

	/* Claim link */
	.tool-claim-link {
		display: block; text-align: center; margin-top: 0.75rem;
		font-size: 0.75rem; color: rgb(var(--gray)); text-decoration: underline;
	}
	.tool-claim-link:hover { color: var(--primary); }

	/* Related Articles */
	.related-articles {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1rem;
	}
	@media (min-width: 640px) { .related-articles { grid-template-columns: repeat(2, 1fr); } }
	@media (min-width: 960px) { .related-articles { grid-template-columns: repeat(3, 1fr); } }
	.ra-card {
		display: flex; flex-direction: column; gap: 0.4rem;
		padding: 1.25rem;
		border: 1px solid var(--border);
		border-radius: var(--radius);
		background: var(--bg);
		transition: border-color 0.2s, box-shadow 0.2s;
		color: inherit;
	}
	.ra-card:hover { border-color: var(--primary); box-shadow: 0 2px 12px rgba(0,135,90,0.1); }
	.ra-badge { font-size: 0.7rem; text-transform: capitalize; color: var(--primary); font-weight: 600; }
	.ra-title { font-size: 0.95rem; font-weight: 700; color: rgb(var(--black)); margin: 0; line-height: 1.35; }
	.ra-desc { font-size: 0.82rem; color: rgb(var(--gray)); line-height: 1.5; margin: 0; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
</style>

<script data-astro-rerun>
const favicon = document.getElementById('tool-hero-favicon');
if (favicon) {
	favicon.addEventListener('error', () => {
		favicon.style.display = 'none';
		const fb = document.getElementById('tool-hero-fallback');
		if (fb) fb.style.display = 'flex';
	}, { once: true });
}

// Track outbound visit clicks via GA4
document.querySelectorAll('[data-track="visit"]').forEach(link => {
	link.addEventListener('click', () => {
		if (typeof gtag === 'function') {
			gtag('event', 'outbound_click', { url: link.href });
		}
	});
});
</script>
