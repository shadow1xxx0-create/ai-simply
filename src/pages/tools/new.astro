---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { TOOL_CATEGORIES, PRICING_BADGE, SITE_TITLE } from '../../consts';

const tools = (await getCollection('tools'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 60);

function timeAgo(date: Date) {
	const days = Math.floor((Date.now() - date.valueOf()) / 86400000);
	if (days === 0) return 'Today';
	if (days === 1) return 'Yesterday';
	if (days < 7) return `${days} days ago`;
	if (days < 30) return `${Math.floor(days / 7)}w ago`;
	return `${Math.floor(days / 30)}mo ago`;
}
---

<!doctype html>
<html lang="en">
<head>
	<BaseHead
		title={`New AI Tools (2026) — Latest Additions | ${SITE_TITLE}`}
		description="Discover the newest AI tools added to our directory. Updated daily with the latest AI apps, generators, and productivity tools."
	/>
</head>
<body>
<Header />

<div class="page-header">
	<div class="container">
		<div class="header-badge">Updated Daily</div>
		<h1>New AI Tools</h1>
		<p>The latest AI tools added to our directory — sorted by newest first.</p>
	</div>
</div>

<main class="container new-body">
	<div class="tools-grid">
		{tools.map(tool => {
			const cat = TOOL_CATEGORIES.find(c => c.slug === tool.data.category);
			const domain = new URL(tool.data.url).hostname;
			const favicon = `https://www.google.com/s2/favicons?domain=${domain}&sz=64`;
			const badge = PRICING_BADGE[tool.data.pricing];
			const ago = timeAgo(tool.data.pubDate);
			return (
				<a href={`/tools/${tool.id}/`} class="tool-card">
					<div class="tool-card__top">
						<div class="tool-logo">
							<img src={favicon} alt={tool.data.name} width="36" height="36" loading="lazy"
								onerror={`this.style.display='none';this.nextElementSibling.style.display='flex'`} />
							<span class="tool-logo-fb" style="display:none">{cat?.emoji ?? '🤖'}</span>
						</div>
						<div class="tool-meta">
							<h3>{tool.data.name}</h3>
							<span class="cat-tag">{cat?.emoji} {cat?.name}</span>
						</div>
						<span class="pricing-pill" style={`background:${badge.bg};color:${badge.text}`}>{badge.label}</span>
					</div>
					<p class="tool-desc">{tool.data.description}</p>
					<div class="tool-footer">
						<span class="added-date">Added {ago}</span>
						{tool.data.rating && <span class="tool-rating">★ {tool.data.rating.toFixed(1)}</span>}
					</div>
				</a>
			);
		})}
	</div>
</main>

<Footer />
</body>
</html>

<style>
.page-header {
	background: linear-gradient(135deg, var(--primary-light) 0%, var(--bg) 100%);
	border-bottom: 1px solid var(--border);
	padding: 3rem 0 2rem;
	text-align: center;
}
.header-badge {
	display: inline-block;
	background: var(--primary);
	color: #fff;
	font-size: 0.7rem;
	font-weight: 700;
	letter-spacing: 0.08em;
	text-transform: uppercase;
	padding: 0.25rem 0.75rem;
	border-radius: 99px;
	margin-bottom: 0.75rem;
}
.page-header h1 { font-size: clamp(1.8rem, 4vw, 2.6rem); margin-bottom: 0.5rem; }
.page-header p { color: rgb(var(--gray)); max-width: 480px; margin: 0 auto; }

.new-body { padding: 2.5rem 0 4rem; }

.tools-grid {
	display: grid;
	grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
	gap: 1.1rem;
}

.tool-card {
	display: flex;
	flex-direction: column;
	gap: 0.6rem;
	padding: 1.1rem;
	background: var(--bg);
	border: 1px solid var(--border);
	border-radius: var(--radius);
	color: inherit;
	transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
}
.tool-card:hover {
	transform: translateY(-2px);
	border-color: rgba(0,200,150,0.35);
	box-shadow: 0 4px 16px rgba(0,200,150,0.1);
}

.tool-card__top {
	display: flex;
	align-items: center;
	gap: 0.7rem;
}

.tool-logo {
	width: 44px; height: 44px;
	background: var(--primary-light);
	border-radius: var(--radius);
	display: flex; align-items: center; justify-content: center;
	flex-shrink: 0; overflow: hidden;
}
.tool-logo img { width: 32px; height: 32px; object-fit: contain; }
.tool-logo-fb { font-size: 1.4rem; display: flex; align-items: center; justify-content: center; }

.tool-meta { flex: 1; min-width: 0; }
.tool-meta h3 { font-size: 0.95rem; margin: 0 0 0.2rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.tool-card:hover h3 { color: var(--primary); }
.cat-tag { font-size: 0.72rem; color: rgb(var(--gray)); }

.pricing-pill {
	font-size: 0.68rem; font-weight: 700;
	padding: 0.2rem 0.5rem;
	border-radius: 99px;
	flex-shrink: 0;
}

.tool-desc {
	font-size: 0.83rem;
	color: rgb(var(--gray));
	margin: 0;
	display: -webkit-box;
	-webkit-line-clamp: 2;
	-webkit-box-orient: vertical;
	overflow: hidden;
	line-height: 1.5;
}

.tool-footer {
	display: flex;
	align-items: center;
	justify-content: space-between;
	margin-top: auto;
}
.added-date { font-size: 0.75rem; color: rgb(var(--gray)); }
.tool-rating { font-size: 0.78rem; font-weight: 700; color: #f59e0b; }
</style>
