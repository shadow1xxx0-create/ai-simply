---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Newsletter from '../components/Newsletter.astro';
import { SITE_TITLE, SITE_URL, SITE_AUTHOR } from '../consts';

type Props = CollectionEntry<'blog'>['data'] & { body?: string };

const { title, description, pubDate, updatedDate, heroImage, category, readingTime, tags, faqs, body } = Astro.props;

function countWords(text: string): number {
	return text
		.replace(/```[\s\S]*?```/g, '')
		.replace(/`[^`]+`/g, '')
		.replace(/\[([^\]]*)\]\([^)]*\)/g, '$1')
		.replace(/[#*_~>|]/g, '')
		.trim()
		.split(/\s+/)
		.filter(w => w.length > 0).length;
}

const wordCount = body ? countWords(body) : undefined;
const categoryLabel = category?.replace(/-/g, ' ');

const articleSchema = {
	"@context": "https://schema.org",
	"@type": "BlogPosting",
	"headline": title,
	"description": description,
	"datePublished": pubDate.toISOString(),
	...(updatedDate && { "dateModified": updatedDate.toISOString() }),
	...(wordCount && { "wordCount": wordCount }),
	...(categoryLabel && { "articleSection": categoryLabel }),
	"author": {
		"@type": "Organization",
		"name": SITE_AUTHOR,
		"url": SITE_URL,
	},
	"publisher": {
		"@type": "Organization",
		"name": SITE_TITLE,
		"url": SITE_URL,
	},
	"mainEntityOfPage": {
		"@type": "WebPage",
		"@id": Astro.url.href,
	},
	...(heroImage && { "image": {
		"@type": "ImageObject",
		"url": new URL(heroImage.src, Astro.url).href,
		"contentUrl": new URL(heroImage.src, Astro.url).href,
		"width": heroImage.width,
		"height": heroImage.height,
		"name": title,
		"description": description,
	}}),
};

const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": [
		{ "@type": "ListItem", "position": 1, "name": "Home", "item": SITE_URL },
		{ "@type": "ListItem", "position": 2, "name": "Articles", "item": `${SITE_URL}/blog/` },
		{ "@type": "ListItem", "position": 3, "name": title, "item": Astro.url.href },
	],
};

const faqSchema = faqs && faqs.length > 0 ? {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	"mainEntity": faqs.map(faq => ({
		"@type": "Question",
		"name": faq.question,
		"acceptedAnswer": {
			"@type": "Answer",
			"text": faq.answer,
		},
	})),
} : null;
---

<!doctype html>
<html lang="en">
<head>
	<BaseHead
		title={title}
		description={description}
		image={heroImage}
		type="article"
		publishDate={pubDate}
		updatedDate={updatedDate}
		category={category}
	/>
	<script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
	<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
	{faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
</head>
<body>
	<Header />
	<main>
		<article itemscope itemtype="https://schema.org/Article">
			<header class="article-header">
				<div class="container">
					<nav class="breadcrumbs" aria-label="Breadcrumb">
						<a href="/">Home</a>
						<span aria-hidden="true">/</span>
						<a href="/blog/">Articles</a>
						<span aria-hidden="true">/</span>
						<span>{title}</span>
					</nav>
					{categoryLabel && <a href={`/blog/category/${category}/`} class="badge">{categoryLabel}</a>}
					<h1 itemprop="headline">{title}</h1>
					<p class="article-header__desc" itemprop="description">{description}</p>
					<div class="article-header__meta">
						<time datetime={pubDate.toISOString()} itemprop="datePublished">
							{pubDate.toLocaleDateString('en-us', { year: 'numeric', month: 'short', day: 'numeric' })}
						</time>
						{updatedDate && (
							<span class="article-header__updated">
								Updated: <time datetime={updatedDate.toISOString()} itemprop="dateModified">
									{updatedDate.toLocaleDateString('en-us', { year: 'numeric', month: 'short', day: 'numeric' })}
								</time>
							</span>
						)}
						{readingTime && <span>{readingTime}</span>}
					</div>
				</div>
			</header>

			{heroImage && (
				<div class="article-hero container">
					<Image
						width={960}
						height={480}
						src={heroImage}
						alt={title}
						loading="eager"
						itemprop="image"
					/>
				</div>
			)}

			<div class="article-body container" itemprop="articleBody">
				<slot />
			</div>

			<!-- FAQ Section -->
			{faqs && faqs.length > 0 && (
				<div class="faq-wrapper container">
					<section class="faq-section">
						<h2>Frequently Asked Questions</h2>
						{faqs.map(faq => (
							<div class="faq-item">
								<h3>{faq.question}</h3>
								<p>{faq.answer}</p>
							</div>
						))}
					</section>
				</div>
			)}

			{tags && tags.length > 0 && (
				<div class="article-tags container">
					<strong>Tags:</strong>
					{tags.map((tag) => (
						<span class="tag">{tag}</span>
					))}
				</div>
			)}
		</article>

		<!-- Bottom newsletter CTA -->
		<Newsletter
			heading="Found this useful? Get more every week."
			text="AI news, breakthroughs, and tools — no jargon, no hype. Free."
		/>
	</main>
	<Footer />
</body>
</html>

<style>
	.article-header {
		padding: 2.5rem 0 2rem;
		background: var(--bg-alt);
		border-bottom: 1px solid var(--border);
	}

	.breadcrumbs {
		font-size: 0.85rem;
		color: rgb(var(--gray));
		margin-bottom: 1rem;
	}

	.breadcrumbs a { color: rgb(var(--gray)); }
	.breadcrumbs a:hover { color: var(--primary); }
	.breadcrumbs span { margin: 0 0.35rem; }

	.article-header h1 {
		font-size: 2.2rem;
		max-width: 750px;
		margin: 0.75rem 0 0.5rem;
		line-height: 1.2;
	}

	.article-header__desc {
		color: rgb(var(--gray));
		font-size: 1.05rem;
		max-width: 650px;
		margin-bottom: 1rem;
	}

	.article-header__meta {
		font-size: 0.85rem;
		color: rgb(var(--gray));
		display: flex;
		gap: 1.25rem;
		flex-wrap: wrap;
	}

	.article-header__updated {
		font-style: italic;
	}

	.article-hero {
		margin-top: 2rem;
	}

	.article-hero img {
		width: 100%;
		max-width: 960px;
		border-radius: var(--radius);
	}

	.article-body {
		max-width: 750px;
		padding-top: 2rem;
		padding-bottom: 2rem;
	}

	.article-body :global(h2) {
		margin-top: 2.5rem;
		padding-top: 1.5rem;
		border-top: 1px solid var(--border);
	}

	.article-body :global(h3) {
		margin-top: 1.5rem;
	}

	.article-body :global(p) {
		margin-bottom: 1.25em;
	}

	.faq-wrapper {
		max-width: 750px;
		padding-bottom: 1rem;
	}

	.article-tags {
		max-width: 750px;
		padding-bottom: 2rem;
		display: flex;
		align-items: center;
		gap: 0.5rem;
		flex-wrap: wrap;
		font-size: 0.85rem;
	}

	.tag {
		background: var(--bg-alt);
		border: 1px solid var(--border);
		padding: 0.2rem 0.6rem;
		border-radius: 50px;
		font-size: 0.8rem;
		color: rgb(var(--gray));
	}

	.mid-article-nl {
		background: var(--bg-alt);
		border: 1px solid var(--border);
		border-radius: var(--radius);
		padding: 2rem 1.5rem;
		margin: 2.5rem 0;
		text-align: center;
	}

	.mid-article-nl h3 {
		color: rgb(var(--black));
		margin-bottom: 0.5rem;
		font-size: 1.2rem;
	}

	.mid-article-nl p {
		font-size: 0.95rem;
		color: rgb(var(--gray));
		margin-bottom: 1rem;
	}

	@media (min-width: 768px) {
		.article-header h1 { font-size: 2.6rem; }
	}
</style>

<script>
	document.addEventListener('DOMContentLoaded', () => {
		const body = document.querySelector('.article-body');
		if (!body) return;

		const headings = body.querySelectorAll('h2');
		if (headings.length === 0) return;

		const midIndex = Math.floor(headings.length / 2);
		const midHeading = headings[midIndex];

		const nl = document.createElement('aside');
		nl.className = 'mid-article-nl';
		nl.setAttribute('aria-label', 'Newsletter signup');
		nl.innerHTML = `
			<h3>Enjoying this article?</h3>
			<p>Get AI news in plain English — free, every week.</p>
			<iframe
				src="https://subscribe-forms.beehiiv.com/fda3e0ad-bcc8-4e4d-8f5b-123db9391be9"
				class="beehiiv-embed"
				data-test-id="beehiiv-embed"
				frameborder="0"
				scrolling="no"
				style="width:100%;max-width:100%;height:260px;margin:0;border-radius:6px!important;background-color:transparent;box-shadow:0 0 #0000;"
			></iframe>
		`;

		midHeading.parentNode.insertBefore(nl, midHeading);
	});
</script>
