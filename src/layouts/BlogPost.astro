---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Newsletter from '../components/Newsletter.astro';
import ShareButtons from '../components/ShareButtons.astro';
import { SITE_TITLE, SITE_URL, DEFAULT_AUTHOR } from '../consts';

const authorSameAs = [
	DEFAULT_AUTHOR.twitter && `https://twitter.com/${DEFAULT_AUTHOR.twitter}`,
].filter(Boolean);

type Props = CollectionEntry<'blog'>['data'] & { body?: string };

const {
	title, description, pubDate, updatedDate, heroImage, category, readingTime, tags, faqs, body,
	author, authorBio, authorTwitter, authorAvatar,
} = Astro.props;

const authorName = author ?? DEFAULT_AUTHOR.name;
const authorBioText = authorBio ?? DEFAULT_AUTHOR.bio;
const authorAvatarSrc = authorAvatar ?? DEFAULT_AUTHOR.avatar;
const authorTwitterHandle = authorTwitter ?? DEFAULT_AUTHOR.twitter;
const authorPageUrl = `${SITE_URL}/author/${DEFAULT_AUTHOR.slug}/`;
const authorInitials = authorName.split(' ').map(p => p[0]).join('').slice(0, 2).toUpperCase();

function countWords(text: string): number {
	return text
		.replace(/```[\s\S]*?```/g, '')
		.replace(/`[^`]+`/g, '')
		.replace(/\[([^\]]*)\]\([^)]*\)/g, '$1')
		.replace(/[#*_~>|]/g, '')
		.trim()
		.split(/\s+/)
		.filter(w => w.length > 0).length;
}

const wordCount = body ? countWords(body) : undefined;
const categoryLabel = category?.replace(/-/g, ' ');

const articleSchema = {
	"@context": "https://schema.org",
	"@type": "BlogPosting",
	"headline": title,
	"description": description,
	"inLanguage": "en-US",
	"datePublished": pubDate.toISOString(),
	...(updatedDate && { "dateModified": updatedDate.toISOString() }),
	...(wordCount && { "wordCount": wordCount }),
	...(categoryLabel && { "articleSection": categoryLabel }),
	...(tags && tags.length > 0 && { "keywords": tags.join(", ") }),
	"author": {
		"@type": "Organization",
		"name": authorName,
		"url": authorPageUrl,
		"logo": `${SITE_URL}${authorAvatarSrc}`,
		...(authorSameAs.length && { "sameAs": authorSameAs }),
	},
	"publisher": {
		"@type": "Organization",
		"name": SITE_TITLE,
		"url": SITE_URL,
	},
	"mainEntityOfPage": {
		"@type": "WebPage",
		"@id": Astro.url.href,
	},
	...(heroImage && { "image": {
		"@type": "ImageObject",
		"url": new URL(heroImage.src, Astro.url).href,
		"contentUrl": new URL(heroImage.src, Astro.url).href,
		"width": heroImage.width,
		"height": heroImage.height,
		"name": title,
		"description": description,
	}}),
};

const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": [
		{ "@type": "ListItem", "position": 1, "name": "Home", "item": SITE_URL },
		{ "@type": "ListItem", "position": 2, "name": "Articles", "item": `${SITE_URL}/blog/` },
		{ "@type": "ListItem", "position": 3, "name": title, "item": Astro.url.href },
	],
};

const faqSchema = faqs && faqs.length > 0 ? {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	"mainEntity": faqs.map(faq => ({
		"@type": "Question",
		"name": faq.question,
		"acceptedAnswer": {
			"@type": "Answer",
			"text": faq.answer,
		},
	})),
} : null;
---

<!doctype html>
<html lang="en">
<head>
	<BaseHead
		title={title}
		description={description}
		image={heroImage}
		type="article"
		publishDate={pubDate}
		updatedDate={updatedDate}
		category={category}
	/>
	<script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
	<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
	{faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
</head>
<body>
	<Header />
	<div class="reading-progress" id="reading-progress"></div>
	<main id="main-content">
		<article itemscope itemtype="https://schema.org/Article">
			<header class="article-header">
				<div class="container">
					<nav class="breadcrumbs" aria-label="Breadcrumb">
						<a href="/">Home</a>
						<span aria-hidden="true">/</span>
						<a href="/blog/">Articles</a>
						<span aria-hidden="true">/</span>
						<span>{title}</span>
					</nav>
					{categoryLabel && <a href={`/blog/category/${category}/`} class="badge">{categoryLabel}</a>}
					<h1 itemprop="headline">{title}</h1>
					<p class="article-header__desc" itemprop="description">{description}</p>
					<div class="article-header__meta">
						<a href={`/author/${DEFAULT_AUTHOR.slug}/`} class="article-byline" rel="author" itemprop="author" itemscope itemtype="https://schema.org/Organization">
							<img src={authorAvatarSrc} alt={authorName} width="26" height="26" class="article-byline__avatar" itemprop="logo" />
							<span class="article-byline__by">By <span itemprop="name">{authorName}</span></span>
						</a>
						<time datetime={pubDate.toISOString()} itemprop="datePublished">
							{pubDate.toLocaleDateString('en-us', { year: 'numeric', month: 'short', day: 'numeric' })}
						</time>
						{updatedDate && (
							<span class="article-header__updated">
								Updated: <time datetime={updatedDate.toISOString()} itemprop="dateModified">
									{updatedDate.toLocaleDateString('en-us', { year: 'numeric', month: 'short', day: 'numeric' })}
								</time>
							</span>
						)}
						{readingTime && <span>{readingTime}</span>}
					</div>
					<ShareButtons url={`${SITE_URL}${Astro.url.pathname}`} title={`${title} — ${SITE_TITLE}`} />
				</div>
			</header>

			{heroImage && (
				<div class="article-hero container">
					<Image
						width={960}
						height={480}
						src={heroImage}
						alt={title}
						loading="eager"
						itemprop="image"
					/>
				</div>
			)}

			<div class="article-body container" itemprop="articleBody">
				<slot />
			</div>

			<!-- FAQ Section -->
			{faqs && faqs.length > 0 && (
				<div class="faq-wrapper container">
					<section class="faq-section">
						<h2>Frequently Asked Questions</h2>
						{faqs.map(faq => (
							<div class="faq-item">
								<h3>{faq.question}</h3>
								<p>{faq.answer}</p>
							</div>
						))}
					</section>
				</div>
			)}

			{tags && tags.length > 0 && (
				<div class="article-tags container">
					<strong>Tags:</strong>
					{tags.map((tag) => (
						<span class="tag">{tag}</span>
					))}
				</div>
			)}
		</article>

		<!-- Author bio -->
		<div class="author-bio container">
			<div class="author-bio__inner" itemscope itemtype="https://schema.org/Organization">
				<img src={authorAvatarSrc} alt={authorName} width="48" height="48" class="author-bio__avatar" itemprop="logo" />
				<div class="author-bio__content">
					<p class="author-bio__name">
						Written by <a href={`/author/${DEFAULT_AUTHOR.slug}/`} itemprop="url"><span itemprop="name">{authorName}</span></a>
						<span class="author-bio__role">— {DEFAULT_AUTHOR.role}</span>
					</p>
					<p class="author-bio__desc" itemprop="description">{authorBioText}</p>
					{authorTwitterHandle && (
						<p class="author-bio__social">
							<a href={`https://twitter.com/${authorTwitterHandle}`} target="_blank" rel="noopener me" itemprop="sameAs">@{authorTwitterHandle}</a>
						</p>
					)}
				</div>
			</div>
		</div>

		<!-- Bottom newsletter CTA -->
		<Newsletter
			heading="Found this useful? Get more in my newsletter."
			text="The stories worth your time. Stay ahead without the noise."
		/>
	</main>
	<Footer />
</body>
</html>

<style>
	.article-header {
		padding: 2.5rem 0 2rem;
		background: var(--bg-alt);
		border-bottom: 1px solid var(--border);
	}

	.breadcrumbs {
		font-size: 0.85rem;
		color: rgb(var(--gray));
		margin-bottom: 1rem;
	}

	.breadcrumbs a { color: rgb(var(--gray)); }
	.breadcrumbs a:hover { color: var(--primary); }
	.breadcrumbs span { margin: 0 0.35rem; }

	.article-header h1 {
		font-size: 2.2rem;
		max-width: 750px;
		margin: 0.75rem 0 0.5rem;
		line-height: 1.2;
	}

	.article-header__desc {
		color: rgb(var(--gray));
		font-size: 1.05rem;
		max-width: 650px;
		margin-bottom: 1rem;
	}

	.article-header__meta {
		font-size: 0.85rem;
		color: rgb(var(--gray));
		display: flex;
		gap: 1.25rem;
		flex-wrap: wrap;
		align-items: center;
	}

	.article-byline {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		text-decoration: none;
		color: rgb(var(--black));
		font-weight: 600;
	}
	.article-byline:hover { color: var(--primary); }
	.article-byline__avatar {
		width: 26px; height: 26px;
		border-radius: 50%;
		display: inline-block;
	}
	.article-byline__by { font-size: 0.85rem; }

	.article-header__updated {
		font-style: italic;
	}

	.article-hero {
		margin-top: 2rem;
	}

	.article-hero img {
		width: 100%;
		max-width: 960px;
		border-radius: var(--radius);
	}

	.article-body {
		max-width: 750px;
		padding-top: 2rem;
		padding-bottom: 2rem;
	}

	.article-body :global(h2) {
		margin-top: 2.5rem;
		padding-top: 1.5rem;
		border-top: 1px solid var(--border);
	}

	.article-body :global(h3) {
		margin-top: 1.5rem;
	}

	.article-body :global(p) {
		margin-bottom: 1.25em;
	}

	.article-body :global(img.best-of-shot),
	.article-body :global(img) {
		max-width: 100%;
		height: auto;
		border-radius: var(--radius);
		border: 1px solid var(--border);
		margin: 1.25rem 0 1.5rem;
		display: block;
	}

	.article-body :global(aside.methodology) {
		background: var(--bg-alt);
		border-left: 3px solid var(--primary);
		padding: 1rem 1.25rem;
		border-radius: 0 var(--radius) var(--radius) 0;
		margin: 0 0 2rem;
		font-size: 0.92rem;
	}
	.article-body :global(aside.methodology h2) {
		font-size: 0.92rem;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		margin: 0 0 0.5rem;
		padding: 0;
		border: 0;
		color: var(--primary);
	}
	.article-body :global(aside.methodology p) {
		margin: 0;
		color: rgb(var(--gray));
	}

	.faq-wrapper {
		max-width: 750px;
		padding-bottom: 1rem;
	}

	.article-tags {
		max-width: 750px;
		padding-bottom: 2rem;
		display: flex;
		align-items: center;
		gap: 0.5rem;
		flex-wrap: wrap;
		font-size: 0.85rem;
	}

	.tag {
		background: var(--bg-alt);
		border: 1px solid var(--border);
		padding: 0.2rem 0.6rem;
		border-radius: 50px;
		font-size: 0.8rem;
		color: rgb(var(--gray));
	}

	/* Table of Contents */
	.toc {
		background: var(--bg-alt);
		border: 1px solid var(--border);
		border-radius: var(--radius);
		padding: 1.25rem 1.5rem;
		margin-bottom: 2rem;
		font-size: 0.92rem;
	}

	.toc__title {
		font-weight: 700;
		font-size: 0.85rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: rgb(var(--gray));
		margin-bottom: 0.75rem;
	}

	.toc ol {
		margin: 0;
		padding-left: 1.25rem;
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
	}

	.toc a {
		color: rgb(var(--black));
		text-decoration: none;
	}

	.toc a:hover {
		color: var(--primary);
	}

	/* Author bio */
	.author-bio {
		max-width: 750px;
		padding-bottom: 2.5rem;
	}

	.author-bio__inner {
		display: flex;
		gap: 1rem;
		align-items: flex-start;
		background: var(--bg-alt);
		border: 1px solid var(--border);
		border-radius: var(--radius);
		padding: 1.25rem 1.5rem;
	}

	.author-bio__avatar {
		flex-shrink: 0;
		width: 48px;
		height: 48px;
		border-radius: 50%;
		display: block;
	}

	.author-bio__name {
		font-weight: 700;
		font-size: 0.95rem;
		margin-bottom: 0.35rem !important;
	}
	.author-bio__name a { color: var(--primary); text-decoration: none; }
	.author-bio__name a:hover { text-decoration: underline; }
	.author-bio__role {
		font-weight: 400;
		color: rgb(var(--gray));
		font-size: 0.85rem;
	}

	.author-bio__desc {
		font-size: 0.9rem;
		color: rgb(var(--gray));
		margin-bottom: 0.4rem !important;
	}

	.author-bio__social {
		font-size: 0.85rem;
		margin-bottom: 0 !important;
	}
	.author-bio__social a { color: var(--primary); text-decoration: none; }
	.author-bio__social a:hover { text-decoration: underline; }

	.mid-article-nl {
		background: var(--bg-alt);
		border: 1px solid var(--border);
		border-radius: var(--radius);
		padding: 2rem 1.5rem;
		margin: 2.5rem 0;
		text-align: center;
	}

	.mid-article-nl h3 {
		color: rgb(var(--black));
		margin-bottom: 0.5rem;
		font-size: 1.2rem;
	}

	.mid-article-nl p {
		font-size: 0.95rem;
		color: rgb(var(--gray));
		margin-bottom: 1rem;
	}

	@media (min-width: 768px) {
		.article-header h1 { font-size: 2.6rem; }
	}

	/* Reading progress bar */
	.reading-progress {
		position: fixed; top: 0; left: 0; height: 3px;
		background: var(--primary);
		width: 0%; z-index: 9999;
		transition: width 0.1s linear;
	}
</style>

<script data-astro-rerun>
	// Reading progress bar
	const progressBar = document.getElementById('reading-progress');
	if (progressBar) {
		window.addEventListener('scroll', () => {
			const scrollTop = window.scrollY;
			const docHeight = document.documentElement.scrollHeight - window.innerHeight;
			const pct = docHeight > 0 ? Math.min((scrollTop / docHeight) * 100, 100) : 0;
			progressBar.style.width = pct + '%';
		});
	}

	document.addEventListener('DOMContentLoaded', () => {
		const body = document.querySelector('.article-body');
		if (!body) return;

		const headings = body.querySelectorAll('h2');
		if (headings.length === 0) return;

		// Table of Contents — inject before first H2 if 3+ headings
		if (headings.length >= 3) {
			const toc = document.createElement('nav');
			toc.className = 'toc';
			toc.setAttribute('aria-label', 'Table of contents');
			const tocTitle = document.createElement('p');
			tocTitle.className = 'toc__title';
			tocTitle.textContent = 'In this article';
			const ol = document.createElement('ol');
			headings.forEach(h => {
				if (!h.id) return;
				const li = document.createElement('li');
				const a = document.createElement('a');
				a.href = `#${h.id}`;
				a.textContent = h.textContent || '';
				li.appendChild(a);
				ol.appendChild(li);
			});
			toc.appendChild(tocTitle);
			toc.appendChild(ol);
			headings[0].parentNode.insertBefore(toc, headings[0]);
		}

		// Mid-article newsletter
		const midIndex = Math.floor(headings.length / 2);
		const midHeading = headings[midIndex];

		const nl = document.createElement('aside');
		nl.className = 'mid-article-nl';
		nl.setAttribute('aria-label', 'Newsletter signup');
		nl.innerHTML = `
			<h3>Get more in my newsletter</h3>
			<p>The stories worth your time. Stay ahead without the noise.</p>
			<form class="nl-form" action="https://subscribe-forms.beehiiv.com/fda3e0ad-bcc8-4e4d-8f5b-123db9391be9" method="POST" target="_blank" rel="noopener">
				<input type="email" name="email" required placeholder="you@example.com" aria-label="Email address" class="nl-form__input" />
				<button type="submit" class="nl-form__btn">Subscribe</button>
			</form>
		`;

		midHeading.parentNode.insertBefore(nl, midHeading);
	});
</script>
