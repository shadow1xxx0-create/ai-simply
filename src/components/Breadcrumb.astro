---
interface Crumb {
	label: string;
	href?: string;
}

interface Props {
	crumbs: Crumb[];
}

const { crumbs } = Astro.props;
---

<nav class="breadcrumbs" aria-label="Breadcrumb">
	{crumbs.map((crumb, i) => (
		<>
			{i > 0 && <span aria-hidden="true">/</span>}
			{crumb.href ? <a href={crumb.href}>{crumb.label}</a> : <span>{crumb.label}</span>}
		</>
	))}
</nav>
