---
import { BEEHIIV_FORM_URL } from '../consts';

interface Props {
	variant?: 'full' | 'inline';
	heading?: string;
	text?: string;
}

const {
	variant = 'full',
	heading = 'Get AI news in plain English — free, every week',
	text = 'Join thousands of readers. No jargon, no hype. Free.',
} = Astro.props;
---

<script async src="https://subscribe-forms.beehiiv.com/embed.js" crossorigin="anonymous"></script>

{variant === 'full' ? (
	<section class="newsletter" id="newsletter" aria-label="Newsletter signup">
		<div class="container newsletter__inner">
			<iframe
				src={BEEHIIV_FORM_URL}
				class="beehiiv-embed"
				data-test-id="beehiiv-embed"
				frameborder="0"
				scrolling="no"
				loading="lazy"
				style="width:100%;max-width:100%;height:260px;margin:0;border-radius:0!important;background-color:transparent;box-shadow:0 0 #0000;"
			></iframe>
		</div>
	</section>
) : (
	<aside class="inline-nl" aria-label="Newsletter signup">
		<h3>{heading}</h3>
		<p>{text}</p>
		<iframe
			src={BEEHIIV_FORM_URL}
			class="beehiiv-embed"
			data-test-id="beehiiv-embed"
			frameborder="0"
			scrolling="no"
			loading="lazy"
			style="width:100%;max-width:100%;height:260px;margin:0;border-radius:6px!important;background-color:transparent;box-shadow:0 0 #0000;"
		></iframe>
	</aside>
)}

<style>
	.newsletter {
		background: var(--bg-alt);
		padding: 2.5rem 0;
		text-align: center;
	}

	.newsletter__inner {
		max-width: 520px;
		margin: 0 auto;
		max-height: 310px;
		overflow: hidden;
	}

	/* Inline variant */
	.inline-nl {
		background: var(--bg-alt);
		border: 1px solid var(--border);
		border-radius: var(--radius);
		padding: 2rem 1.5rem;
		margin: 2.5rem 0;
		text-align: center;
	}

	.inline-nl h3 {
		color: rgb(var(--black));
		margin-bottom: 0.5rem;
	}

	.inline-nl p {
		font-size: 0.95rem;
		color: rgb(var(--gray));
		margin-bottom: 1rem;
	}
</style>
