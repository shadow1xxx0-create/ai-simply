---
import { BEEHIIV_FORM_URL } from '../consts';

interface Props {
	variant?: 'full' | 'inline';
	heading?: string;
	text?: string;
}

const {
	variant = 'full',
	heading = 'Enjoying this article?',
	text = 'Get AI news in plain English — free, every week.',
} = Astro.props;
---

{variant === 'full' ? (
	<section class="newsletter" id="newsletter" aria-label="Newsletter signup">
		<div class="container newsletter__inner">
			<h3 class="newsletter__heading">{heading}</h3>
			<p class="newsletter__text">{text}</p>
			<form class="nl-form" action={BEEHIIV_FORM_URL} method="POST" target="_blank" rel="noopener">
				<input
					type="email"
					name="email"
					required
					placeholder="you@example.com"
					aria-label="Email address"
					class="nl-form__input"
				/>
				<button type="submit" class="nl-form__btn">Subscribe</button>
			</form>
		</div>
	</section>
) : (
	<aside class="inline-nl" aria-label="Newsletter signup">
		<h3>{heading}</h3>
		<p>{text}</p>
		<form class="nl-form" action={BEEHIIV_FORM_URL} method="POST" target="_blank" rel="noopener">
			<input
				type="email"
				name="email"
				required
				placeholder="you@example.com"
				aria-label="Email address"
				class="nl-form__input"
			/>
			<button type="submit" class="nl-form__btn">Subscribe</button>
		</form>
	</aside>
)}

<style>
	.newsletter {
		background: var(--bg-alt);
		padding: 2.5rem 0;
		text-align: center;
	}

	.newsletter__inner {
		max-width: 520px;
		margin: 0 auto;
	}

	.newsletter__heading {
		color: rgb(var(--black));
		margin-bottom: 0.5rem;
		font-size: 1.4rem;
	}

	.newsletter__text {
		font-size: 0.95rem;
		color: rgb(var(--gray));
		margin-bottom: 1.25rem;
	}

	/* Inline variant */
	.inline-nl {
		background: var(--bg-alt);
		border: 1px solid var(--border);
		border-radius: var(--radius);
		padding: 2rem 1.5rem;
		margin: 2.5rem 0;
		text-align: center;
	}

	.inline-nl h3 {
		color: rgb(var(--black));
		margin-bottom: 0.5rem;
	}

	.inline-nl p {
		font-size: 0.95rem;
		color: rgb(var(--gray));
		margin-bottom: 1rem;
	}
</style>
