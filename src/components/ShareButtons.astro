---
interface Props {
	url: string;
	title: string;
}

const { url, title } = Astro.props;
const encodedUrl = encodeURIComponent(url);
const encodedTitle = encodeURIComponent(title);
---

<div class="share-buttons">
	<span class="share-label">Share:</span>
	<a
		href={`https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`}
		target="_blank"
		rel="noopener noreferrer"
		class="share-btn share-btn--x"
		aria-label="Share on X"
	>
		<svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
			<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
		</svg>
	</a>
	<a
		href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`}
		target="_blank"
		rel="noopener noreferrer"
		class="share-btn share-btn--li"
		aria-label="Share on LinkedIn"
	>
		<svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
			<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
		</svg>
	</a>
	<button
		class="share-btn share-btn--copy"
		data-url={url}
		aria-label="Copy link"
	>
		<svg class="share-icon-link" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
			<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
			<path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
		</svg>
		<svg class="share-icon-check" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" hidden>
			<polyline points="20 6 9 17 4 12"/>
		</svg>
	</button>
</div>

<script>
	function initShareCopyButtons() {
		document.querySelectorAll('.share-btn--copy').forEach((btn) => {
			if (btn.dataset.shareInit === '1') return;
			btn.dataset.shareInit = '1';
			const linkIcon = btn.querySelector('.share-icon-link');
			const checkIcon = btn.querySelector('.share-icon-check');
			btn.addEventListener('click', async () => {
				const url = btn.dataset.url;
				if (!url) return;
				try {
					await navigator.clipboard.writeText(url);
				} catch (err) {
					const ta = document.createElement('textarea');
					ta.value = url;
					document.body.appendChild(ta);
					ta.select();
					document.execCommand('copy');
					ta.remove();
				}
				if (linkIcon) linkIcon.hidden = true;
				if (checkIcon) checkIcon.hidden = false;
				setTimeout(() => {
					if (linkIcon) linkIcon.hidden = false;
					if (checkIcon) checkIcon.hidden = true;
				}, 1500);
			});
		});
	}
	initShareCopyButtons();
	document.addEventListener('astro:page-load', initShareCopyButtons);
</script>

<style>
	.share-buttons { display: flex; align-items: center; gap: 0.5rem; }
	.share-label { font-size: 0.78rem; color: rgb(var(--gray)); font-weight: 600; }
	.share-btn {
		display: inline-flex; align-items: center; justify-content: center;
		width: 32px; height: 32px;
		border: 1px solid var(--border); border-radius: var(--radius);
		background: var(--bg); color: rgb(var(--gray-dark));
		font-size: 0.78rem; font-weight: 700;
		cursor: pointer; transition: all 0.15s;
		text-decoration: none; line-height: 1;
	}
	.share-btn:hover { border-color: var(--primary); color: var(--primary); background: var(--primary-light); }
</style>
