---
import { SITE_TITLE, BEEHIIV_FORM_URL, TOOL_CATEGORIES } from '../consts';
const year = new Date().getFullYear();
const freeToolLinks = [
	{ name: 'AI Writing Tools', href: '/tools/category/ai-writing/' },
	{ name: 'AI Image Generators', href: '/tools/category/ai-image/' },
	{ name: 'AI Chatbots', href: '/tools/category/ai-chatbot/' },
	{ name: 'AI Coding Tools', href: '/tools/category/ai-coding/' },
	{ name: 'AI Video Generators', href: '/tools/category/ai-video/' },
	{ name: 'AI Productivity', href: '/tools/category/ai-productivity/' },
	{ name: 'AI Detection Tools', href: '/tools/category/ai-detection/' },
];
---

<footer class="site-footer" role="contentinfo">
	<div class="container">
		<div class="footer-grid">

			<!-- Brand -->
			<div class="footer-brand">
				<h4>{SITE_TITLE}</h4>
				<p>Discover the best AI tools across 21 categories. Curated, categorized, and updated daily.</p>
				<a href={BEEHIIV_FORM_URL} target="_blank" rel="noopener noreferrer" class="footer-subscribe-btn">Get my newsletter →</a>
			</div>

			<!-- Free AI Tools -->
			<div>
				<h4>Free AI Tools</h4>
				<ul>
					{freeToolLinks.map(l => <li><a href={l.href}>{l.name}</a></li>)}
				</ul>
			</div>

			<!-- Resources -->
			<div>
				<h4>Resources</h4>
				<ul>
					<li><a href="/tools/">All AI Tools</a></li>
					<li><a href="/tools/quiz/">🎯 Find My AI Tool</a></li>
					<li><a href="/tools/new/">New AI Tools</a></li>
					<li><a href="/tools/top-rated/">Top Rated Tools</a></li>
					<li><a href="/tools/collections/">Collections</a></li>
					<li><a href="/reviews/">Reviews</a></li>
					<li><a href="/tutorials/">Tutorials</a></li>
					<li><a href="/blog/">Articles</a></li>
					<li><a href="/rating-methodology/">Rating Methodology</a></li>
					<li><a href="/submit/">Submit a Tool</a></li>
				</ul>
			</div>

			<!-- Company -->
			<div>
				<h4>Company</h4>
				<ul>
					<li><a href="/about/">About</a></li>
					<li><a href="/contact/">Contact</a></li>
					<li><a href="/privacy/">Privacy Policy</a></li>
					<li><a href="/terms/">Terms of Service</a></li>
				</ul>
				<div class="footer-newsletter">
					<p>Stay ahead without the noise</p>
					<a href={BEEHIIV_FORM_URL} target="_blank" rel="noopener noreferrer" class="newsletter-link">Get my newsletter →</a>
				</div>
			</div>

		</div>

		<div class="footer-bottom">
			<p>&copy; {year} {SITE_TITLE}. All rights reserved.</p>
			<div class="footer-bottom-right">
				<div class="footer-bottom-links">
					<a href="/privacy/">Privacy</a>
					<a href="/terms/">Terms</a>
					<a href="/sitemap-index.xml">Sitemap</a>
				</div>
			</div>
		</div>
	</div>
</footer>

<!-- Back to top -->
<button id="back-to-top" aria-label="Back to top" title="Back to top">↑</button>

<!-- Bottom-left Newsletter Capture -->
<aside id="nl-toast" class="nl-toast" hidden aria-label="Newsletter signup">
	<button class="nl-toast__close" id="nl-toast-close" aria-label="Close">✕</button>
	<div class="nl-toast__body">
		<div class="nl-toast__icon" aria-hidden="true">📬</div>
		<div class="nl-toast__copy">
			<h3>Get the AI brief.</h3>
			<p>Plain-English AI news. Free. Once a week.</p>
		</div>
	</div>
	<form id="nl-toast-form" class="nl-toast__form" action={BEEHIIV_FORM_URL} method="POST" target="_blank" rel="noopener">
		<input
			type="email"
			name="email"
			required
			placeholder="you@example.com"
			aria-label="Email address"
			class="nl-toast__input"
			autocomplete="email"
		/>
		<button type="submit" class="nl-toast__btn">Subscribe</button>
	</form>
	<div id="nl-toast-success" class="nl-toast__success" hidden>Thanks! Check your inbox to confirm. ✨</div>
</aside>

<script data-astro-rerun>
// Back-to-top
(function () {
	const btn = document.getElementById('back-to-top');
	if (!btn) return;
	const onScroll = () => btn.classList.toggle('visible', window.scrollY > 400);
	window.addEventListener('scroll', onScroll, { passive: true });
	btn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
})();

// Bottom-left newsletter capture toast
(function () {
	const toast = document.getElementById('nl-toast');
	const toastClose = document.getElementById('nl-toast-close');
	const toastForm = document.getElementById('nl-toast-form');
	const toastSuccess = document.getElementById('nl-toast-success');
	if (!toast || !toastForm || !toastClose || !toastSuccess) return;

	const STORAGE_KEY = 'nl_toast_state';
	const SHOW_DELAY_MS = 25 * 1000;
	const DISMISS_HIDE_DAYS = 7;
	const SUBSCRIBED_HIDE_DAYS = 365;

	function getState() {
		try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}'); } catch (e) { return {}; }
	}
	function setState(next) {
		try { localStorage.setItem(STORAGE_KEY, JSON.stringify(next)); } catch (e) {}
	}
	function shouldShow() {
		const s = getState();
		if (s.subscribed) return false;
		if (s.hideUntil && Date.now() < s.hideUntil) return false;
		return true;
	}
	function showToast() {
		if (!shouldShow()) return;
		toast.hidden = false;
		requestAnimationFrame(() => toast.classList.add('nl-toast--in'));
	}
	function hideToast(daysHidden) {
		toast.classList.remove('nl-toast--in');
		setTimeout(() => { toast.hidden = true; }, 250);
		setState(Object.assign(getState(), { hideUntil: Date.now() + daysHidden * 24 * 60 * 60 * 1000 }));
	}

	// Single timer across SPA navigations so we don't re-trigger on every page change.
	if (window.__nlToastTimer) clearTimeout(window.__nlToastTimer);
	if (shouldShow()) {
		window.__nlToastTimer = setTimeout(showToast, SHOW_DELAY_MS);
	}

	toastClose.addEventListener('click', () => hideToast(DISMISS_HIDE_DAYS));

	toastForm.addEventListener('submit', () => {
		setState({ subscribed: true, hideUntil: Date.now() + SUBSCRIBED_HIDE_DAYS * 24 * 60 * 60 * 1000 });
		toastForm.hidden = true;
		toastSuccess.hidden = false;
		setTimeout(() => hideToast(SUBSCRIBED_HIDE_DAYS), 4000);
	});
})();
</script>

<style>
/* Bottom-left newsletter toast */
.nl-toast {
	position: fixed;
	bottom: 1.25rem;
	left: 1.25rem;
	z-index: 10000;
	width: min(340px, calc(100vw - 2rem));
	background: var(--surface-1, var(--bg-alt));
	color: rgb(var(--gray-dark));
	border: 1px solid var(--border);
	border-radius: 14px;
	box-shadow: 0 16px 48px rgba(0,0,0,0.45);
	padding: 1rem 1rem 0.9rem;
	opacity: 0;
	transform: translateY(16px);
	transition: opacity 0.25s var(--ease-out, ease), transform 0.25s var(--ease-out, ease);
}
.nl-toast[hidden] { display: none; }
.nl-toast--in { opacity: 1; transform: translateY(0); }

.nl-toast__close {
	position: absolute;
	top: 0.4rem;
	right: 0.5rem;
	background: none;
	border: none;
	cursor: pointer;
	font-size: 0.95rem;
	color: rgb(var(--gray));
	padding: 0.25rem 0.4rem;
	line-height: 1;
	border-radius: 6px;
}
.nl-toast__close:hover { color: rgb(var(--black)); background: rgb(var(--gray) / 0.12); }

.nl-toast__body {
	display: flex;
	gap: 0.7rem;
	align-items: flex-start;
	padding-right: 1.25rem;
	margin-bottom: 0.75rem;
}
.nl-toast__icon {
	font-size: 1.4rem;
	line-height: 1;
	flex-shrink: 0;
	margin-top: 2px;
}
.nl-toast__copy h3 {
	margin: 0 0 0.15rem;
	font-size: 0.95rem;
	color: rgb(var(--black));
	font-weight: 700;
}
.nl-toast__copy p {
	margin: 0;
	font-size: 0.8rem;
	color: rgb(var(--gray));
	line-height: 1.4;
}

.nl-toast__form {
	display: flex;
	gap: 0.4rem;
}
.nl-toast__input {
	flex: 1;
	min-width: 0;
	padding: 0.55rem 0.7rem;
	border: 1px solid var(--border);
	border-radius: 8px;
	background: var(--bg);
	color: rgb(var(--black));
	font-size: 0.85rem;
	font-family: inherit;
	outline: none;
	transition: border-color 0.15s;
}
.nl-toast__input:focus { border-color: var(--primary); }
.nl-toast__input::placeholder { color: rgb(var(--gray) / 0.7); }

.nl-toast__btn {
	padding: 0.55rem 0.85rem;
	background: var(--primary);
	color: #0b0f0d;
	border: none;
	border-radius: 8px;
	font-size: 0.82rem;
	font-weight: 700;
	font-family: inherit;
	cursor: pointer;
	white-space: nowrap;
	transition: background 0.15s;
}
.nl-toast__btn:hover { background: var(--primary-dark); }

.nl-toast__success {
	font-size: 0.85rem;
	color: var(--primary);
	font-weight: 600;
	text-align: center;
	padding: 0.4rem 0;
}

/* On desktop, sit clear of the left sidebar nav (top-aligned, ~144px wide) */
@media (min-width: 768px) {
	.nl-toast { left: 176px; bottom: 1.5rem; }
}

/* On small mobile, full-width minus margins */
@media (max-width: 480px) {
	.nl-toast { left: 0.75rem; right: 0.75rem; bottom: 0.75rem; width: auto; }
}

#back-to-top {
	position: fixed;
	bottom: 1.5rem;
	right: 1.5rem;
	width: 40px;
	height: 40px;
	border-radius: 50%;
	background: var(--primary);
	color: #fff;
	border: none;
	font-size: 1.1rem;
	cursor: pointer;
	display: flex;
	align-items: center;
	justify-content: center;
	opacity: 0;
	transform: translateY(12px);
	transition: opacity 0.2s, transform 0.2s;
	z-index: 999;
	box-shadow: 0 2px 12px rgba(0,0,0,0.2);
}
#back-to-top.visible { opacity: 1; transform: translateY(0); }
#back-to-top:hover { background: var(--primary-dark); }
@media (max-width: 767px) { #back-to-top { display: none; } }
</style>

<style>
	.site-footer {
		background: var(--bg-alt);
		color: rgb(var(--gray-dark) / 0.85);
		border-top: 1px solid var(--border);
		padding: 3.5rem 0 1.5rem;
	}

	.footer-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 2.5rem;
		margin-bottom: 2.5rem;
	}

	.site-footer h4 {
		color: rgb(var(--black));
		font-size: 0.72rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		margin-bottom: 1rem;
	}

	.footer-brand p { font-size: 0.85rem; line-height: 1.65; margin-bottom: 1rem; }

	.site-footer .footer-subscribe-btn {
		display: inline-block;
		padding: 0.5rem 1rem;
		background: var(--primary);
		color: #0b0f0d;
		font-size: 0.82rem;
		font-weight: 700;
		border-radius: var(--radius);
		margin-bottom: 1.25rem;
		transition: background 0.25s var(--ease-out), transform 0.25s var(--ease-out), box-shadow 0.25s var(--ease-out);
	}

	.site-footer .footer-subscribe-btn:hover { background: var(--primary-dark); color: #0b0f0d; transform: translateY(-1px); box-shadow: var(--accent-glow); }

	.footer-socials {
		display: flex;
		gap: 0.6rem;
	}

	.footer-socials a {
		width: 32px;
		height: 32px;
		background: rgb(var(--black) / 0.08);
		border-radius: 8px;
		display: flex;
		align-items: center;
		justify-content: center;
		color: rgb(var(--gray-dark) / 0.7);
		transition: background 0.25s var(--ease-out), color 0.25s var(--ease-out), transform 0.25s var(--ease-out);
	}

	.footer-socials a:hover { background: var(--primary); color: #0b0f0d; transform: translateY(-2px); }

	.site-footer ul { list-style: none; padding: 0; margin: 0; }
	.site-footer li { margin-bottom: 0.5rem; }
	.site-footer a { color: rgb(var(--gray-dark) / 0.82); font-size: 0.85rem; transition: color 0.2s var(--ease-out); }
	.site-footer a:hover { color: var(--primary); }

	.footer-newsletter { margin-top: 1.5rem; }
	.footer-newsletter p { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.06em; color: rgb(var(--gray)); margin-bottom: 0.4rem; }
	.newsletter-link { font-size: 0.82rem; color: var(--primary) !important; font-weight: 600; }

	.footer-bottom {
		border-top: 1px solid var(--border);
		padding-top: 1.25rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.footer-bottom p { font-size: 0.78rem; margin: 0; }

	.footer-bottom-links {
		display: flex;
		gap: 1rem;
	}

	.footer-bottom-links a { font-size: 0.78rem; color: rgb(var(--gray)); }
	.footer-bottom-links a:hover { color: var(--primary); }

	.footer-bottom-right { display: flex; align-items: center; gap: 1.25rem; flex-wrap: wrap; }

@media (min-width: 640px) {
		.footer-grid { grid-template-columns: repeat(2, 1fr); }
	}

	@media (min-width: 960px) {
		.footer-grid { grid-template-columns: 2fr 1fr 1fr 1fr; }
	}
</style>
