---
import { SITE_TITLE, BEEHIIV_FORM_URL, TOOL_CATEGORIES } from '../consts';
const year = new Date().getFullYear();
const freeToolLinks = [
	{ name: 'AI Writing Tools', href: '/tools/category/ai-writing/' },
	{ name: 'AI Image Generators', href: '/tools/category/ai-image/' },
	{ name: 'AI Chatbots', href: '/tools/category/ai-chatbot/' },
	{ name: 'AI Coding Tools', href: '/tools/category/ai-coding/' },
	{ name: 'AI Video Generators', href: '/tools/category/ai-video/' },
	{ name: 'AI Productivity', href: '/tools/category/ai-productivity/' },
	{ name: 'AI Detection Tools', href: '/tools/category/ai-detection/' },
];
---

<footer class="site-footer" role="contentinfo">
	<div class="container">
		<div class="footer-grid">

			<!-- Brand -->
			<div class="footer-brand">
				<h4>{SITE_TITLE}</h4>
				<p>Discover the best AI tools across 22 categories. Curated, categorized, and updated daily.</p>
				<a href={BEEHIIV_FORM_URL} target="_blank" rel="noopener noreferrer" class="footer-subscribe-btn">Get my newsletter →</a>
			</div>

			<!-- Free AI Tools -->
			<div>
				<h4>Free AI Tools</h4>
				<ul>
					{freeToolLinks.map(l => <li><a href={l.href}>{l.name}</a></li>)}
				</ul>
			</div>

			<!-- Resources -->
			<div>
				<h4>Resources</h4>
				<ul>
					<li><a href="/tools/">All AI Tools</a></li>
					<li><a href="/tools/quiz/">🎯 Find My AI Tool</a></li>
					<li><a href="/tools/new/">New AI Tools</a></li>
					<li><a href="/tools/top-rated/">Top Rated Tools</a></li>
					<li><a href="/tools/collections/">Collections</a></li>
					<li><a href="/reviews/">Reviews</a></li>
					<li><a href="/tutorials/">Tutorials</a></li>
					<li><a href="/blog/">Articles</a></li>
					<li><a href="/rating-methodology/">Rating Methodology</a></li>
					<li><a href="/submit/">Submit a Tool</a></li>
				</ul>
			</div>

			<!-- Company -->
			<div>
				<h4>Company</h4>
				<ul>
					<li><a href="/about/">About</a></li>
					<li><a href="/contact/">Contact</a></li>
					<li><a href="/privacy/">Privacy Policy</a></li>
					<li><a href="/terms/">Terms of Service</a></li>
				</ul>
				<div class="footer-newsletter">
					<p>Stay ahead without the noise</p>
					<a href={BEEHIIV_FORM_URL} target="_blank" rel="noopener noreferrer" class="newsletter-link">Get my newsletter →</a>
				</div>
			</div>

		</div>

		<div class="footer-bottom">
			<p>&copy; {year} {SITE_TITLE}. All rights reserved.</p>
			<div class="footer-bottom-right">
				<div class="footer-bottom-links">
					<a href="/privacy/">Privacy</a>
					<a href="/terms/">Terms</a>
					<a href="/sitemap-index.xml">Sitemap</a>
				</div>
			</div>
		</div>
	</div>
</footer>

<!-- Back to top -->
<button id="back-to-top" aria-label="Back to top" title="Back to top">↑</button>

<!-- Exit-Intent Newsletter -->
<div id="exit-popup" class="exit-popup" hidden>
	<div class="exit-popup__card">
		<button class="exit-popup__close" id="exit-close" aria-label="Close">✕</button>
		<h3>Before you go...</h3>
		<p>The stories worth your time. Stay ahead without the noise.</p>
		<a href={BEEHIIV_FORM_URL} target="_blank" rel="noopener noreferrer" class="btn btn--primary" style="width:100%;justify-content:center">Subscribe Free →</a>
		<span class="exit-popup__dismiss" id="exit-dismiss">No thanks</span>
	</div>
</div>

<script>
const btn = document.getElementById('back-to-top')!;
window.addEventListener('scroll', () => { btn.classList.toggle('visible', window.scrollY > 400); });
btn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

// Recurring subscribe popup — every 2 minutes
const exitPopup = document.getElementById('exit-popup')!;
const exitClose = document.getElementById('exit-close')!;
const exitDismiss = document.getElementById('exit-dismiss')!;

const POPUP_INTERVAL_MS = 2 * 60 * 1000;
let popupTimer: number | undefined;

function showExit() {
	exitPopup.hidden = false;
}
function hideExit() {
	exitPopup.hidden = true;
	scheduleNext();
}
function scheduleNext() {
	if (popupTimer) clearTimeout(popupTimer);
	popupTimer = window.setTimeout(showExit, POPUP_INTERVAL_MS);
}

scheduleNext();
exitClose?.addEventListener('click', hideExit);
exitDismiss?.addEventListener('click', hideExit);
exitPopup?.addEventListener('click', (e) => { if (e.target === exitPopup) hideExit(); });
</script>

<style>
/* Exit-intent popup */
.exit-popup {
	position: fixed; inset: 0;
	background: rgba(0,0,0,0.5); z-index: 10000;
	display: flex; align-items: center; justify-content: center;
	padding: 1rem;
}
.exit-popup[hidden] { display: none; }
.exit-popup__card {
	background: var(--bg); border-radius: 12px; padding: 2rem;
	max-width: 400px; width: 100%; text-align: center;
	box-shadow: 0 20px 60px rgba(0,0,0,0.2); position: relative;
}
.exit-popup__card h3 { font-size: 1.25rem; color: rgb(var(--black)); margin-bottom: 0.5rem; }
.exit-popup__card p { font-size: 0.9rem; color: rgb(var(--gray)); margin-bottom: 1.25rem; }
.exit-popup__close {
	position: absolute; top: 0.75rem; right: 0.75rem;
	background: none; border: none; cursor: pointer;
	font-size: 1.1rem; color: rgb(var(--gray)); padding: 0.25rem;
}
.exit-popup__dismiss {
	display: block; margin-top: 0.75rem;
	font-size: 0.78rem; color: rgb(var(--gray)); cursor: pointer;
}
.exit-popup__dismiss:hover { color: rgb(var(--black)); }

#back-to-top {
	position: fixed;
	bottom: 1.5rem;
	right: 1.5rem;
	width: 40px;
	height: 40px;
	border-radius: 50%;
	background: var(--primary);
	color: #fff;
	border: none;
	font-size: 1.1rem;
	cursor: pointer;
	display: flex;
	align-items: center;
	justify-content: center;
	opacity: 0;
	transform: translateY(12px);
	transition: opacity 0.2s, transform 0.2s;
	z-index: 999;
	box-shadow: 0 2px 12px rgba(0,0,0,0.2);
}
#back-to-top.visible { opacity: 1; transform: translateY(0); }
#back-to-top:hover { background: var(--primary-dark); }
@media (max-width: 767px) { #back-to-top { display: none; } }
</style>

<style>
	.site-footer {
		background: var(--bg-alt);
		color: rgb(var(--gray-dark) / 0.85);
		border-top: 1px solid var(--border);
		padding: 3.5rem 0 1.5rem;
	}

	.footer-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 2.5rem;
		margin-bottom: 2.5rem;
	}

	.site-footer h4 {
		color: rgb(var(--black));
		font-size: 0.72rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		margin-bottom: 1rem;
	}

	.footer-brand p { font-size: 0.85rem; line-height: 1.65; margin-bottom: 1rem; }

	.footer-subscribe-btn {
		display: inline-block;
		padding: 0.5rem 1rem;
		background: var(--primary);
		color: #0b0f0d;
		font-size: 0.82rem;
		font-weight: 700;
		border-radius: var(--radius);
		margin-bottom: 1.25rem;
		transition: background 0.25s var(--ease-out), transform 0.25s var(--ease-out), box-shadow 0.25s var(--ease-out);
	}

	.footer-subscribe-btn:hover { background: var(--primary-dark); color: #0b0f0d; transform: translateY(-1px); box-shadow: var(--accent-glow); }

	.footer-socials {
		display: flex;
		gap: 0.6rem;
	}

	.footer-socials a {
		width: 32px;
		height: 32px;
		background: rgb(var(--black) / 0.08);
		border-radius: 8px;
		display: flex;
		align-items: center;
		justify-content: center;
		color: rgb(var(--gray-dark) / 0.7);
		transition: background 0.25s var(--ease-out), color 0.25s var(--ease-out), transform 0.25s var(--ease-out);
	}

	.footer-socials a:hover { background: var(--primary); color: #0b0f0d; transform: translateY(-2px); }

	.site-footer ul { list-style: none; padding: 0; margin: 0; }
	.site-footer li { margin-bottom: 0.5rem; }
	.site-footer a { color: rgb(var(--gray-dark) / 0.82); font-size: 0.85rem; transition: color 0.2s var(--ease-out); }
	.site-footer a:hover { color: var(--primary); }

	.footer-newsletter { margin-top: 1.5rem; }
	.footer-newsletter p { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.06em; color: rgb(var(--gray)); margin-bottom: 0.4rem; }
	.newsletter-link { font-size: 0.82rem; color: var(--primary) !important; font-weight: 600; }

	.footer-bottom {
		border-top: 1px solid var(--border);
		padding-top: 1.25rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.footer-bottom p { font-size: 0.78rem; margin: 0; }

	.footer-bottom-links {
		display: flex;
		gap: 1rem;
	}

	.footer-bottom-links a { font-size: 0.78rem; color: rgb(var(--gray)); }
	.footer-bottom-links a:hover { color: var(--primary); }

	.footer-bottom-right { display: flex; align-items: center; gap: 1.25rem; flex-wrap: wrap; }

@media (min-width: 640px) {
		.footer-grid { grid-template-columns: repeat(2, 1fr); }
	}

	@media (min-width: 960px) {
		.footer-grid { grid-template-columns: 2fr 1fr 1fr 1fr; }
	}
</style>
