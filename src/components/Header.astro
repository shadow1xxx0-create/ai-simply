---
import { SITE_TITLE, TOOL_CATEGORIES } from '../consts';
import { getCollection } from 'astro:content';
const pathname = Astro.url.pathname;

const allTools = await getCollection('tools');
const allPosts = await getCollection('blog');

const searchIndex = [
	...allTools.map(t => ({
		type: 'tool' as const,
		name: t.data.name,
		desc: t.data.description,
		url: `/tools/${t.id}/`,
		cat: TOOL_CATEGORIES.find(c => c.slug === t.data.category)?.name ?? '',
		emoji: TOOL_CATEGORIES.find(c => c.slug === t.data.category)?.emoji ?? '🤖',
	})),
	...allPosts.map(p => ({
		type: 'article' as const,
		name: p.data.title,
		desc: p.data.description,
		url: `/blog/${p.id}/`,
		cat: p.data.category,
		emoji: '📝',
	})),
];
---

<a href="#main-content" class="skip-link">Skip to main content</a>
<header class="site-header" role="banner">
	<nav class="site-nav" aria-label="Main navigation">
		<a href="/" class="site-logo" aria-label={`${SITE_TITLE} - Home`}>
			<span class="site-logo__icon" aria-hidden="true">&#129302;</span>
			<span class="site-logo__text">{SITE_TITLE}</span>
		</a>

		<button class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">
			<span class="nav-toggle__bar"></span>
			<span class="nav-toggle__bar"></span>
			<span class="nav-toggle__bar"></span>
		</button>

		<ul class="nav-links">
			<li>
				<a href="/" class:list={[{ active: pathname === '/' }]}>
					<span class="nav-icon" aria-hidden="true">🏠</span>
					<span class="nav-label">Home</span>
				</a>
			</li>

			<li class="nav-dropdown">
				<a href="/tools/" class:list={[{ active: pathname.startsWith('/tools') }]}>
					<span class="nav-icon" aria-hidden="true">🛠️</span>
					<span class="nav-label">AI Tools<svg class="dropdown-caret" width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="6 9 12 15 18 9"/></svg></span>
				</a>
				<div class="dropdown-menu">
					<div class="dropdown-grid">
						{TOOL_CATEGORIES.map(cat => (
							<a href={`/tools/category/${cat.slug}/`} class="dropdown-item">
								<span class="dropdown-item__emoji">{cat.emoji}</span>
								<span>{cat.name}</span>
							</a>
						))}
					</div>
					<div class="dropdown-footer">
						<div class="dropdown-footer-links">
							<a href="/tools/new/">🆕 New Tools</a>
							<a href="/tools/top-rated/">⭐ Top Rated</a>
							<a href="/tools/collections/">📦 Collections</a>
						</div>
						<a href="/tools/quiz/" class="dropdown-footer-quiz">🎯 Find My Tool →</a>
					</div>
				</div>
			</li>

			<li>
				<a href="/reviews/" class:list={[{ active: pathname.startsWith('/reviews') }]}>
					<span class="nav-icon" aria-hidden="true">⭐</span>
					<span class="nav-label">Reviews</span>
				</a>
			</li>
			<li>
				<a href="/tutorials/" class:list={[{ active: pathname.startsWith('/tutorials') }]}>
					<span class="nav-icon" aria-hidden="true">🎓</span>
					<span class="nav-label">Tutorials</span>
				</a>
			</li>
			<li>
				<a href="/blog/" class:list={[{ active: pathname.startsWith('/blog') }]}>
					<span class="nav-icon" aria-hidden="true">📝</span>
					<span class="nav-label">Articles</span>
				</a>
			</li>
			<li>
				<a href="/news/" class:list={[{ active: pathname.startsWith('/news') }]}>
					<span class="nav-icon" aria-hidden="true">📰</span>
					<span class="nav-label">News</span>
				</a>
			</li>
			<li>
				<a href="/pricing/" class:list={[{ active: pathname === '/pricing/' }]}>
					<span class="nav-icon" aria-hidden="true">💲</span>
					<span class="nav-label">Pricing</span>
				</a>
			</li>
			<li>
				<a href="/proxy/" class:list={[{ active: pathname === '/proxy/' }]}>
					<span class="nav-icon" aria-hidden="true">🌐</span>
					<span class="nav-label">Proxy</span>
				</a>
			</li>

			<li>
				<button class="nav-search-btn" id="nav-search-btn" aria-label="Search">
					<span class="nav-icon" aria-hidden="true">🔍</span>
					<span class="nav-label">Search</span>
				</button>
			</li>

			<li class="nav-submit-item">
				<a href="/submit/" class="nav-submit-btn">Submit a Tool</a>
			</li>
		</ul>
	</nav>
</header>

<!-- Global Search Modal -->
<div class="search-overlay" id="search-overlay" role="dialog" aria-modal="true" aria-label="Search" hidden>
	<div class="search-modal">
		<div class="search-modal__bar">
			<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
			<input
				type="search"
				id="global-search-input"
				placeholder="Search tools, articles..."
				autocomplete="off"
				aria-label="Search tools and articles"
			/>
			<button class="search-modal__close" id="search-close" aria-label="Close search">✕</button>
		</div>
		<div id="search-results" class="search-results" hidden></div>
		<div id="search-hints" class="search-modal__hints">
			<span>Try: <a href="/tools/?q=writing">writing</a></span>
			<span><a href="/tools/?q=free">free tools</a></span>
			<span><a href="/tools/?q=image">image</a></span>
			<span><a href="/tools/?q=code">coding</a></span>
		</div>
	</div>
</div>

<script define:vars={{ searchIndex }}>
	window.__searchIndex = searchIndex;
</script>
<script>
	const INDEX = (window as any).__searchIndex as Array<{type:string;name:string;desc:string;url:string;cat:string;emoji:string}>;
	const overlay = document.getElementById('search-overlay')!;
	const searchInput = document.getElementById('global-search-input') as HTMLInputElement;
	const openBtn = document.getElementById('nav-search-btn')!;
	const closeBtn = document.getElementById('search-close')!;
	const resultsEl = document.getElementById('search-results')!;
	const hintsEl = document.getElementById('search-hints')!;

	function openSearch() {
		overlay.hidden = false;
		document.body.style.overflow = 'hidden';
		setTimeout(() => searchInput?.focus(), 50);
	}
	function closeSearch() {
		overlay.hidden = true;
		document.body.style.overflow = '';
		searchInput.value = '';
		resultsEl.hidden = true;
		hintsEl.hidden = false;
	}

	function esc(s: string) { const d = document.createElement('span'); d.textContent = s; return d.innerHTML; }

	let searchTimer: ReturnType<typeof setTimeout>;
	searchInput?.addEventListener('input', () => {
		clearTimeout(searchTimer);
		searchTimer = setTimeout(() => {
			const q = searchInput.value.trim().toLowerCase();
			if (!q) { resultsEl.hidden = true; hintsEl.hidden = false; return; }
			const matches = INDEX.filter(item =>
				item.name.toLowerCase().includes(q) || item.desc.toLowerCase().includes(q) || item.cat.toLowerCase().includes(q)
			).slice(0, 8);
			if (matches.length === 0) {
				resultsEl.innerHTML = `<div class="sr-empty">No results for "${esc(q)}"</div>`;
			} else {
				resultsEl.innerHTML = matches.map(m => `
					<a href="${m.url}" class="sr-item">
						<span class="sr-emoji">${m.emoji}</span>
						<div class="sr-info">
							<span class="sr-name">${esc(m.name)}</span>
							<span class="sr-meta">${m.type === 'tool' ? 'Tool' : 'Article'} · ${esc(m.cat)}</span>
						</div>
					</a>
				`).join('');
			}
			resultsEl.hidden = false;
			hintsEl.hidden = true;
		}, 150);
	});

	openBtn?.addEventListener('click', openSearch);
	closeBtn?.addEventListener('click', closeSearch);
	overlay?.addEventListener('click', (e) => { if (e.target === overlay) closeSearch(); });

	searchInput?.addEventListener('keydown', (e) => {
		if (e.key === 'Enter') {
			const q = searchInput.value.trim();
			if (q) window.location.href = `/tools/?q=${encodeURIComponent(q)}`;
		}
	});

	document.addEventListener('keydown', (e) => {
		if ((e.key === 'k' && (e.metaKey || e.ctrlKey)) || e.key === '/') {
			e.preventDefault();
			overlay?.hidden ? openSearch() : closeSearch();
		}
		if (e.key === 'Escape') closeSearch();
	});

	// Mobile drawer toggle
	const toggle = document.querySelector('.nav-toggle');
	const nav = document.querySelector('.nav-links');
	if (toggle && nav) {
		function closeNav() {
			toggle.setAttribute('aria-expanded', 'false');
			nav.classList.remove('nav-links--open');
		}
		toggle.addEventListener('click', () => {
			const expanded = toggle.getAttribute('aria-expanded') === 'true';
			expanded ? closeNav() : (toggle.setAttribute('aria-expanded', 'true'), nav.classList.add('nav-links--open'));
		});
		document.addEventListener('click', (e) => {
			if (!nav.contains(e.target) && !toggle.contains(e.target)) closeNav();
		});
		document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeNav(); });
		nav.querySelectorAll('a').forEach(link => link.addEventListener('click', closeNav));
	}
</script>

<style>
	/* Skip to content */
	.skip-link {
		position: absolute; top: -100px; left: 50%; transform: translateX(-50%);
		background: var(--primary); color: #fff; padding: 0.5rem 1.5rem;
		border-radius: 0 0 var(--radius) var(--radius);
		font-weight: 700; font-size: 0.85rem; z-index: 9999;
		transition: top 0.2s;
	}
	.skip-link:focus { top: 0; }

	/* ============================================================
	   MOBILE FIRST (< 768px)
	   Compact top bar with hamburger; nav opens as a left drawer.
	   ============================================================ */

	.site-header {
		background: var(--bg);
		border-bottom: 1px solid var(--border);
		position: sticky;
		top: 0;
		z-index: 200;
	}

	.site-nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 56px;
		padding: 0 1rem;
	}

	.site-logo {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 1.1rem;
		font-weight: 700;
		color: rgb(var(--black));
	}
	.site-logo:hover { color: var(--primary); }
	.site-logo__icon {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 32px;
		height: 32px;
		background: var(--accent);
		color: #fff;
		border-radius: 50%;
		font-size: 1rem;
	}
	.site-logo__text { font-size: 1rem; }

	.nav-toggle {
		display: flex;
		flex-direction: column;
		gap: 5px;
		background: none;
		border: 1px solid var(--border);
		border-radius: var(--radius);
		padding: 8px;
		cursor: pointer;
	}
	.nav-toggle__bar {
		display: block;
		width: 20px;
		height: 2px;
		background: rgb(var(--gray-dark));
		border-radius: 2px;
	}

	.nav-links {
		display: none;
		list-style: none;
		padding: 0;
		margin: 0;
	}

	/* Mobile drawer */
	.nav-links--open {
		display: flex;
		flex-direction: column;
		gap: 4px;
		position: fixed;
		top: 56px;
		left: 0;
		bottom: 0;
		width: 240px;
		background: var(--bg-alt);
		border-right: 1px solid var(--border);
		padding: 1rem 0.75rem;
		box-shadow: 4px 0 24px rgba(0,0,0,0.4);
		overflow-y: auto;
	}
	.nav-links--open a,
	.nav-links--open .nav-search-btn {
		display: flex;
		flex-direction: row;
		align-items: center;
		justify-content: flex-start;
		gap: 0.85rem;
		padding: 0.65rem 0.85rem;
		color: rgb(var(--gray-dark));
		font-weight: 500;
		font-size: 0.95rem;
		border-radius: 8px;
		text-align: left;
		width: 100%;
		background: none;
		border: none;
		cursor: pointer;
		font-family: inherit;
	}
	.nav-links--open a:hover,
	.nav-links--open a.active,
	.nav-links--open .nav-search-btn:hover {
		color: var(--primary);
		background: var(--primary-light);
	}
	.nav-links--open .nav-icon { font-size: 1.15rem; line-height: 1; }
	.nav-links--open .nav-label {
		font-size: 0.95rem;
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
	}
	.nav-links--open .nav-submit-item { margin-top: 0.5rem; }
	.nav-links--open .nav-submit-btn {
		display: block;
		text-align: center;
		background: var(--primary);
		color: #fff;
		padding: 0.65rem 1rem;
		border-radius: 8px;
		font-weight: 700;
	}
	.nav-links--open .nav-submit-btn:hover { background: var(--primary-dark); color: #fff; }

	/* ============================================================
	   DESKTOP (>= 768px)
	   Fixed left vertical sidebar, icons + labels, near-top, auto-height.
	   ============================================================ */
	@media (min-width: 768px) {
		.site-header {
			background: transparent;
			border: none;
			position: fixed;
			top: 24px;
			left: 16px;
			right: auto;
			bottom: auto;
			z-index: 200;
		}

		.site-nav {
			flex-direction: column;
			align-items: stretch;
			justify-content: flex-start;
			width: 144px;
			height: auto;
			padding: 14px 8px;
			gap: 4px;
			background: var(--surface-1);
			border: 1px solid var(--border);
			border-radius: 16px;
			box-shadow: 0 12px 36px rgba(0,0,0,0.45);
		}

		.nav-toggle { display: none; }

		.site-logo {
			flex-direction: column;
			gap: 4px;
			padding: 6px 4px 12px;
			border-bottom: 1px solid var(--border);
			margin-bottom: 6px;
			text-align: center;
			font-size: 0.78rem;
		}
		.site-logo__icon { width: 36px; height: 36px; font-size: 1.1rem; }
		.site-logo__text {
			font-size: 0.78rem;
			letter-spacing: 0.02em;
			line-height: 1.1;
		}

		.nav-links {
			display: flex;
			flex-direction: column;
			gap: 2px;
			width: 100%;
		}
		.nav-links li { width: 100%; }

		.nav-links a,
		.nav-links .nav-search-btn {
			display: flex;
			flex-direction: column;
			align-items: center;
			justify-content: center;
			gap: 4px;
			padding: 10px 4px;
			color: rgb(var(--gray-dark));
			font-weight: 500;
			border-radius: 10px;
			text-align: center;
			width: 100%;
			background: none;
			border: none;
			cursor: pointer;
			font-family: inherit;
			transition: background 0.15s, color 0.15s;
		}
		.nav-links a:hover,
		.nav-links a.active,
		.nav-links .nav-search-btn:hover {
			color: var(--primary);
			background: var(--primary-light);
		}
		.nav-icon { font-size: 1.3rem; line-height: 1; }
		.nav-label {
			font-size: 0.7rem;
			letter-spacing: 0.01em;
			display: inline-flex;
			align-items: center;
			gap: 3px;
		}

		.nav-submit-item { margin-top: 6px; padding-top: 8px; border-top: 1px solid var(--border); }
		.nav-submit-btn {
			display: block;
			text-align: center;
			background: var(--primary);
			color: #fff !important;
			padding: 0.55rem 0.5rem;
			border-radius: 10px;
			font-weight: 700;
			font-size: 0.75rem;
			line-height: 1.2;
			transition: background 0.15s;
		}
		.nav-submit-btn:hover { background: var(--primary-dark); color: #fff !important; }

		/* Caret rotates -90deg so it points right (toward the flyout) */
		.dropdown-caret { transform: rotate(-90deg); transition: transform 0.2s; flex-shrink: 0; }
		.nav-dropdown:hover .dropdown-caret { transform: rotate(0deg); }

		/* AI Tools dropdown flies out to the right */
		.nav-dropdown { position: relative; }
		.dropdown-menu {
			display: none;
			position: absolute;
			top: 0;
			left: calc(100% + 12px);
			width: 580px;
			background: var(--bg-alt);
			border: 1px solid var(--border);
			border-radius: 12px;
			box-shadow: 0 12px 36px rgba(0,0,0,0.5);
			z-index: 300;
			overflow: hidden;
		}
		/* Invisible bridge so cursor can cross the gap without losing hover */
		.dropdown-menu::before {
			content: '';
			position: absolute;
			top: 0;
			left: -12px;
			width: 12px;
			height: 100%;
		}
		.nav-dropdown:hover .dropdown-menu,
		.nav-dropdown:focus-within .dropdown-menu { display: block; }

		.dropdown-grid {
			display: grid;
			grid-template-columns: repeat(2, 1fr);
			gap: 4px;
			padding: 0.75rem;
		}
		.dropdown-item {
			display: flex;
			flex-direction: row !important;
			align-items: center !important;
			gap: 0.55rem;
			padding: 0.55rem 0.7rem;
			border-radius: 8px;
			font-size: 0.85rem;
			font-weight: 500;
			color: rgb(var(--gray-dark));
			background: none;
		}
		.dropdown-item:hover { background: var(--primary-light); color: var(--primary); }
		.dropdown-item__emoji { font-size: 1rem; flex-shrink: 0; }

		.dropdown-footer {
			border-top: 1px solid var(--border);
			padding: 0.65rem 1rem;
			background: var(--surface-1);
			display: flex;
			align-items: center;
			justify-content: space-between;
			gap: 0.75rem;
			flex-wrap: wrap;
		}
		.dropdown-footer-links { display: flex; gap: 1rem; }
		.dropdown-footer-links a {
			font-size: 0.8rem;
			font-weight: 500;
			color: rgb(var(--gray-dark));
			padding: 0;
			background: none;
			flex-direction: row !important;
		}
		.dropdown-footer-links a:hover { color: var(--primary); background: none; }
		.dropdown-footer-quiz {
			font-size: 0.8rem;
			font-weight: 700;
			color: #fff !important;
			background: var(--primary);
			padding: 0.35rem 0.85rem;
			border-radius: 99px;
			flex-direction: row !important;
		}
		.dropdown-footer-quiz:hover { background: var(--primary-dark); color: #fff !important; }
	}

	/* On mobile keep dropdown menu hidden — categories are reachable via /tools/ */
	@media (max-width: 767px) {
		.dropdown-menu { display: none !important; }
		.dropdown-caret { display: none; }
	}

	/* ============================================================
	   Search overlay (shared)
	   ============================================================ */
	.search-overlay {
		position: fixed; inset: 0;
		background: rgba(0,0,0,0.55);
		z-index: 9999;
		display: flex; align-items: flex-start; justify-content: center;
		padding-top: 80px;
		-webkit-backdrop-filter: blur(2px);
		backdrop-filter: blur(2px);
	}
	.search-overlay[hidden] { display: none; }

	.search-modal {
		width: 100%; max-width: 580px;
		background: var(--bg);
		border: 1px solid var(--border);
		border-radius: 14px;
		box-shadow: 0 20px 60px rgba(0,0,0,0.5);
		overflow: hidden;
		margin: 0 1rem;
	}

	.search-modal__bar {
		display: flex; align-items: center; gap: 0.75rem;
		padding: 1rem 1.25rem;
		border-bottom: 1px solid var(--border);
	}
	.search-modal__bar svg { color: rgb(var(--gray)); flex-shrink: 0; }
	.search-modal__bar input {
		flex: 1; border: none; outline: none;
		font-size: 1.05rem; font-family: inherit;
		background: transparent; color: rgb(var(--black));
	}
	.search-modal__close {
		background: none; border: none; cursor: pointer;
		font-size: 1rem; color: rgb(var(--gray));
		padding: 0.25rem; line-height: 1;
	}
	.search-modal__close:hover { color: rgb(var(--black)); }

	.search-modal__hints {
		display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;
		padding: 0.75rem 1.25rem;
		font-size: 0.82rem; color: rgb(var(--gray));
	}
	.search-modal__hints a {
		color: var(--primary); font-weight: 600;
		background: var(--primary-light);
		padding: 0.2rem 0.6rem; border-radius: 50px;
	}
	.search-modal__hints a:hover { background: var(--primary); color: #fff; }

	.search-results { max-height: 360px; overflow-y: auto; }
	.search-results[hidden] { display: none; }
	.sr-item {
		display: flex; align-items: center; gap: 0.75rem;
		padding: 0.65rem 1.25rem;
		color: rgb(var(--black));
		transition: background 0.1s;
	}
	.sr-item:hover { background: var(--primary-light); }
	.sr-emoji { font-size: 1.2rem; flex-shrink: 0; width: 28px; text-align: center; }
	.sr-info { display: flex; flex-direction: column; min-width: 0; }
	.sr-name { font-weight: 600; font-size: 0.9rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
	.sr-meta { font-size: 0.75rem; color: rgb(var(--gray)); }
	.sr-empty { padding: 1.5rem 1.25rem; text-align: center; font-size: 0.9rem; color: rgb(var(--gray)); }
</style>
